---
import HomeNewPage from "@determinant/site-kit/components/HomeNewPage.astro";
import BaseLayout from "@determinant/site-kit/layouts/BaseLayout.astro";
import { determinantSite } from "../../site.config";
---

<BaseLayout
  title="Consultoría e Ingeniería de IA Empresarial | Determinant Systems"
  description="Consultoría e ingeniería de IA empresarial para agentes gobernados, RAG, búsqueda, grafos de conocimiento, automatización y aplicaciones de IA."
  theme="midnight"
  lang="es"
  siteName={determinantSite.name}
  imageAlt="Consultoría e ingeniería de IA empresarial de Determinant Systems"
  alternates={[
    { lang: "en", href: "/" },
    { lang: "es", href: "/es/" },
    { lang: "x-default", href: "/" },
  ]}
>
  <HomeNewPage locale="es" />
</BaseLayout>
