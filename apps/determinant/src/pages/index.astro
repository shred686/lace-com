---
import HomeV2Page from "@determinant/site-kit/components/HomeV2Page.astro";
import BaseLayout from "@determinant/site-kit/layouts/BaseLayout.astro";
import { determinantSite, determinantJsonLd } from "../site.config";
---

<BaseLayout
  title={determinantSite.title}
  description={determinantSite.description}
  theme="midnight"
  lang="en"
  siteName={determinantSite.name}
  imageAlt="Determinant Systems enterprise AI consulting and engineering"
  alternates={[
    { lang: "en", href: "/" },
    { lang: "es", href: "/es/" },
    { lang: "x-default", href: "/" },
  ]}
  jsonLd={determinantJsonLd}
>
  <HomeV2Page />
</BaseLayout>
