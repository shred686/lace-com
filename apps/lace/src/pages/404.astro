---
import BaseLayout from "@determinant/site-kit/layouts/BaseLayout.astro";
import LaceNav from "@determinant/site-kit/components/lace/LaceNav.astro";
import LaceFooter from "@determinant/site-kit/components/lace/LaceFooter.astro";
import "@determinant/site-kit/styles/lace-site.css";
import { laceSite } from "../site.config";
---

<BaseLayout
  title={`Page Not Found | ${laceSite.name}`}
  description="The requested LACE page could not be found. Explore the enterprise AI platform, documentation, pricing, or contact the team."
  theme="lace"
  themeColor="#f6f7f9"
  siteName={laceSite.name}
  noindex={true}
>
  <main class="lp-site lp-not-found">
    <LaceNav />
    <section class="lp-not-found-main">
      <div class="lp-wrap">
        <p class="lp-kicker">404 · Page not found</p>
        <h1 class="lp-h1">This page is outside the graph.</h1>
        <p class="lp-lead">The URL may have changed or the page may no longer exist.</p>
        <div class="lp-not-found-actions">
          <a href="/" class="lp-btn lp-btn-primary">Return home</a>
          <a href="/platform/enterprise-search" class="lp-btn lp-btn-ghost">Explore the platform</a>
          <a href="/docs" class="lp-btn lp-btn-ghost">Read the docs</a>
        </div>
      </div>
    </section>
    <LaceFooter />
  </main>
</BaseLayout>

<style>
  .lp-not-found-main {
    display: grid;
    align-items: center;
    min-height: 72vh;
    padding: 9rem 0 5rem;
    text-align: center;
  }
  .lp-not-found-main h1 { max-width: 16ch; margin: 1rem auto; }
  .lp-not-found-main .lp-lead { max-width: 560px; margin-inline: auto; }
  .lp-not-found-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 2rem; }
</style>

