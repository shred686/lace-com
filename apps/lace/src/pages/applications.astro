---
import BaseLayout from "@determinant/site-kit/layouts/BaseLayout.astro";
import LaceNav from "@determinant/site-kit/components/lace/LaceNav.astro";
import LaceFooter from "@determinant/site-kit/components/lace/LaceFooter.astro";
import LaceCtaBand from "@determinant/site-kit/components/lace/LaceCtaBand.astro";
import "@determinant/site-kit/styles/lace-site.css";
import { breadcrumbSchema } from "@determinant/site-kit/seo/schema";
import { laceSite } from "../site.config";

const editions = [
  {
    id: "lace-gov",
    name: "LACE-GOV",
    market: "Federal · Defense · Intelligence",
    title: "Standards-conformant knowledge for the mission boundary.",
    accent: "the mission boundary.",
    body: "The platform packaged for federal programs: BFO/CCO-conformant schema packs, cross-enclave federated discovery without data movement, air-gapped deployment with no external AI calls, and accreditation evidence — lineage, access enforcement, and standards conformance — exportable as artifacts.",
    chips: ["BFO/CCO schema packs", "Cross-enclave federation", "Air-gapped deploys", "Accreditation evidence", "RFP & compliance drafting"],
  },
  {
    id: "lace-legal",
    name: "LACE Legal",
    market: "Legal · Compliance",
    title: "Contract intelligence with the receipts attached.",
    accent: "receipts attached.",
    body: "Obligation tracking, renewal and notice-period surveillance, and conflict detection across document versions — every extracted term linked to the clause it came from. Point-in-time queries answer “what did we know and when” for investigations and litigation holds.",
    chips: ["Obligation tracking", "Version conflict maps", "Point-in-time queries", "Clause-level citations", "Review workflows"],
  },
  {
    id: "lace-finance",
    name: "LACE Finance",
    market: "Financial Services",
    title: "Research where every figure traces to source.",
    accent: "traces to source.",
    body: "Grounded research and reporting over filings, agreements, and internal data — numeric answers come from the actual table cell, not a paraphrase. Auditable analysis workflows and agents operating under hard policy constraints.",
    chips: ["Table-native answers", "Auditable workflows", "Policy-bound agents", "Filing & report drafting", "Cost attribution"],
  },
];

const portfolio = [
  {
    name: "Proposal Studio",
    line: "RFP and proposal drafting grounded in your past performance library — every claim cited.",
  },
  {
    name: "Compliance Desk",
    line: "Regulatory frameworks mapped to your documents, with gap flags routed for review.",
  },
  {
    name: "Intake Triage",
    line: "An answers-and-actions desk across email, chat, and voice — approval gates included.",
  },
];

const description = "Explore LACE industry AI applications for government, defense, legal, compliance, and financial services, plus governed apps built and operated on LACE.";
---

<BaseLayout
  title={`Enterprise AI Applications for Regulated Industries | ${laceSite.name}`}
  description={description}
  theme="lace"
  themeColor="#f6f7f9"
  lang="en"
  siteName={laceSite.name}
  imageAlt="LACE enterprise AI applications for government, legal, and finance"
  jsonLd={[
    breadcrumbSchema([
      { name: "Home", url: `${laceSite.url}/` },
      { name: "Applications", url: `${laceSite.url}/applications/` },
    ]),
    {
      "@type": "ItemList",
      name: "LACE industry applications",
      itemListElement: editions.map((edition, index) => ({
        "@type": "ListItem",
        position: index + 1,
        url: `${laceSite.url}/applications/#${edition.id}`,
        name: edition.name,
      })),
    },
  ]}
>
  <main class="lp-site lp-apps">
    <LaceNav active="product" />

    <!-- ── Hero ───────────────────────────────────────────────────── -->
    <section class="lp-apps-hero">
      <div class="lp-wrap lp-head-center">
        <p class="lp-kicker" data-r>Applications</p>
        <h1 class="lp-h1 lp-apps-title" data-r data-reveal-delay="70">
          Software we ship.<br />
          <span class="lp-accent">On the platform we sell.</span>
        </h1>
        <p class="lp-lead lp-apps-lead" data-r data-reveal-delay="140">
          LACE-built, LACE-managed applications offered as products in their own
          right — packaged for the industries where auditability is the
          purchasing decision.
        </p>
      </div>
    </section>

    <!-- ── Industry editions ──────────────────────────────────────── -->
    <section class="lp-section-tight">
      <div class="lp-wrap lp-editions">
        {
          editions.map((edition, index) => (
            <article id={edition.id} class="lp-card lp-edition" data-r data-reveal-delay={80 + index * 60}>
              <div class="lp-edition-head">
                <span class="lp-edition-name">{edition.name}</span>
                <span class="lp-edition-market">{edition.market}</span>
              </div>
              <h2
                class="lp-h2 lp-edition-title"
                set:html={edition.title.replace(
                  edition.accent,
                  `<span class="lp-accent">${edition.accent}</span>`,
                )}
              />
              <p class="lp-edition-body">{edition.body}</p>
              <div class="lp-edition-chips">
                {edition.chips.map((chip) => (
                  <span class="lp-chip">{chip}</span>
                ))}
              </div>
              <a href="/contact" class="lp-edition-cta">Talk to us about {edition.name} →</a>
            </article>
          ))
        }
      </div>
    </section>

    <!-- ── Portfolio + build your own ─────────────────────────────── -->
    <section id="built-on-lace" class="lp-section lp-portfolio">
      <div class="lp-wrap">
        <div class="lp-head lp-head-center" data-r>
          <p class="lp-kicker">Built on LACE</p>
          <h2 class="lp-h2 lp-portfolio-title">
            Every app inherits the platform.<br />
            <span class="lp-accent">Including yours.</span>
          </h2>
          <p class="lp-oneliner">
            Apps we operate as products — and the same lane, open to you.
          </p>
        </div>

        <div class="lp-portfolio-grid">
          {
            portfolio.map((app, index) => (
              <article class="lp-card lp-card-hover lp-portfolio-card" data-r data-reveal-delay={100 + index * 70}>
                <span class="lp-portfolio-dot" aria-hidden="true"></span>
                <h3 class="lp-h3">{app.name}</h3>
                <p>{app.line}</p>
                <em class="lp-portfolio-tag">LACE-managed · subscription</em>
              </article>
            ))
          }
        </div>

        <div class="lp-launch" data-r>
          <div>
            <h3 class="lp-h3">Launch your own</h3>
            <p>
              Build it with the <a href="/platform/app-builder">App Builder</a> or the
              <a href="/docs#sdk">lace-app-sdk</a>, host it on LACE, and charge for
              it — billing, sign-in, releases, and rollback are already there.
            </p>
          </div>
          <a href="/contact" class="lp-btn lp-btn-primary">Start a build</a>
        </div>
      </div>
    </section>

    <LaceCtaBand
      title="Buy the platform. Or just the product."
      accent="the product."
      line="Editions and portfolio apps run on the same governed foundation — start wherever the pain is."
    />

    <LaceFooter />
  </main>
</BaseLayout>

<style>
  .lp-apps-hero {
    padding: clamp(8.5rem, 15vh, 11rem) 0 clamp(2rem, 4vw, 3rem);
  }

  .lp-apps-title {
    font-size: clamp(2.2rem, 5vw, 4rem);
  }

  .lp-apps-lead {
    max-width: 640px;
    margin: 1.5rem auto 0;
  }

  .lp-oneliner {
    margin: 0;
    font-size: clamp(1rem, 1.4vw, 1.14rem);
    line-height: 1.6;
    color: var(--lp-muted);
  }

  /* ── Editions ─────────────────────────────────────────────────── */
  .lp-editions {
    display: grid;
    gap: 1.2rem;
  }

  .lp-edition {
    scroll-margin-top: 5.5rem;
    padding: clamp(1.8rem, 4vw, 2.8rem);
    display: grid;
    gap: 1rem;
    background:
      radial-gradient(46rem 18rem at 100% 0%, rgba(var(--lp-green-rgb), 0.06), transparent 62%),
      #ffffff;
  }

  .lp-edition-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem;
  }

  .lp-edition-name {
    padding: 0.35rem 0.75rem;
    border-radius: var(--lp-radius);
    background: var(--lp-grad);
    color: #fff;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .lp-edition-market {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  .lp-edition-title {
    margin: 0;
    max-width: 24ch;
  }

  .lp-edition-body {
    margin: 0;
    max-width: 72ch;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--lp-muted);
  }

  .lp-edition-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .lp-edition-cta {
    justify-self: start;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--lp-green-deep);
  }

  .lp-edition-cta:hover {
    text-decoration: underline;
  }

  /* ── Portfolio ────────────────────────────────────────────────── */
  .lp-portfolio {
    scroll-margin-top: 5.5rem;
    background:
      radial-gradient(56rem 30rem at 50% 0%, rgba(var(--lp-green-rgb), 0.055), transparent 64%);
  }

  .lp-portfolio-title {
    font-size: clamp(1.8rem, 3.4vw, 2.8rem);
  }

  .lp-portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: clamp(2.4rem, 5vw, 3.6rem);
  }

  .lp-portfolio-card {
    padding: 1.6rem 1.5rem;
    display: grid;
    gap: 0.55rem;
    align-content: start;
  }

  .lp-portfolio-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--lp-green);
    box-shadow: 0 0 10px rgba(var(--lp-green-rgb), 0.6);
  }

  .lp-portfolio-card p {
    margin: 0;
    font-size: 0.86rem;
    line-height: 1.65;
    color: var(--lp-muted);
  }

  .lp-portfolio-tag {
    font-style: normal;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lp-green-deep);
  }

  .lp-launch {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.4rem;
    margin-top: clamp(2rem, 4vw, 3rem);
    padding: clamp(1.6rem, 3vw, 2.2rem);
    border: 1px solid rgba(var(--lp-green-rgb), 0.3);
    border-radius: var(--lp-radius-lg);
    background: #ffffff;
    box-shadow: var(--lp-shadow-sm);
  }

  .lp-launch h3 {
    margin-bottom: 0.4rem;
  }

  .lp-launch p {
    margin: 0;
    max-width: 56ch;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--lp-muted);
  }

  .lp-launch a:not(.lp-btn) {
    color: var(--lp-green-deep);
    font-weight: 600;
    text-decoration: none;
  }

  .lp-launch a:not(.lp-btn):hover {
    text-decoration: underline;
  }

  @media (max-width: 980px) {
    .lp-portfolio-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
