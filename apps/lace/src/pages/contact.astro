---
import BaseLayout from "@determinant/site-kit/layouts/BaseLayout.astro";
import LaceNav from "@determinant/site-kit/components/lace/LaceNav.astro";
import LaceFooter from "@determinant/site-kit/components/lace/LaceFooter.astro";
import "@determinant/site-kit/styles/lace-site.css";
import { laceSite } from "../site.config";
---

<BaseLayout
  title={`Contact | ${laceSite.name}`}
  description={`Talk with the ${laceSite.name} team about a demo, a technical evaluation, or an enterprise deployment.`}
  theme="lace"
  themeColor="#f6f7f9"
  lang="en"
  siteName={laceSite.name}
>
  <main class="lp-site lp-contact">
    <LaceNav />

    <section class="lp-contact-shell">
      <div class="lp-wrap lp-contact-grid">
        <div class="lp-contact-copy" data-r>
          <p class="lp-kicker">Contact</p>
          <h1 class="lp-h1 lp-contact-title">
            See it on<br />
            <span class="lp-accent">your documents.</span>
          </h1>
          <p class="lp-lead">
            Tell us about the corpus, the workflow, and where it needs to run.
            We'll map the first LACE path with you — and if we're not the right
            fit, we'll tell you that too.
          </p>

          <div class="lp-contact-direct">
            <a href={laceSite.contactPhoneHref} class="lp-contact-item">
              <span class="lp-contact-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path
                    d="M7.2 4.5h3.1l1.2 4.1-1.9 1.9a15.4 15.4 0 0 0 3.9 3.9l1.9-1.9 4.1 1.2v3.1a1.2 1.2 0 0 1-1.2 1.2A13.8 13.8 0 0 1 4.5 5.7 1.2 1.2 0 0 1 5.7 4.5h1.5Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
              <span>{laceSite.contactPhone}</span>
            </a>

            <a href={`mailto:${laceSite.contactEmail}`} class="lp-contact-item">
              <span class="lp-contact-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path
                    d="M4 7.5A1.5 1.5 0 0 1 5.5 6h13A1.5 1.5 0 0 1 20 7.5v9a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 4 16.5v-9Z"
                    stroke="currentColor"
                    stroke-width="1.5"></path>
                  <path
                    d="m5 8 7 5 7-5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
              <span>{laceSite.contactEmail}</span>
            </a>
          </div>

          <ul class="lp-contact-notes">
            <li>Enterprise briefings and technical evaluations under NDA</li>
            <li>Cloud, private cloud, on-premises, and air-gapped deployment</li>
            <li>Evaluations run in weeks, not quarters</li>
          </ul>
        </div>

        <div class="lp-card lp-contact-panel" data-r data-reveal-delay="120">
          <form
            class="lp-form"
            action="https://formsubmit.co/sales@laceplatform.com"
            method="POST"
          >
            <input type="hidden" name="_subject" value={`New contact form submission from ${laceSite.domain}`} />
            <input type="hidden" name="_next" value={`${laceSite.url}/contact/success`} />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_replyto" value="email" />

            <div class="lp-form-row">
              <label class="lp-field">
                <span>Name</span>
                <input type="text" name="name" placeholder="Jane Smith" required />
              </label>

              <label class="lp-field">
                <span>Work email</span>
                <input type="email" name="email" placeholder="jane@company.com" required />
              </label>
            </div>

            <label class="lp-field">
              <span>Company</span>
              <input type="text" name="company" placeholder="Company or program name" />
            </label>

            <label class="lp-field">
              <span>What should LACE run?</span>
              <textarea
                name="message"
                rows="6"
                placeholder="The corpus (contracts, filings, tickets…), the workflow (search, intake, review…), and any constraints (on-prem, air-gapped, standards)…"
                required></textarea>
            </label>

            <div class="lp-form-row">
              <label class="lp-field">
                <span>Timeline</span>
                <select name="timeline">
                  <option>Exploring options</option>
                  <option>This quarter</option>
                  <option>Immediately</option>
                </select>
              </label>

              <label class="lp-field">
                <span>Deployment preference</span>
                <select name="deployment">
                  <option>Not sure yet</option>
                  <option>Managed cloud</option>
                  <option>Private cloud (VPC)</option>
                  <option>On-premises / air-gapped</option>
                </select>
              </label>
            </div>

            <button type="submit" class="lp-btn lp-btn-primary lp-form-submit">
              Send inquiry
            </button>
          </form>
        </div>
      </div>
    </section>

    <LaceFooter />
  </main>
</BaseLayout>

<style>
  .lp-contact-shell {
    padding: clamp(8.5rem, 15vh, 11rem) 0 clamp(3rem, 6vw, 5rem);
  }

  .lp-contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }

  .lp-contact-title {
    font-size: clamp(2.1rem, 4.4vw, 3.5rem);
    margin-bottom: 1.4rem;
  }

  .lp-contact-direct {
    display: grid;
    gap: 0.7rem;
    margin-top: 1.7rem;
  }

  .lp-contact-item {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    width: fit-content;
    color: var(--lp-ink);
    font-size: 0.95rem;
    text-decoration: none;
  }

  .lp-contact-item:hover {
    color: var(--lp-green-deep);
  }

  .lp-contact-icon {
    display: inline-flex;
    flex: 0 0 2.2rem;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border: 1px solid rgba(var(--lp-green-rgb), 0.35);
    border-radius: var(--lp-radius);
    color: var(--lp-green-deep);
    background: rgba(var(--lp-green-rgb), 0.06);
  }

  .lp-contact-icon svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .lp-contact-notes {
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.6rem;
  }

  .lp-contact-notes li {
    position: relative;
    margin: 0;
    padding-left: 1.3rem;
    font-size: 0.86rem;
    color: var(--lp-muted);
  }

  .lp-contact-notes li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 0.8rem;
    height: 2px;
    background: var(--lp-green);
  }

  .lp-contact-panel {
    padding: clamp(1.5rem, 3.5vw, 2.4rem);
  }

  .lp-form {
    display: grid;
    gap: 1rem;
  }

  .lp-form-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .lp-field {
    display: grid;
    gap: 0.45rem;
    color: var(--lp-muted);
    font-size: 0.88rem;
  }

  .lp-field span {
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lp-ink-soft);
  }

  .lp-field input,
  .lp-field textarea,
  .lp-field select {
    width: 100%;
    padding: 0.85rem 0.9rem;
    border: 1px solid var(--lp-line);
    border-radius: var(--lp-radius);
    color: var(--lp-ink);
    background: #fdfefe;
    font: inherit;
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }

  .lp-field input:focus,
  .lp-field textarea:focus,
  .lp-field select:focus {
    outline: none;
    border-color: rgba(var(--lp-green-rgb), 0.6);
    box-shadow: 0 0 0 3px rgba(var(--lp-green-rgb), 0.14);
  }

  .lp-field textarea {
    resize: vertical;
  }

  .lp-form-submit {
    min-height: 3.1rem;
    border: 0;
  }

  @media (max-width: 860px) {
    .lp-contact-grid,
    .lp-form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
