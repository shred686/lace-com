---
import BaseLayout from "@determinant/site-kit/layouts/BaseLayout.astro";
import { laceSite } from "../site.config";
---

<BaseLayout
  title={`Contact | ${laceSite.name}`}
  description={`Talk with the ${laceSite.name} team about governed AI workflows and enterprise deployment.`}
  theme="midnight"
  lang="en"
>
  <main class="contact-page">
    <div class="noise-layer"></div>

    <section class="contact-shell ds-site">
      <header class="contact-nav" data-reveal>
        <a href="/" class="brand-wordmark">
          <span class="brand-dot"></span>
          <span>{laceSite.name}</span>
        </a>
        <a href="/" class="contact-nav-link">Back home</a>
      </header>

      <section class="contact-hero" data-reveal data-reveal-delay="60">
        <div class="contact-copy">
          <p class="eyebrow">Contact</p>
          <h1>Tell us which workflow needs structure.</h1>
          <div class="contact-direct">
            <a href={laceSite.contactPhoneHref} class="contact-direct-item">
              <span class="contact-direct-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path
                    d="M7.2 4.5h3.1l1.2 4.1-1.9 1.9a15.4 15.4 0 0 0 3.9 3.9l1.9-1.9 4.1 1.2v3.1a1.2 1.2 0 0 1-1.2 1.2A13.8 13.8 0 0 1 4.5 5.7 1.2 1.2 0 0 1 5.7 4.5h1.5Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  ></path>
                </svg>
              </span>
              <span>{laceSite.contactPhone}</span>
            </a>

            <a href={`mailto:${laceSite.contactEmail}`} class="contact-direct-item">
              <span class="contact-direct-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path
                    d="M4 7.5A1.5 1.5 0 0 1 5.5 6h13A1.5 1.5 0 0 1 20 7.5v9a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 4 16.5v-9Z"
                    stroke="currentColor"
                    stroke-width="1.5"
                  ></path>
                  <path
                    d="m5 8 7 5 7-5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  ></path>
                </svg>
              </span>
              <span>{laceSite.contactEmail}</span>
            </a>
          </div>
          <p class="lede">
            Send over the workflow, source documents, and constraints you are trying to
            govern. We will map the first LACE path with you.
          </p>
        </div>

        <div class="contact-panel" data-reveal data-reveal-delay="140">
          <form
            class="contact-form"
            action="https://formsubmit.co/sales@laceplatform.com"
            method="POST"
          >
            <input type="hidden" name="_subject" value={`New contact form submission from ${laceSite.domain}`} />
            <input type="hidden" name="_next" value={`${laceSite.url}/contact/success`} />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_replyto" value="email" />

            <div class="field-row">
              <label class="field">
                <span>Name</span>
                <input type="text" name="name" placeholder="Jane Smith" required />
              </label>

              <label class="field">
                <span>Email</span>
                <input type="email" name="email" placeholder="jane@company.com" required />
              </label>
            </div>

            <label class="field">
              <span>Company</span>
              <input type="text" name="company" placeholder="Company or team name" />
            </label>

            <label class="field">
              <span>Workflow to govern</span>
              <textarea
                name="message"
                rows="6"
                placeholder="We need a governed AI workflow for proposal drafting, compliance review, and source-grounded approvals..."
                required
              ></textarea>
            </label>

            <div class="field-row">
              <label class="field">
                <span>Timeline</span>
                <select name="timeline">
                  <option>Exploring options</option>
                  <option>This quarter</option>
                  <option>Immediately</option>
                </select>
              </label>

              <label class="field">
                <span>Deployment preference</span>
                <select name="deployment">
                  <option>Not sure yet</option>
                  <option>Cloud hosted</option>
                  <option>Private environment</option>
                </select>
              </label>
            </div>

            <button type="submit" class="submit-button">Send inquiry</button>
          </form>
        </div>
      </section>
    </section>
  </main>
</BaseLayout>

<style>
  .contact-page {
    position: relative;
    min-height: 100vh;
    overflow: clip;
  }

  .contact-shell {
    position: relative;
    z-index: 1;
    padding-top: 1.25rem;
  }

  .contact-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    padding: 0.95rem 1rem;
    border: 1px solid var(--line);
    background: rgba(7, 9, 12, 0.72);
    box-shadow: var(--shadow-md);
    backdrop-filter: blur(14px);
  }

  .contact-nav-link {
    color: var(--muted);
    text-decoration: none;
  }

  .contact-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  .contact-copy,
  .contact-panel {
    border: 1px solid var(--line);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.015)),
      rgba(6, 8, 11, 0.78);
    box-shadow: var(--shadow-lg);
    backdrop-filter: blur(16px);
  }

  .contact-copy,
  .contact-panel {
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .eyebrow {
    margin-bottom: 0.85rem;
    color: #8ee5d2;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .lede {
    max-width: 38rem;
    margin-top: 1.25rem;
    color: var(--muted);
    font-size: 1.02rem;
  }

  .contact-direct {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.35rem;
  }

  .contact-direct-item {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    width: fit-content;
    color: var(--text);
    text-decoration: none;
  }

  .contact-direct-icon {
    display: inline-flex;
    flex: 0 0 2.2rem;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border: 1px solid rgba(255, 255, 255, 0.13);
    color: #8ee5d2;
    background: rgba(255, 255, 255, 0.04);
  }

  .contact-direct-icon svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .contact-form {
    display: grid;
    gap: 1rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .field {
    display: grid;
    gap: 0.45rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .field input,
  .field textarea,
  .field select {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: var(--text);
    background: rgba(0, 0, 0, 0.24);
    padding: 0.85rem 0.9rem;
    font: inherit;
  }

  .field textarea {
    resize: vertical;
  }

  .submit-button {
    min-height: 3rem;
    border: 1px solid rgba(142, 229, 210, 0.45);
    color: #06100d;
    background: linear-gradient(135deg, #8ee5d2, #d9e6ff);
    font-weight: 700;
    cursor: pointer;
  }

  @media (max-width: 760px) {
    .contact-hero,
    .field-row {
      grid-template-columns: 1fr;
    }
  }
</style>
