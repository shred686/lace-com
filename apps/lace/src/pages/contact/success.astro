---
import BaseLayout from "@determinant/site-kit/layouts/BaseLayout.astro";
import "@determinant/site-kit/styles/lace-site.css";
import { laceSite } from "../../site.config";
---

<BaseLayout
  title={`Message Sent | ${laceSite.name}`}
  description={`Your message has been sent to ${laceSite.name}.`}
  theme="lace"
  themeColor="#f6f7f9"
  lang="en"
  siteName={laceSite.name}
  noindex={true}
>
  <main class="lp-site lp-success">
    <section class="lp-success-shell">
      <div class="lp-card lp-success-card" data-r>
        <p class="lp-kicker">Contact</p>
        <h1 class="lp-h2 lp-success-title">
          Message <span class="lp-accent">sent.</span>
        </h1>
        <p class="lp-success-copy">
          Thanks for reaching out. We'll review your note and follow up by
          email — usually within one business day.
        </p>
        <div class="lp-success-actions">
          <a href="/" class="lp-btn lp-btn-primary">Back home</a>
          <a href="/contact" class="lp-btn lp-btn-ghost">Send another message</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .lp-success-shell {
    display: grid;
    place-items: center;
    min-height: 100vh;
    padding: 2rem 1.5rem;
  }

  .lp-success-card {
    width: min(40rem, 100%);
    padding: clamp(2rem, 5vw, 3.2rem);
  }

  .lp-success-title {
    margin-bottom: 1rem;
  }

  .lp-success-copy {
    margin: 0;
    max-width: 34rem;
    color: var(--lp-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .lp-success-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }
</style>

<script>
  // No nav on this page — reveal immediately.
  document.querySelectorAll("[data-r]").forEach((el) => el.classList.add("vis"));
</script>
