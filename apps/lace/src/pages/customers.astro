---
import BaseLayout from "@determinant/site-kit/layouts/BaseLayout.astro";
import LaceNav from "@determinant/site-kit/components/lace/LaceNav.astro";
import LaceFooter from "@determinant/site-kit/components/lace/LaceFooter.astro";
import LaceCtaBand from "@determinant/site-kit/components/lace/LaceCtaBand.astro";
import "@determinant/site-kit/styles/lace-site.css";
import { laceSite } from "../site.config";

const stories = [
  {
    id: "federal",
    sector: "Federal program office",
    products: "Enterprise Search · LACE-GOV",
    title: "Searching 12 enclaves without moving a single document.",
    accent: "12 enclaves",
    situation:
      "A program office needed analysts to find what existed across a dozen compartmentalized environments — where copying data across boundaries was not an option, and every access had to be defensible.",
    action:
      "LACE's federated discovery layer indexed what each enclave would allow, enforced source permissions at query time, and returned cited results without any cross-boundary data movement. Deployment ran fully air-gapped, with no external AI calls.",
    outcome:
      "Analysts now see in seconds what exists and where — with an access-enforcement trail their security officers can audit line by line.",
    stats: [
      ["12", "enclaves federated"],
      ["0", "documents moved"],
      ["100%", "access-checked results"],
    ],
  },
  {
    id: "legal",
    sector: "Specialty legal team",
    products: "Knowledge Graph · LACE Legal",
    title: "Every obligation in 4,000 contracts — with the clause attached.",
    accent: "the clause attached.",
    situation:
      "A legal team managed thousands of agreements in shared drives. Renewal dates, notice periods, and obligations lived in institutional memory — and left with it.",
    action:
      "LACE extracted entities and obligations into a governed knowledge graph — every fact linked to its clause, duplicates merged into single entities, conflicting terms across versions flagged for review rather than silently resolved.",
    outcome:
      "Renewal surveillance became a query. When two contract versions disagreed on a notice period, the platform surfaced both passages side by side — before it became a dispute.",
    stats: [
      ["4,000+", "contracts mapped"],
      ["1", "click from fact to clause"],
      ["0", "silent conflict resolutions"],
    ],
  },
  {
    id: "operations",
    sector: "Shared-services organization",
    products: "Agentic Platform · App Builder",
    title: "An intake desk that answers on every channel — and asks first.",
    accent: "asks first.",
    situation:
      "An operations group fielded the same vendor and policy questions by email, chat, and phone — answered by whoever was free, with no record of what was said.",
    action:
      "A LACE intake agent now answers on email, Slack, and voice, grounded in the organization's own documents with citations. Sensitive replies route through one-click approval gates; the team shipped a companion status-tracking app with the App Builder in an afternoon.",
    outcome:
      "Routine questions resolve without a human touch — and every answer, source, and sign-off is on the record.",
    stats: [
      ["3", "channels, one agent"],
      ["100%", "of replies cited & logged"],
      ["1 afternoon", "to ship the tracking app"],
    ],
  },
];
---

<BaseLayout
  title={`Customer Stories | ${laceSite.name}`}
  description="How teams run governed AI on LACE: federated search across enclaves, evidence-locked contract intelligence, and policy-governed intake agents."
  theme="lace"
  themeColor="#f6f7f9"
  lang="en"
  siteName={laceSite.name}
>
  <main class="lp-site lp-customers">
    <LaceNav active="product" />

    <!-- ── Hero ───────────────────────────────────────────────────── -->
    <section class="lp-cust-hero">
      <div class="lp-wrap lp-head-center">
        <p class="lp-kicker" data-r>Customer stories</p>
        <h1 class="lp-h1 lp-cust-title" data-r data-reveal-delay="70">
          Real workflows.<br />
          <span class="lp-accent">On the record.</span>
        </h1>
        <p class="lp-lead lp-cust-lead" data-r data-reveal-delay="140">
          Engagement snapshots from the field — anonymized here, referenceable
          in briefings under NDA.
        </p>
      </div>
    </section>

    <!-- ── Stories ────────────────────────────────────────────────── -->
    <section class="lp-section-tight">
      <div class="lp-wrap lp-stories">
        {
          stories.map((story, index) => (
            <article id={story.id} class="lp-card lp-story" data-r data-reveal-delay={80 + index * 60}>
              <div class="lp-story-head">
                <span class="lp-story-pill">Customer story</span>
                <span class="lp-story-sector">{story.sector}</span>
                <span class="lp-story-products">{story.products}</span>
              </div>

              <h2
                class="lp-h2 lp-story-title"
                set:html={story.title.replace(
                  story.accent,
                  `<span class="lp-accent">${story.accent}</span>`,
                )}
              />

              <div class="lp-story-cols">
                <div>
                  <em>The situation</em>
                  <p>{story.situation}</p>
                </div>
                <div>
                  <em>What LACE did</em>
                  <p>{story.action}</p>
                </div>
                <div>
                  <em>The outcome</em>
                  <p>{story.outcome}</p>
                </div>
              </div>

              <div class="lp-story-stats">
                {story.stats.map(([value, label]) => (
                  <div>
                    <strong>{value}</strong>
                    <span>{label}</span>
                  </div>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <LaceCtaBand
      title="Your workflow could be next."
      accent="next."
      line="Bring the corpus and the process — we'll show you what it looks like governed on LACE."
    />

    <LaceFooter />
  </main>
</BaseLayout>

<style>
  .lp-cust-hero {
    padding: clamp(8.5rem, 15vh, 11rem) 0 clamp(2rem, 4vw, 3rem);
  }

  .lp-cust-title {
    font-size: clamp(2.2rem, 5vw, 4rem);
  }

  .lp-cust-lead {
    max-width: 560px;
    margin: 1.5rem auto 0;
  }

  .lp-stories {
    display: grid;
    gap: 1.2rem;
  }

  .lp-story {
    scroll-margin-top: 5.5rem;
    padding: clamp(1.8rem, 4vw, 2.8rem);
    display: grid;
    gap: 1.3rem;
    background:
      radial-gradient(46rem 18rem at 0% 0%, rgba(var(--lp-green-rgb), 0.05), transparent 62%),
      #ffffff;
  }

  .lp-story-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem;
  }

  .lp-story-pill {
    padding: 0.28rem 0.65rem;
    border-radius: var(--lp-radius);
    background: rgba(var(--lp-green-rgb), 0.12);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lp-green-deep);
  }

  .lp-story-sector {
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lp-ink);
  }

  .lp-story-products {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  .lp-story-title {
    margin: 0;
    max-width: 26ch;
  }

  .lp-story-cols {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.4rem;
  }

  .lp-story-cols em {
    display: block;
    margin-bottom: 0.45rem;
    font-style: normal;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--lp-green-deep);
  }

  .lp-story-cols p {
    margin: 0;
    font-size: 0.87rem;
    line-height: 1.68;
    color: var(--lp-muted);
  }

  .lp-story-stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.4rem, 4vw, 3rem);
    padding-top: 1.2rem;
    border-top: 1px solid var(--lp-line-soft);
  }

  .lp-story-stats strong {
    display: block;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: clamp(1.3rem, 2.2vw, 1.8rem);
    font-weight: 500;
    background: var(--lp-grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .lp-story-stats span {
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.56rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  @media (max-width: 880px) {
    .lp-story-cols {
      grid-template-columns: 1fr;
    }
  }
</style>
