<script>
  (() => {
    const topnav = document.getElementById("topnav");
    const toggle = document.querySelector(".official-topnav-toggle");
    const panel = document.getElementById("topNavPanel");

    if (topnav && toggle && panel) {
      const setOpen = (open) => {
        topnav.classList.toggle("is-open", open);
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      };

      toggle.addEventListener("click", () => {
        const open = !topnav.classList.contains("is-open");
        setOpen(open);
      });

      panel.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => setOpen(false));
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setOpen(false);
      });

      document.addEventListener("click", (event) => {
        if (!topnav.contains(event.target)) setOpen(false);
      });

      let navRaf = 0;
      const updateNav = () => {
        navRaf = 0;
        const progress = Math.min(1, Math.max(0, (window.scrollY - 20) / 100));
        topnav.style.setProperty("--nav-progress", String(progress));
      };
      const requestNav = () => {
        if (navRaf) return;
        navRaf = requestAnimationFrame(updateNav);
      };
      updateNav();
      window.addEventListener("scroll", requestNav, { passive: true });
      window.addEventListener("resize", requestNav);
    }
  })();

  // Dark → light flip around the LACE platform zone
  (() => {
    const zone = document.getElementById("light-zone");
    const veil = document.getElementById("lace-flash-veil");
    const home = document.querySelector(".official-home");
    if (!zone || !veil || !home) return;

    let isLight = false;
    let flashTimer = 0;
    let raf = 0;

    const clearFlash = () => {
      if (flashTimer) window.clearTimeout(flashTimer);
      flashTimer = 0;
      veil.classList.remove("flash-to-light", "flash-to-dark");
    };

    const applyLight = (on) => {
      zone.classList.toggle("is-light", on);
      home.classList.toggle("canvas-dim", on);
    };

    const setLight = (on) => {
      if (on === isLight) return;
      isLight = on;
      clearFlash();
      veil.classList.add(on ? "flash-to-light" : "flash-to-dark");
      flashTimer = window.setTimeout(() => {
        applyLight(on);
        flashTimer = 0;
      }, 90);
      window.setTimeout(clearFlash, 520);
    };

    const update = () => {
      raf = 0;
      const rect = zone.getBoundingClientRect();
      const mid = window.innerHeight * 0.55;
      setLight(rect.top < mid && rect.bottom > mid);
    };

    const requestUpdate = () => {
      if (raf) return;
      raf = requestAnimationFrame(update);
    };

    update();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
  })();

  (() => {
    const trigger = document.querySelector("[data-lightbox-trigger]");
    const lightbox = document.querySelector("[data-lightbox]");

    if (trigger && lightbox) {
      trigger.addEventListener("click", () => lightbox.showModal());

      lightbox.querySelector(".v2-lightbox-close")?.addEventListener("click", () => {
        lightbox.close();
      });

      lightbox.addEventListener("click", (event) => {
        if (event.target === lightbox) {
          lightbox.close();
        }
      });
    }
  })();

  // Enterprise search demo: cycle through typed queries with streaming results
  (() => {
    const panel = document.querySelector(".v2-search-panel");
    if (!panel) return;
    const queryEl = panel.querySelector(".v2-search-query");
    const resultsEl = panel.querySelector(".v2-search-results");
    if (!queryEl || !resultsEl) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const lockSvg =
      '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="5" y="10" width="14" height="10" stroke="currentColor" stroke-width="1.5"/><path d="M8 10V7a4 4 0 018 0v3" stroke="currentColor" stroke-width="1.5"/></svg>';

    const scenarios = [
      {
        query: "renewal terms for the Acme contract",
        results: [
          {
            badge: "PDF",
            title: "MSA-2024 — Master Service Agreement",
            meta: "§4.2 Renewal · SharePoint / Legal",
            score: 96
          },
          {
            badge: "WIKI",
            title: "Acme account — commercial summary",
            meta: "Last updated 3 weeks ago · Sales wiki",
            score: 81
          },
          {
            badge: "XLS",
            title: "Pricing model (restricted)",
            meta: "Hidden — this user doesn't have access",
            locked: true
          }
        ]
      },
      {
        query: "sales reps associated with Acme",
        results: [
          {
            badge: "CRM",
            title: "Acme Corp — account team",
            meta: "Owner: D. Reyes · Salesforce",
            score: 97
          },
          {
            badge: "EMAIL",
            title: "Intro call follow-up — Acme renewal",
            meta: "M. Chen → d.reyes · Gmail, last Tuesday",
            score: 88
          },
          {
            badge: "SLACK",
            title: "#acme-account — “Dana owns the Acme relationship…”",
            meta: "Slack · 14-message thread",
            score: 74
          }
        ]
      }
    ];

    const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

    const buildRow = (r) => {
      const row = document.createElement("div");
      row.className = "v2-search-row" + (r.locked ? " v2-search-row-locked" : "");
      const badge = document.createElement("span");
      badge.className = "v2-search-badge";
      badge.textContent = r.badge;
      const body = document.createElement("div");
      const title = document.createElement("strong");
      title.textContent = r.title;
      const meta = document.createElement("em");
      meta.textContent = r.meta;
      body.append(title, meta);
      row.append(badge, body);
      if (r.locked) {
        row.insertAdjacentHTML("beforeend", lockSvg);
      } else {
        const score = document.createElement("span");
        score.className = "v2-search-score";
        score.style.setProperty("--score", `${r.score}%`);
        row.appendChild(score);
      }
      return row;
    };

    let running = false;

    const run = async () => {
      if (running) return;
      running = true;
      resultsEl.classList.add("js-anim");
      resultsEl.querySelectorAll(".v2-search-row").forEach((row) => row.classList.add("is-in"));
      let index = 1; // static markup already shows scenario 0

      while (true) {
        await sleep(3200);

        // fade out current results
        resultsEl.classList.add("is-clearing");
        await sleep(360);
        resultsEl.innerHTML = "";
        resultsEl.classList.remove("is-clearing");

        // backspace the old query
        while (queryEl.textContent.length > 0) {
          queryEl.textContent = queryEl.textContent.slice(0, -1);
          await sleep(11);
        }
        await sleep(320);

        // type the new one
        const scenario = scenarios[index];
        for (const ch of scenario.query) {
          queryEl.textContent += ch;
          await sleep(34 + Math.random() * 42);
        }
        await sleep(430);

        // stream in results
        for (const r of scenario.results) {
          const row = buildRow(r);
          resultsEl.appendChild(row);
          requestAnimationFrame(() => requestAnimationFrame(() => row.classList.add("is-in")));
          await sleep(280);
        }

        index = (index + 1) % scenarios.length;
      }
    };

    const obs = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          obs.disconnect();
          run();
        }
      },
      { threshold: 0.35 }
    );
    obs.observe(panel);
  })();

  (() => {
    const els = Array.from(document.querySelectorAll("[data-r]"));
    els.forEach((el, i) => {
      const explicit = Number(el.getAttribute("data-reveal-delay"));
      const delay = Number.isFinite(explicit) ? explicit : i * 25;
      el.style.setProperty("--rd", `${delay}ms`);
    });

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("vis");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -4% 0px" }
    );

    els.forEach((el) => obs.observe(el));
  })();

  (() => {
    const canvas = document.getElementById("cta-canvas");
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const C = "255,216,111";
    let W = 0;
    let H = 0;
    let offset = 0;
    let glints = [];
    let raf = 0;

    const resize = () => {
      const host = canvas.parentElement;
      if (!host) return;
      W = canvas.width = host.offsetWidth;
      H = canvas.height = host.offsetHeight;
    };

    const drawLines = () => {
      const numLines = 90;
      for (let i = 0; i < numLines; i += 1) {
        const t = i / numLines;
        const y = t * H;
        const curl = (t - 0.5) * H * 0.55;
        const cp1x = W * 0.25;
        const cp1y = y - curl * 0.6;
        const cp2x = W * 0.75;
        const cp2y = y + curl * 0.4;
        const dy = (offset * 0.4) % (H / numLines);
        const fy = y + dy;
        const dist = Math.abs(t - 0.5);
        const baseOp = Math.max(0.02, 0.22 - dist * 0.35);

        ctx.beginPath();
        ctx.moveTo(0, fy);
        ctx.bezierCurveTo(cp1x, cp1y + dy, cp2x, cp2y + dy, W, fy - curl * 0.08);
        ctx.strokeStyle = `rgba(${C},${baseOp})`;
        ctx.lineWidth = 0.55;
        ctx.stroke();
      }
    };

    const spawnGlint = () => {
      glints.push({
        x: Math.random() * W * 0.8 + W * 0.1,
        y: Math.random() * H,
        life: 1,
        size: Math.random() * 3 + 2
      });
    };

    const drawGlints = () => {
      glints = glints.filter((g) => g.life > 0);
      glints.forEach((g) => {
        const op = g.life * 0.85;
        const gr = ctx.createRadialGradient(g.x, g.y, 0, g.x, g.y, g.size * 5);
        gr.addColorStop(0, `rgba(${C},${op})`);
        gr.addColorStop(0.3, `rgba(${C},${op * 0.4})`);
        gr.addColorStop(1, `rgba(${C},0)`);

        ctx.beginPath();
        ctx.arc(g.x, g.y, g.size * 5, 0, Math.PI * 2);
        ctx.fillStyle = gr;
        ctx.fill();

        ctx.beginPath();
        ctx.arc(g.x, g.y, g.size * 0.6, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${op})`;
        ctx.fill();

        g.life -= 0.025;
      });
    };

    const draw = () => {
      ctx.clearRect(0, 0, W, H);
      drawLines();
      drawGlints();
      offset += 1;
      if (Math.random() < 0.04) spawnGlint();
      raf = requestAnimationFrame(draw);
    };

    resize();
    draw();

    if (window.ResizeObserver) {
      const ro = new ResizeObserver(() => {
        cancelAnimationFrame(raf);
        resize();
        draw();
      });
      if (canvas.parentElement) ro.observe(canvas.parentElement);
    } else {
      window.addEventListener("resize", () => {
        cancelAnimationFrame(raf);
        resize();
        draw();
      });
    }
  })();

  (() => {
    const canvas = document.getElementById("neural-canvas");
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const home = document.querySelector(".official-home");
    const isLight = () => !!(home && home.classList.contains("canvas-dim"));
    // Dark: honey yellow. Light: deeper amber so the network remains visible on white.
    const C = () => isLight() ? "154,111,14" : "255,216,111";
    // Opacity scale: base values were tuned for dark bg; boost them for white.
    const os = () => isLight() ? 2.1 : 1;
    let nodes = [];
    let links = [];
    let layers = [];
    let signals = [];
    let W = 0;
    let H = 0;
    let raf = 0;
    let lastTs = 0;
    let nextSignalAt = 0;
    let nextSignalDirection = "forward";

    const clampValue = (value, min, max) => Math.min(max, Math.max(min, value));
    const lerp = (start, end, value) => start + (end - start) * value;

    const createLayeredNetwork = () => {
      nodes = [];
      links = [];
      layers = [];
      const isSmall = W <= 680;
      const counts = isSmall ? [1, 8, 8, 8, 1] : [1, 10, 12, 10, 1];
      const layerX = isSmall ? [0.055, 0.27, 0.5, 0.73, 0.945] : [0.045, 0.26, 0.5, 0.74, 0.955];
      const centerY = H * 0.5;
      const spread = Math.min(H * (isSmall ? 0.56 : 0.62), isSmall ? 430 : 560);

      const addNode = (x, y, layer, ordinal) => {
        const index = nodes.length;
        nodes.push({
          x,
          y,
          bx: x,
          by: y,
          layer,
          ordinal,
          phase: Math.random() * Math.PI * 2,
          r: layer === 0 || layer === counts.length - 1 ? 1.7 : 1.1 + Math.random() * 0.5,
          g: Math.random() * 0.2
        });
        return index;
      };

      const seen = new Set();
      const addLink = (a, b) => {
        const key = a < b ? `${a}:${b}` : `${b}:${a}`;
        if (seen.has(key)) return;
        seen.add(key);
        links.push({
          a,
          b,
          fromLayer: nodes[a].layer,
          toLayer: nodes[b].layer,
          seed: Math.random()
        });
      };

      counts.forEach((count, layer) => {
        const layerNodes = [];
        const x = W * layerX[layer];
        for (let ordinal = 0; ordinal < count; ordinal += 1) {
          const t = count === 1 ? 0.5 : ordinal / (count - 1);
          const y = count === 1 ? centerY : centerY - spread / 2 + spread * t;
          layerNodes.push(addNode(x, y, layer, ordinal));
        }
        layers.push(layerNodes);
      });

      layers.slice(0, -1).forEach((sourceLayer, layerIndex) => {
        const targetLayer = layers[layerIndex + 1];
        const isEdgeHop = layerIndex === 0 || layerIndex === layers.length - 2;

        sourceLayer.forEach((source, sourceIndex) => {
          if (isEdgeHop) {
            targetLayer.forEach((target) => addLink(source, target));
            return;
          }

          const targetCount = targetLayer.length;
          const sourceCount = sourceLayer.length;
          const projected = sourceCount === 1 ? 0 : Math.round((sourceIndex / (sourceCount - 1)) * (targetCount - 1));
          const shift = Math.max(2, Math.round(targetCount * 0.32));
          const targetOrdinals = new Set([
            projected,
            targetCount - 1 - projected,
            (projected + shift) % targetCount,
            (projected + targetCount - Math.max(1, Math.round(shift * 0.62))) % targetCount
          ]);

          targetOrdinals.forEach((targetOrdinal) => {
            addLink(source, targetLayer[targetOrdinal]);
          });
        });
      });
    };

    const resize = () => {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
      signals = [];
      lastTs = 0;
      createLayeredNetwork();
      nextSignalAt = 0;
      nextSignalDirection = "forward";
    };

    const layerLinks = (fromLayer, toLayer) =>
      links.filter((link) => link.fromLayer === fromLayer && link.toLayer === toLayer);

    const linkDelay = (link, stageIndex) => {
      const from = nodes[link.a];
      const to = nodes[link.b];
      const lastStageIndex = layers.length - 2;
      if (stageIndex === 0) return to.ordinal * 48;
      if (stageIndex === lastStageIndex) return from.ordinal * 44;
      return (from.ordinal * 34 + to.ordinal * 25 + link.seed * 68) % 230;
    };

    const spawnSignal = (now) => {
      if (signals.length > 1 || layers.length < 2) return;
      const direction = nextSignalDirection;
      const isBackward = direction === "backward";
      nextSignalDirection = isBackward ? "forward" : "backward";
      const traceMs = isBackward ? 440 + Math.random() * 80 : 540 + Math.random() * 90;
      const stageGap = isBackward ? 125 : 155;
      const lastLayerIndex = layers.length - 1;
      const chooseTargets = (layerIndex) => {
        const layerNodes = layers[layerIndex];
        if (layerIndex === 0 || layerIndex === lastLayerIndex) return layerNodes;

        const minActive = Math.max(2, Math.floor(layerNodes.length * 0.36));
        const maxActive = Math.max(minActive, layerNodes.length - 1);
        const activeCount = minActive + Math.floor(Math.random() * (maxActive - minActive + 1));
        return layerNodes
          .map((node) => ({ node, sort: Math.random() }))
          .sort((a, b) => a.sort - b.sort)
          .slice(0, activeCount)
          .map(({ node }) => node);
      };

      const buildStages = () => {
        let activeSources = new Set([isBackward ? layers[lastLayerIndex][0] : layers[0][0]]);
        const builtStages = [];

        for (let stageIndex = 0; stageIndex < lastLayerIndex; stageIndex += 1) {
          const fromLayer = isBackward ? lastLayerIndex - stageIndex : stageIndex;
          const toLayer = isBackward ? lastLayerIndex - stageIndex - 1 : stageIndex + 1;
          const targetPool = new Set(chooseTargets(toLayer));
          const stageLinks = (isBackward
            ? layerLinks(toLayer, fromLayer).map((link) => ({
                ...link,
                a: link.b,
                b: link.a,
                fromLayer,
                toLayer
              }))
            : layerLinks(fromLayer, toLayer)
          ).filter((link) => activeSources.has(link.a) && targetPool.has(link.b));

          if (!stageLinks.length) return null;

          builtStages.push({
            startOffset: stageIndex * (traceMs + stageGap),
            traceMs,
            links: stageLinks.map((link) => ({
              ...link,
              delay: linkDelay(link, stageIndex)
            }))
          });

          activeSources = new Set(stageLinks.map((link) => link.b));
        }

        return builtStages;
      };

      let stages = null;
      for (let attempt = 0; attempt < 6 && !stages; attempt += 1) {
        stages = buildStages();
      }

      if (!stages) return null;
      const signal = {
        stages,
        direction,
        source: isBackward ? layers[lastLayerIndex][0] : layers[0][0],
        start: now,
        glowMs: isBackward ? 560 : 700
      };
      signals.push(signal);
      return signal;
    };

    const stageEnd = (stage) => {
      let maxDelay = 0;
      stage.links.forEach((link) => {
        maxDelay = Math.max(maxDelay, link.delay);
      });
      return stage.startOffset + maxDelay + stage.traceMs;
    };

    const signalDuration = (signal) => {
      let end = 0;
      signal.stages.forEach((stage) => {
        end = Math.max(end, stageEnd(stage));
      });
      return end + signal.glowMs;
    };

    const applyNodeGlow = (nodeIndex, elapsed, fireAt, duration) => {
      if (elapsed < fireAt) return;
      const glow = clampValue(1 - (elapsed - fireAt) / duration, 0, 1);
      if (glow > 0) nodes[nodeIndex].g = Math.max(nodes[nodeIndex].g, glow);
    };

    const updateNodePositions = (now) => {
      nodes.forEach((node) => {
        node.x = node.bx;
        node.y = node.by;
        node.g = Math.max(0, node.g - 0.018);
      });
    };

    const drawReceivingNodes = (signal, elapsed) => {
      applyNodeGlow(signal.source, elapsed, 0, signal.glowMs);
      signal.stages.forEach((stage) => {
        stage.links.forEach((link) => {
          applyNodeGlow(link.b, elapsed, stage.startOffset + link.delay + stage.traceMs, signal.glowMs);
        });
      });
    };

    const drawStageTraces = (signal, elapsed, color, scale) => {
      signal.stages.forEach((stage, stageIndex) => {
        stage.links.forEach((link) => {
          const progress = (elapsed - stage.startOffset - link.delay) / stage.traceMs;
          const a = nodes[link.a];
          const b = nodes[link.b];

          if (progress >= 0 && progress <= 1) {
            const head = clampValue(progress, 0, 1);
            const directionScale = signal.direction === "backward" ? 0.74 : 1;
            const alpha = (0.1 + Math.sin(head * Math.PI) * 0.08) * scale * directionScale;
            drawTrace(a, b, head, alpha, color);
          } else if (progress > 1 && progress < 1.24) {
            const fade = 1 - (progress - 1) / 0.24;
            const directionScale = signal.direction === "backward" ? 0.68 : 1;
            drawStroke(a, b, (stageIndex === 1 ? 0.075 : 0.06) * fade * scale * directionScale, 0.74, color);
          }
        });
      });
    };

    const drawIdleNetwork = (color, scale) => {
      links.forEach((link) => {
        const a = nodes[link.a];
        const b = nodes[link.b];
        const op = (0.018 + (a.g + b.g) * 0.024) * scale;
        drawStroke(a, b, op, 0.38, color);
      });
    };

    const drawNodes = (color, scale) => {
      nodes.forEach((n) => {
        if (n.g > 0.15) {
          const gr = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r * 10);
          gr.addColorStop(0, `rgba(${color},${n.g * 0.34 * scale})`);
          gr.addColorStop(1, `rgba(${color},0)`);
          ctx.beginPath();
          ctx.arc(n.x, n.y, n.r * 10, 0, Math.PI * 2);
          ctx.fillStyle = gr;
          ctx.fill();
        }

        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${color},${Math.min(1, (0.12 + n.g * 0.72) * scale)})`;
        ctx.fill();
      });
    };

    const drawStroke = (a, b, alpha, width, color) => {
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = `rgba(${color},${alpha})`;
      ctx.lineWidth = width;
      ctx.stroke();
    };

    const drawTrace = (a, b, progress, alpha, color) => {
      const head = clampValue(progress, 0, 1);
      if (head <= 0) return;
      const to = {
        x: lerp(a.x, b.x, head),
        y: lerp(a.y, b.y, head)
      };
      const trace = ctx.createLinearGradient(a.x, a.y, to.x, to.y);
      trace.addColorStop(0, `rgba(${color},${alpha * 0.12})`);
      trace.addColorStop(0.58, `rgba(${color},${alpha * 0.42})`);
      trace.addColorStop(1, `rgba(255,243,184,${alpha})`);

      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(to.x, to.y);
      ctx.strokeStyle = trace;
      ctx.lineWidth = 1.08;
      ctx.lineCap = "butt";
      ctx.stroke();
    };

    const drawSignal = (signal, now, color, scale) => {
      const elapsed = now - signal.start;
      drawReceivingNodes(signal, elapsed);

      ctx.save();
      ctx.shadowColor = `rgba(${color},0.5)`;
      ctx.shadowBlur = 10;
      drawStageTraces(signal, elapsed, color, scale);
      ctx.restore();

      return elapsed < signalDuration(signal);
    };

    const draw = (ts) => {
      const now = ts || performance.now();
      lastTs = now;
      const color = C();
      const scale = os();

      ctx.clearRect(0, 0, W, H);
      updateNodePositions(now);

      drawIdleNetwork(color, scale);
      signals = signals.filter((signal) => drawSignal(signal, now, color, scale));
      drawNodes(color, scale);

      if (signals.length === 0 && now >= nextSignalAt) {
        const signal = spawnSignal(now);
        const roundPause = signal?.direction === "forward" ? 120 + Math.random() * 120 : 1200 + Math.random() * 1400;
        nextSignalAt = signal ? now + signalDuration(signal) + roundPause : now + 600;
      }

      raf = requestAnimationFrame(draw);
    };

    resize();
    draw();

    window.addEventListener("resize", () => {
      cancelAnimationFrame(raf);
      resize();
      draw();
    });
  })();
</script>
