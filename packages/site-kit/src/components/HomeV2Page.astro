const connectors = [
  { id: "gmail", name: "Gmail" },
  { id: "slack", name: "Slack" },
  { id: "teams", name: "Teams" },
  { id: "drive", name: "Google Drive" },
  { id: "notion", name: "Notion" },
  { id: "whatsapp", name: "WhatsApp" },
  { id: "salesforce", name: "Salesforce" },
  { id: "twilio", name: "Twilio" }
];

const zapSteps = [
  {
    icon: "gmail",
    kicker: "Trigger · Gmail",
    label: "A customer email arrives"
  },
  {
    icon: "lace",
    kicker: "Step 1 · LACE AI",
    label: "Reads it, pulls the order details, drafts a reply",
    ai: true
  },
  {
    icon: "slack",
    kicker: "Step 2 · Slack",
    label: "Manager approves with one click"
  },
  {
    icon: "salesforce",
    kicker: "Step 3 · Salesforce",
    label: "Reply sent, record updated, run logged"
  }
];
const zapLinkLabels = ["then", "needs sign-off", "approved"];

const copy = {
  toggleNav: "Toggle navigation",
  navServices: "What We Build",
  navPlatform: "Platform",
  navHow: "How We Work",
  navContact: "Contact us",

  heroTitle: "Make AI work for your company.",
  heroIntro: "Infrastructure for enterprise AI.",
  heroDetail:
    "Determinant Systems designs and builds AI systems that run on your data, inside your rules — LLM-powered workflows, retrieval, enterprise search, and knowledge graphs.",
  heroCtaPrimary: "TALK TO US",
  heroCtaSecondary: "Download whitepaper",

  introKicker: "Who We Are",
  introTitle: "We build the layer between AI models and your business.",
  introTitleAccent: "the layer",
  introLead:
    "The models are already good. The hard part is making them work inside a real company — connected to your data, aware of your rules, and accountable for what they produce. That's our job.",
  introBody:
    "Determinant Systems is an engineering firm. We integrate AI into the systems you already run — document stores, databases, CRMs, ticketing — and build the retrieval, search, and knowledge layers that make its answers worth trusting.",

  ctaLabel: "Get started",
  ctaTitle: "Bring us the work your team does by hand.",
  ctaTitleAccent: "by hand.",
  ctaBody:
    "Tell us about the process — we'll show you what it looks like as a system. And if we're not the right fit, we'll tell you that too.",
  ctaPrimary: "Talk to us",
  ctaSecondary: "Download the enterprise overview →",
  workflows: "Workflows",
  traceable: "Traceable",
  blackBoxes: "Black Boxes",
  footerTagline: "Enterprise AI infrastructure",
  security: "Security",
  privacy: "Privacy"
};

const serviceTiles = [
  {
    href: "#workflows",
    accent: "#00ffc2",
    title: "LLM-Powered Workflows",
    blurb: "AI that executes a business process step by step, with checks along the way.",
    icon: "flow"
  },
  {
    href: "#rag",
    accent: "#ffd86f",
    title: "Retrieval-Augmented Generation",
    blurb: "Answers written from your documents, with citations you can open.",
    icon: "doc"
  },
  {
    href: "#search",
    accent: "#7aa2ff",
    title: "Enterprise Search",
    blurb: "One search across every place your company keeps information.",
    icon: "search"
  },
  {
    href: "#graphs",
    accent: "#c58dff",
    title: "Knowledge Graphs",
    blurb: "Your documents, distilled into a network of facts you can query.",
    icon: "graph"
  }
];

const services = {
  workflows: {
    kicker: "AI Integrations",
    title: "LLM-powered workflows, wired into the systems you already use.",
    titleAccent: "the systems you already use",
    paragraphs: [
      "Most AI projects stall at the demo stage — impressive in a browser tab, useless in your operation. We take a process your team runs every week — intake, triage, drafting, review, reporting — and build it as a workflow the AI executes step by step, inside your systems.",
      "Each step has defined inputs, outputs, and checks. If a result doesn't pass, it routes to a person instead of going out the door. If it does pass, the next step picks it up automatically."
    ],
    points: [
      {
        title: "Connects to what you run today",
        detail: "CRMs, ticketing, email, file stores, and internal databases."
      },
      {
        title: "Human approval where it matters",
        detail: "You decide which steps need sign-off before anything moves."
      },
      {
        title: "Every run is logged",
        detail: "See what came in, what the AI did, and who approved what."
      }
    ]
  },
  rag: {
    kicker: "Retrieval-Augmented Generation",
    title: "Answers from your documents, not from the model's memory.",
    titleAccent: "your documents",
    paragraphs: [
      "On its own, a language model answers from whatever it absorbed during training — which is why it sounds confident about things it can't possibly know, like your contracts. Retrieval-augmented generation fixes that: the system finds the relevant passages in your documents first, then writes the answer from what it found.",
      "We build the version of this that survives real documents. Tables stay tables. Sections keep their context. A numeric question is answered from the actual figure in the actual table — and the citation takes you straight to it."
    ],
    points: [
      {
        title: "Citations you can open",
        detail: "Every claim links back to the page it came from."
      },
      {
        title: "Tables and figures, understood",
        detail: "Structure is preserved, not flattened into a soup of text."
      },
      {
        title: "“I don't know” is an answer",
        detail: "When the sources don't support a claim, the system says so."
      }
    ]
  },
  search: {
    kicker: "Enterprise Search",
    title: "One search across everything your company knows.",
    titleAccent: "everything your company knows",
    paragraphs: [
      "The answer usually exists. It's in SharePoint, or a shared drive, or a wiki, or a database someone set up in 2019. The problem isn't that your company lacks information — it's that nobody can find it.",
      "We build search that spans those sources in a single query, understands what you mean rather than just matching keywords, and respects permissions — people only ever see results they're allowed to see."
    ],
    points: [
      {
        title: "All your sources, one query",
        detail: "SharePoint, Google Drive, OneDrive, Notion, databases, and more."
      },
      {
        title: "Meaning, not just keywords",
        detail: "“Termination clause” finds the right paragraph even when it never uses those words."
      },
      {
        title: "Permissions carry through",
        detail: "Access rules from the source systems are enforced on every result."
      }
    ]
  },
  graphs: {
    kicker: "Knowledge Graphs",
    title: "Turn a pile of documents into a map of facts.",
    titleAccent: "a map of facts",
    paragraphs: [
      "Search finds documents. A knowledge graph finds what's inside them: the companies, people, contracts, dates, and amounts — and how they connect. Which agreements renew this quarter? Which vendors touch customer data? Questions that used to mean a week of reading become a query.",
      "Every fact in the graph links back to the passage it came from, so you can verify it in seconds. And when two sources disagree, the graph keeps both versions and flags the conflict instead of quietly picking one."
    ],
    points: [
      {
        title: "Built from your documents",
        detail: "Extracted automatically, reviewed by people where it counts."
      },
      {
        title: "Every fact has a source",
        detail: "Click through from any fact to the exact sentence behind it."
      },
      {
        title: "Disagreements surface",
        detail: "Conflicting information is flagged, never silently resolved."
      }
    ]
  }
};

const lace = {
  kicker: "Our Platform",
  titleLead: "Everything above runs on",
  titleAccent: "LACE.",
  lead:
    "LACE is the enterprise AI platform we built to deliver this work. Workflows, retrieval, search, and knowledge graphs aren't four separate projects — they're four capabilities of one system, with the same governance underneath: every action is permissioned, every output traces back to its source, and a person can be put in the loop anywhere.",
  sub:
    "For your team, that means an engagement doesn't start from a blank repository. It starts from a platform that already handles the unglamorous parts — connectors, ingestion, orchestration, audit trails, deployment — so the work is about your process, not plumbing.",
  pillars: [
    {
      glyph: "→",
      title: "Workflows",
      body: "Define a process once, then run it as a governed pipeline — typed steps, checkpoints, and a full history of every run."
    },
    {
      glyph: "⊕",
      title: "Agents",
      body: "AI assistants with explicit capabilities. What they can read, do, and spend is set by you and enforced by the platform."
    },
    {
      glyph: "◈",
      title: "Knowledge",
      body: "Connect document stores and databases; get retrieval, enterprise search, and knowledge graphs over all of it."
    },
    {
      glyph: "⬡",
      title: "Apps",
      body: "Package a proven workflow as an internal tool or a full application — without building new infrastructure."
    },
    {
      glyph: "⋯",
      title: "Assistant",
      body: "A copilot that operates the platform on your behalf, through the same permissions as everyone else."
    }
  ],
  governance: [
    {
      title: "Policy-governed",
      body: "Budgets, data access, model usage, and approval rules are enforced by the platform — not by trusting the AI."
    },
    {
      title: "Traceable",
      body: "Every output links back to its sources and to the steps that produced it. Auditors get answers, not shrugs."
    },
    {
      title: "Human in the loop",
      body: "Review gates go wherever a decision is too important to automate. Nothing ships without the sign-offs you require."
    }
  ],
  deployChips: ["Cloud", "Private Cloud", "On-Premise", "Air-Gapped"],
  ctaPrimary: "Download the platform overview",
  ctaSecondary: "Talk to us about LACE"
};

const engagement = {
  kicker: "Working With Us",
  title: "Start with one workflow. Prove it. Expand.",
  titleAccent: "one workflow",
  lead: "We're a small senior team, and we work in weeks, not quarters.",
  steps: [
    {
      title: "Scope",
      body: "We pick one process together — something recurring, measurable, and painful — and define what “working” means before anything gets built."
    },
    {
      title: "Build",
      body: "You get a working system on your own data, usually within a few weeks. You judge it on real output, not slides."
    },
    {
      title: "Run",
      body: "We deploy it where you need it — cloud, private cloud, or fully on-premise — and either operate it with you or hand it over."
    }
  ]
};

const emphasize = (title: string, accent?: string) =>
  accent ? title.replace(accent, `<span class="lace-accent-word">${accent}</span>`) : title;

const heroTitleWords = copy.heroTitle.split(" ");
const heroDesktopTitleLead = heroTitleWords.slice(0, 4).join(" ");
const heroDesktopTitleRest = heroTitleWords.slice(4).join(" ");
const heroMobileTitleLines = ["Make", "AI", "work", "for", "you."];

const year = new Date().getFullYear();
---

<main class="official-home home-v2">
  <canvas id="neural-canvas" class="neural-canvas" aria-hidden="true"></canvas>

  <header id="topnav" class="official-topnav" data-r>
    <div class="official-topnav-inner">
      <a href="/" class="brand-mark">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="3" fill="#00FFC2"></circle>
          <circle cx="9" cy="9" r="6.5" stroke="#00FFC2" stroke-width="0.5" opacity="0.4"></circle>
          <circle cx="9" cy="9" r="9" stroke="#00FFC2" stroke-width="0.3" opacity="0.15"></circle>
        </svg>
        <span>DETERMINANT SYSTEMS</span>
      </a>

      <button class="official-topnav-toggle" type="button" aria-expanded="false" aria-label={copy.toggleNav}>
        <span></span>
        <span></span>
      </button>

      <div class="official-topnav-panel" id="topNavPanel">
        <nav class="official-topnav-links" aria-label="Primary">
          <a href="#services">{copy.navServices}</a>
          <a href="#platform">{copy.navPlatform}</a>
          <a href="#how-we-work">{copy.navHow}</a>
        </nav>

        <div class="official-topnav-actions">
          <a href="/contact" class="nav-deploy-link">{copy.navContact}</a>
        </div>
      </div>
    </div>
  </header>

  <section class="official-hero section-shell">
    <div class="hero-radial-glow" aria-hidden="true"></div>

    <div class="official-hero-content" data-r>
      <h1 aria-label={copy.heroTitle}>
        <span class="hero-title-desktop" aria-hidden="true">
          {heroDesktopTitleLead}<br />
          <span class="accent-glow">{heroDesktopTitleRest}</span>
        </span>
        <span class="hero-title-mobile" aria-hidden="true">
          {heroMobileTitleLines.map((line, index) => (
            <span
              class:list={[
                "hero-title-line",
                `hero-title-line-${index + 1}`,
                index === heroMobileTitleLines.length - 1 && "accent-glow"
              ]}
            >
              {line}
            </span>
          ))}
        </span>
      </h1>

      <p class="hero-intro">{copy.heroIntro}</p>
      <p class="hero-detail">{copy.heroDetail}</p>

      <div class="hero-actions">
        <a href="/contact" class="hero-btn hero-btn-primary">
          {copy.heroCtaPrimary}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5"></path>
          </svg>
        </a>
        <a href={whitepaperEnglish} target="_blank" rel="noopener noreferrer" class="hero-btn hero-btn-ghost">
          {copy.heroCtaSecondary}
        </a>
      </div>
    </div>

    <div class="hero-bottom-glow" aria-hidden="true"></div>
  </section>

  <!-- ── Company intro + scope of work ─────────────────────────────── -->
  <section id="services" class="v2-section v2-intro">
    <div class="v2-wrap">
      <div class="v2-intro-copy" data-r>
        <p class="section-kicker">{copy.introKicker}</p>
        <h2 class="v2-h2" set:html={emphasize(copy.introTitle, copy.introTitleAccent)} />
        <p class="v2-lead">{copy.introLead}</p>
        <p class="v2-body">{copy.introBody}</p>
      </div>

      <div class="v2-tile-grid">
        {serviceTiles.map((tile, index) => (
          <a
            href={tile.href}
            class="v2-tile"
            style={`--tile-accent: ${tile.accent};`}
            data-r
            data-reveal-delay={120 + index * 80}
          >
            <span class="v2-tile-icon" aria-hidden="true">
              {tile.icon === "flow" && (
                <svg viewBox="0 0 24 24" fill="none">
                  <rect x="2" y="9" width="6" height="6" stroke="currentColor" stroke-width="1.4" />
                  <rect x="16" y="2" width="6" height="6" stroke="currentColor" stroke-width="1.4" />
                  <rect x="16" y="16" width="6" height="6" stroke="currentColor" stroke-width="1.4" />
                  <path d="M8 12h4m0 0V5h4m-4 7v7h4" stroke="currentColor" stroke-width="1.4" />
                </svg>
              )}
              {tile.icon === "doc" && (
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M5 2h9l5 5v15H5z" stroke="currentColor" stroke-width="1.4" />
                  <path d="M14 2v5h5" stroke="currentColor" stroke-width="1.4" />
                  <path d="M8 12h8M8 15.5h8M8 19h5" stroke="currentColor" stroke-width="1.4" />
                </svg>
              )}
              {tile.icon === "search" && (
                <svg viewBox="0 0 24 24" fill="none">
                  <circle cx="10.5" cy="10.5" r="6.5" stroke="currentColor" stroke-width="1.4" />
                  <path d="M15.5 15.5L21 21" stroke="currentColor" stroke-width="1.4" />
                </svg>
              )}
              {tile.icon === "graph" && (
                <svg viewBox="0 0 24 24" fill="none">
                  <circle cx="5" cy="19" r="2.6" stroke="currentColor" stroke-width="1.4" />
                  <circle cx="12" cy="5" r="2.6" stroke="currentColor" stroke-width="1.4" />
                  <circle cx="19" cy="15" r="2.6" stroke="currentColor" stroke-width="1.4" />
                  <path d="M6.5 16.8L10.7 7.3M14.4 6.6l3.2 6.3M7.6 18.4l8.9-2.7" stroke="currentColor" stroke-width="1.4" />
                </svg>
              )}
            </span>
            <h3>{tile.title}</h3>
            <p>{tile.blurb}</p>
            <span class="v2-tile-more" aria-hidden="true">See how →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="neural-separator section-shell" aria-hidden="true"></div>

  <!-- ── Service: LLM-powered workflows ────────────────────────────── -->
  <section id="workflows" class="v2-section v2-service" style="--svc: #00ffc2; --svc-rgb: 0, 255, 194;">
    <div class="v2-wrap">
      <div class="v2-copy" data-r>
        <p class="v2-kicker">{services.workflows.kicker}</p>
        <h2 class="v2-h2" set:html={emphasize(services.workflows.title, services.workflows.titleAccent)} />
        {services.workflows.paragraphs.map((paragraph) => (
          <p class="v2-body">{paragraph}</p>
        ))}
        <ul class="v2-points">
          {services.workflows.points.map((point) => (
            <li>
              <strong>{point.title}</strong>
