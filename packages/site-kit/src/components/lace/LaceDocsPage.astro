---
/**
 * laceplatform.com/docs — documentation shell (Mintlify-style).
 * Own header (search, GitHub, status), left sidebar nav with live filter
 * and scrollspy, prose content column, right "On this page" rail.
 * Namespace: lpd-* (docs shell) on top of the lp-* tokens.
 */
import "../../styles/lace-site.css";

const sidebar = [
  {
    group: "Get Started",
    items: [
      { id: "introduction", label: "Introduction" },
      { id: "organization", label: "How LACE is organized" },
      { id: "deployment", label: "Deployment options" },
    ],
  },
  {
    group: "lace-app-sdk",
    items: [
      { id: "install", label: "Install" },
      { id: "quickstart", label: "Quickstart" },
      { id: "manifest", label: "Manifest" },
      { id: "data", label: "Data collections" },
      { id: "tools", label: "Tools" },
      { id: "agents", label: "Agents & skills" },
      { id: "modules", label: "Module reference" },
    ],
  },
  {
    group: "Platform Guide",
    items: [
      { id: "datasets", label: "Datasets & connectors" },
      { id: "search-rag", label: "Search & RAG" },
      { id: "knowledge-graph", label: "Knowledge graph" },
      { id: "agents-channels", label: "Agents & channels" },
      { id: "workflows", label: "Workflows & pipelines" },
      { id: "app-builder", label: "App Builder" },
      { id: "governance", label: "Governance & security" },
    ],
  },
];

const modules = [
  ["manifest", "LaceAppManifest — the canonical app declaration: routes, tools, pipelines, agents, data, UI, schedules, migrations."],
  ["data", "App-owned collections, records, and queries plus blob storage — served through the governed AppDataService."],
  ["tools", "Custom tool providers with metadata, registration, and trust-tiered execution contexts."],
  ["agents", "Agent definitions, capabilities, loop-guard config, in-loop skills, approval gates, hooks, and guardrails."],
  ["skills", "Reusable agent skills (AgentSkill) declared inside agent definitions."],
  ["pipelines", "Pipeline providers that contribute typed steps to the workflow graph."],
  ["routes", "HTTP route providers served by the sidecar app runtime."],
  ["connectors", "Dataset connector contracts: capability manifest and runtime protocol."],
  ["memory", "Identity-scoped memory: custom axes, formation hooks, and governed retrieval."],
  ["policy", "App policy providers for access and action rules."],
  ["migrations", "App-owned schema evolution, applied through the platform lifecycle."],
  ["ui", "Runtime-UI declarations loaded by the frontend plugin host."],
  ["testing", "Harnesses for validating app builds before they're sealed and published."],
];

/* Hand-highlighted code samples (mirror the real lace_app_sdk contracts). */
const codeInstall = `<span class="tk-c"># Python 3.11+</span>
<span class="tk-f">pip</span> <span class="tk-n">install</span> lace-app-sdk`;

const codeManifest = `<span class="tk-c"># app.py — one file declares the whole app. LACE discovers the rest.</span>
<span class="tk-k">from</span> lace_app_sdk.manifest <span class="tk-k">import</span> <span class="tk-n">LaceAppManifest</span>
<span class="tk-k">from</span> app.data <span class="tk-k">import</span> <span class="tk-n">TICKETS</span>

<span class="tk-n">MANIFEST</span> = <span class="tk-f">LaceAppManifest</span>(
    app_id=<span class="tk-s">"acme.field_intake"</span>,
    display_name=<span class="tk-s">"Field Intake"</span>,
    version=<span class="tk-s">"0.1.0"</span>,
    data_collections=[<span class="tk-n">TICKETS</span>],
    tool_providers=[<span class="tk-s">"app.tools:ToolProvider"</span>],
    agent_providers=[<span class="tk-s">"app.agents:AgentProvider"</span>],
    route_providers=[<span class="tk-s">"app.routes:RouteProvider"</span>],
)`;

const codeData = `<span class="tk-c"># app/data.py — typed, tenant-scoped collections with an admin panel for free.</span>
<span class="tk-k">from</span> lace_app_sdk.data <span class="tk-k">import</span> <span class="tk-n">AppDataCollectionSchema</span>

<span class="tk-n">TICKETS</span> = <span class="tk-f">AppDataCollectionSchema</span>(
    app_id=<span class="tk-s">"acme.field_intake"</span>,
    collection_id=<span class="tk-s">"tickets"</span>,
    display_name=<span class="tk-s">"Intake Tickets"</span>,
    storage_backend=<span class="tk-s">"generic_app_data"</span>,
    json_schema={
        <span class="tk-s">"type"</span>: <span class="tk-s">"object"</span>,
        <span class="tk-s">"properties"</span>: {
            <span class="tk-s">"subject"</span>:  {<span class="tk-s">"type"</span>: <span class="tk-s">"string"</span>},
            <span class="tk-s">"priority"</span>: {<span class="tk-s">"enum"</span>: [<span class="tk-s">"low"</span>, <span class="tk-s">"normal"</span>, <span class="tk-s">"urgent"</span>]},
            <span class="tk-s">"evidence_blob"</span>: {<span class="tk-s">"type"</span>: <span class="tk-s">"string"</span>},
        },
    },
)`;

const codeTools = `<span class="tk-c"># app/tools.py — custom tools run in constrained runtimes; trust tier checked on dispatch.</span>
<span class="tk-k">from</span> lace_app_sdk.tools <span class="tk-k">import</span> <span class="tk-n">AppToolMetadata</span>, <span class="tk-n">AppToolContext</span>

<span class="tk-k">class</span> <span class="tk-n">ToolProvider</span>:
    app_id = <span class="tk-s">"acme.field_intake"</span>

    <span class="tk-k">def</span> <span class="tk-f">tool_metadata</span>(<span class="tk-k">self</span>) -&gt; <span class="tk-n">AppToolMetadata</span>:
        <span class="tk-k">return</span> <span class="tk-f">AppToolMetadata</span>(
            app_id=<span class="tk-k">self</span>.app_id,
            bundle_id=<span class="tk-s">"field_intake.tools"</span>,
            tool_ids=[<span class="tk-s">"lookup_ticket"</span>, <span class="tk-s">"escalate"</span>],
            exposure_scope=<span class="tk-s">"agent_only"</span>,
        )

    <span class="tk-k">def</span> <span class="tk-f">register_tools</span>(<span class="tk-k">self</span>, registry, context: <span class="tk-n">AppToolContext</span> | <span class="tk-k">None</span> = <span class="tk-k">None</span>):
        registry.<span class="tk-f">register</span>(<span class="tk-s">"lookup_ticket"</span>, handler=lookup_ticket)
        registry.<span class="tk-f">register</span>(<span class="tk-s">"escalate"</span>, handler=escalate)`;

const codeAgents = `<span class="tk-c"># app/agents.py — a real agentic loop, with an approval gate on the risky tool.</span>
<span class="tk-k">from</span> lace_app_sdk.agents <span class="tk-k">import</span> <span class="tk-n">AgentDefinition</span>, <span class="tk-n">ToolCapability</span>
<span class="tk-k">from</span> lace_app_sdk.skills <span class="tk-k">import</span> <span class="tk-n">AgentSkill</span>

<span class="tk-k">class</span> <span class="tk-n">AgentProvider</span>:
    app_id = <span class="tk-s">"acme.field_intake"</span>

    <span class="tk-k">def</span> <span class="tk-f">agent_definitions</span>(<span class="tk-k">self</span>):
        <span class="tk-k">return</span> [
            <span class="tk-f">AgentDefinition</span>(
                agent_id=<span class="tk-s">"intake-triage"</span>,
                slug=<span class="tk-s">"intake-triage"</span>,
                name=<span class="tk-s">"Intake Triage"</span>,
                description=<span class="tk-s">"Classifies tickets, drafts replies with citations."</span>,
                capabilities=[
                    <span class="tk-f">ToolCapability</span>(tool_id=<span class="tk-s">"lookup_ticket"</span>),
                    <span class="tk-f">ToolCapability</span>(tool_id=<span class="tk-s">"escalate"</span>, approval_required=<span class="tk-k">True</span>),
                ],
            )
        ]`;

const toc = [
  { id: "introduction", label: "Introduction" },
  { id: "organization", label: "How LACE is organized" },
  { id: "deployment", label: "Deployment options" },
  { id: "install", label: "Install the SDK" },
  { id: "quickstart", label: "Quickstart" },
  { id: "modules", label: "Module reference" },
  { id: "datasets", label: "Platform guide" },
  { id: "governance", label: "Governance & security" },
];
---

<div class="lpd">
  <!-- ── Docs header ──────────────────────────────────────────────── -->
  <header class="lpd-header">
    <div class="lpd-header-row">
      <a href="/" class="lpd-brand" aria-label="LACE home">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="3" fill="#00A882"></circle>
          <circle cx="9" cy="9" r="6.5" stroke="#00A882" stroke-width="0.7" opacity="0.5"></circle>
        </svg>
        <span>LACE</span>
      </a>

      <div class="lpd-select" data-select>
        <button type="button" aria-haspopup="listbox" aria-expanded="false">
          <span data-select-label>v0.1</span>
          <svg width="9" height="9" viewBox="0 0 10 10" fill="none" aria-hidden="true">
