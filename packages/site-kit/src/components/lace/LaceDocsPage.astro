          <path d="M15.5 15.5L21 21" stroke="currentColor" stroke-width="1.6"></path>
        </svg>
        <input type="search" placeholder="Search docs…" data-docs-search autocomplete="off" />
        <kbd>Ctrl K</kbd>
      </label>

      <div class="lpd-header-actions">
        <a
          href="https://github.com/Determinant-Systems"
          target="_blank"
          rel="noopener noreferrer"
