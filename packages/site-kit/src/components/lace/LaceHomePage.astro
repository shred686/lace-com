<style>
  /* ═══ The frame: hairline rails + crosshair intersections ═══════ */
  .lp2 {
    --hair: rgba(13, 27, 22, 0.09);
    --hair-soft: rgba(13, 27, 22, 0.055);
  }

  .lp2-frame {
    position: relative;
    width: min(1180px, calc(100% - 3rem));
    margin-inline: auto;
    /* The full-bleed hero above already clears the fixed nav, so the
       frame only needs a little breathing room before the marquee. */
    padding-top: clamp(1.5rem, 4vw, 3rem);
  }

  @media (min-width: 1080px) {
    .lp2-frame::before,
    .lp2-frame::after {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      width: 1px;
      background: var(--hair);
    }

    .lp2-frame::before { left: 0; }
    .lp2-frame::after { right: 0; }

    /* crosshairs where section borders meet the rails */
    .lp2-frame > section {
      position: relative;
    }

    .lp2-frame > section::before,
    .lp2-frame > section::after {
      content: "+";
      position: absolute;
      top: -0.72em;
      z-index: 2;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.85rem;
      font-weight: 400;
      line-height: 1;
      color: rgba(var(--lp-green-rgb), 0.65);
      background: transparent;
    }

    .lp2-frame > section::before { left: -0.34em; }
    .lp2-frame > section::after { right: -0.34em; }

    .lp2-hero::before,
    .lp2-hero::after {
      content: none;
    }
  }

  .lp2-frame > section {
    border-top: 1px solid var(--hair);
  }

  .lp2-frame > .lp2-hero {
    border-top: 0;
  }

  /* ═══ Type ══════════════════════════════════════════════════════ */
  .lp2-eyebrow {
    margin: 0 0 1.6rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--lp-green-deep);
  }

  .lp2-h1 {
    margin: 0;
    font-family: "Space Grotesk", "Red Hat Display", sans-serif;
    font-size: clamp(2.5rem, 5.6vw, 4.4rem);
    font-weight: 500;
    letter-spacing: -0.025em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--lp-ink);
    text-wrap: balance;
  }

  .lp2-sub {
    max-width: 480px;
    margin: 1.5rem auto 0;
    font-size: clamp(1rem, 1.4vw, 1.13rem);
    line-height: 1.65;
    color: var(--lp-muted);
    text-wrap: balance;
  }

  .lp2 h2 {
    font-family: "Space Grotesk", "Red Hat Display", sans-serif;
    font-weight: 400;
    letter-spacing: -0.015em;
    text-transform: uppercase;
    line-height: 1.05;
    color: var(--lp-ink);
  }

  .lp2-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
    margin-top: 2.2rem;
  }

  /* ═══ Hero ══════════════════════════════════════════════════════ */
  .lp2-hero {
    padding: 0 0 clamp(3rem, 6vw, 5rem);
    text-align: center;
  }

  /* ── Hero: Introducing LACE + scroll-driven screenshot ─────────── */
  /* Restored from the original homepage's "Introducing LACE" moment:
     the headline is pinned to the top of the viewport and the dark,
     neon-framed screenshot rises up from below into full view as you
     scroll. Full-bleed (breaks out of the 1180px frame). */
  .lp2-hero-intro {
    position: relative;
    width: 100%;
    min-height: 200svh;
    padding: 0;
    margin: 0;
  }

  .lp2-hero-pin {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
  }

  /* Headline: vertically centred in the viewport (like the original), and
     it fades out as the screenshot rises up over it. */
  .lp2-intro-copy {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    z-index: 5;
    text-align: center;
    padding-inline: 1.5rem;
    opacity: var(--copy-opacity, 1);
    transform: translateY(calc(-50% + var(--copy-y, 0svh)));
    will-change: opacity, transform;
  }

  .lp2-intro-h1 {
    margin: 0.6rem 0 0;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: clamp(2.6rem, 7.4vw, 5.6rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    line-height: 0.97;
    color: var(--lp-ink);
  }

  .lp2-intro-lace {
    color: var(--lp-green);
    /* A single mint highlight sweeps across the word once, just after it
       lands — both endpoints resolve to solid green so the rested state is
       clean and reduced-motion is unaffected. */
    background-image: linear-gradient(
      100deg,
      var(--lp-green) 0%,
      var(--lp-green) 42%,
      #7dffdb 50%,
      var(--lp-green) 58%,
      var(--lp-green) 100%
    );
    background-size: 250% 100%;
    background-position: 120% 0;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: lp2-lace-sheen 1500ms cubic-bezier(0.4, 0, 0.2, 1) 980ms both;
  }

  @keyframes lp2-lace-sheen {
    from { background-position: 120% 0; }
    to { background-position: -40% 0; }
  }

  .lp2-intro-sub {
    max-width: min(660px, 92vw);
    margin: 1.5rem auto 0;
    font-size: clamp(1rem, 1.5vw, 1.22rem);
    line-height: 1.6;
    color: var(--lp-muted);
    text-wrap: balance;
  }

  /* Load entrance: eyebrow, headline and subhead rise up out of a soft
     blur, staggered — a calm, premium reveal on first paint. */
  .lp2-eyebrow,
  .lp2-intro-h1,
  .lp2-intro-sub {
    animation: lp2-hero-in 980ms cubic-bezier(0.22, 0.61, 0.36, 1) both;
  }

  .lp2-eyebrow { animation-delay: 140ms; }
  .lp2-intro-h1 { animation-delay: 320ms; }
  .lp2-intro-sub { animation-delay: 560ms; }

  @keyframes lp2-hero-in {
    from {
      opacity: 0;
      transform: translateY(22px);
      filter: blur(12px);
    }
    to {
      opacity: 1;
      transform: none;
      filter: blur(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp2-eyebrow,
    .lp2-intro-h1,
    .lp2-intro-sub,
    .lp2-intro-lace {
      animation: none;
    }
  }

  /* Screenshot stage: ~95vw (nearly full width, no height cap — like the
     original), rising from below the fold up to nearly fill the screen. */
  .lp2-introshot {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 6; /* above the headline copy (z-index 5) — it rises OVER the text */
    width: min(95vw, 1640px);
    aspect-ratio: 1.575 / 1;
    pointer-events: none;
    opacity: var(--introshot-opacity, 0);
    transform: translate3d(-50%, calc(-50% + var(--introshot-y, 112svh)), 0);
    transform-origin: 50% 76%;
    will-change: opacity, transform;
  }

  /* One-shot load glide: the screenshot slides up from off-screen to its
     resting peek (top edge poking into view — a clear "scroll down" cue).
     Added by JS for the intro only, then removed so scroll updates stay
     instant and driven by the per-frame damping in the script below. */
  .lp2-hero-intro.is-hero-anim .lp2-introshot {
    transition:
      transform 1400ms cubic-bezier(0.16, 0.84, 0.32, 1),
      opacity 1000ms ease;
  }

  .lp2-introshot-card {
    position: absolute;
    inset: 0;
    z-index: 1;
    margin: 0;
    aspect-ratio: 1.575 / 1;
    padding: 7px;
    overflow: hidden;
    border: 1px solid rgba(247, 250, 255, 0.2);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(54, 60, 64, 0.96) 0%, rgba(22, 25, 27, 0.98) 48%, rgba(10, 11, 12, 0.98) 100%),
      #101214;
    box-shadow:
      0 22px 60px rgba(2, 10, 14, 0.22),
      0 8px 24px rgba(2, 10, 14, 0.14),
      0 0 0 1px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      inset 0 -1px 0 rgba(0, 0, 0, 0.72);
  }

  .lp2-introshot-card::before {
    content: "";
    position: absolute;
    inset: 7px;
    z-index: 2;
    pointer-events: none;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 4px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 0 0 1px rgba(0, 0, 0, 0.22);
  }

  .lp2-introshot-card::after {
    content: "";
    position: absolute;
    left: 1rem;
    right: 1rem;
    top: 0;
    z-index: 3;
    height: 1px;
    pointer-events: none;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.34), transparent);
  }

  .lp2-introshot-img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    object-fit: cover;
    object-position: center top;
  }

  @media (prefers-reduced-motion: reduce) {
    .lp2-hero-intro { min-height: 0; }
    .lp2-hero-pin { position: static; height: auto; padding: clamp(2rem, 5vw, 4rem) 0 clamp(3rem, 6vw, 5rem); }
    .lp2-intro-copy { position: static; padding-inline: 1.5rem; opacity: 1 !important; transform: none !important; }
    .lp2-introshot {
      position: relative;
      top: auto;
      left: 50%;
      margin: clamp(2.4rem, 5vw, 4rem) 0 0;
      width: min(95vw, 1400px);
      transform: translateX(-50%);
      opacity: 1 !important;
