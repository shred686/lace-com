<script>
  // Hero: sticky-pinned "Introducing LACE" stage. The headline holds while
  // the dark, neon-framed screenshot rises from below into full view as the
  // user scrolls through the stage — restored from the original homepage.
  (() => {
    const hero = document.querySelector<HTMLElement>("[data-hero-intro]");
    if (!hero) return;

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      hero.style.setProperty("--introshot-y", "0svh");
      hero.style.setProperty("--introshot-opacity", "1");
      hero.style.setProperty("--introshot-halo", "0.7");
      return;
    }

    const clamp = (v: number, a: number, b: number) => Math.min(b, Math.max(a, v));
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

    // Progress is a LINEAR function of scroll position (constant movement per
    // pixel scrolled — no easing curve, so every scroll step advances the shot
    // by the same distance). A light per-frame damping glides between discrete
    // mouse-wheel steps so the motion reads smooth rather than stepped.
    const scrollProgress = () => {
      const rect = hero.getBoundingClientRect();
      const travel = Math.max(1, rect.height - window.innerHeight);
      return clamp(-rect.top / travel, 0, 1);
    };

    // At the top of the page the shot RESTS at a peek — its top edge poking
    // into the viewport — instead of hiding fully off-screen, so it reads as a
    // clear "there's more below" cue. Scrolling lifts it the rest of the way.
    //
    // The shot is width:min(95vw,1640px) at aspect 1.575, so its rendered
    // HEIGHT depends on the window. A fixed svh offset therefore showed wildly
    // different amounts across viewports — and dropped it entirely off-screen
    // on short/narrow ones. Instead we compute the offset so a CONSTANT
    // fraction of the shot always peeks, whatever the window shape.
    const SHOT_ASPECT = 1.575; // must match the CSS aspect-ratio
    const PEEK_FRAC = 0.12; // ≈ top tenth of the shot stays in view at rest
    const SETTLED = 6; // svh: fully risen, filling the stage

    const restY = () => {
      const w = Math.min(window.innerWidth * 0.95, 1640); // matches CSS width
      const hSvh = ((w / SHOT_ASPECT) / window.innerHeight) * 100;
      // Element is centred on the viewport middle (50svh) then pushed down by
      // Y; solving for a `PEEK_FRAC` sliver visible at the bottom edge gives:
      return 50 + hSvh * (0.5 - PEEK_FRAC);
    };
    let REST = restY();

    const apply = (p: number) => {
      // Screenshot rises linearly from its resting peek up to settled.
      const rise = clamp(p / 0.82, 0, 1);
      hero.style.setProperty("--introshot-y", `${lerp(REST, SETTLED, rise)}svh`);
      hero.style.setProperty("--introshot-opacity", "1");
      hero.style.setProperty("--introshot-halo", String(lerp(0.42, 0.8, rise)));

      // Headline holds while the screenshot rises up from below, then fades as
      // the shot nears the vertical midpoint of the page — driven by `rise`
      // (the shot's travel) rather than raw scroll, so it never clears out to
      // an empty screen before the screenshot is actually approaching.
      const copyFade = clamp((rise - 0.5) / 0.22, 0, 1);
      hero.style.setProperty("--copy-opacity", String(1 - copyFade));
      hero.style.setProperty("--copy-y", `${lerp(0, -11, copyFade)}svh`);
    };

    let shown = scrollProgress();
    let target = shown;
    let raf = 0;

    // Load-in: leave the shot in its CSS off-screen state (112svh, opacity 0)
    // for a beat, then flip on a one-shot transition and glide it up to the
    // resting peek — a smooth entrance that also advertises the scroll. Only
    // auto-plays when the page actually loads at the top; if the user landed
    // mid-page, jump straight to the scroll-driven position.
    let intro = false;
    const endIntro = () => {
      if (!intro) return;
      intro = false;
      hero.classList.remove("is-hero-anim");
    };

    if (shown < 0.02) {
      const shot = hero.querySelector<HTMLElement>(".lp2-introshot");
      shot?.addEventListener("transitionend", endIntro, { once: true });
      // Two frames guarantee the off-screen start state is painted first, so
      // the transition has somewhere to animate from; a short beat lets the
      // headline settle before the shot slides up behind it.
      requestAnimationFrame(() =>
        requestAnimationFrame(() =>
          window.setTimeout(() => {
            intro = true;
            hero.classList.add("is-hero-anim");
            apply(shown);
            window.setTimeout(endIntro, 1800); // fallback if transitionend is missed
          }, 420),
        ),
      );
    } else {
      apply(shown);
    }

    const frame = () => {
      const diff = target - shown;
      if (Math.abs(diff) < 0.0004) {
        shown = target;
        apply(shown);
        raf = 0;
        return;
      }
      // Damping factor: higher = snappier, lower = more glide.
      shown += diff * 0.18;
      apply(shown);
      raf = requestAnimationFrame(frame);
    };

    const onScroll = () => {
      // The moment the user scrolls, drop the one-shot intro transition so the
      // scroll-driven damping takes over instantly instead of lagging behind it.
      if (intro) {
        endIntro();
        shown = scrollProgress();
      }
      target = scrollProgress();
      if (!raf) raf = requestAnimationFrame(frame);
    };

    const onResize = () => {
      // Recompute the resting peek for the new window shape, then re-apply.
      REST = restY();
      target = scrollProgress();
      if (!intro) shown = target; // snap when not mid-intro so it can't drift off-screen
      if (!raf) raf = requestAnimationFrame(frame);
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onResize);
  })();
</script>
