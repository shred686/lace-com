---
/**
 * laceplatform.com — home page.
 * Design language: a visible hairline grid the whole page is drawn on
 * (Attio-style), sentence-case type, one product fragment per cell,
 * almost no body copy. Green stays the only accent.
 */
import { Image } from "astro:assets";
import LaceNav from "./LaceNav.astro";
import LaceFooter from "./LaceFooter.astro";
import LaceSearchDemo from "./LaceSearchDemo.astro";
import whitepaper from "../../assets/docs/LACE_Enterprise_Overview_v3.pdf";
import laceScreen2 from "../../assets/images/lace-workflow-dark.png";
import laceKgDark from "../../assets/images/lace-kg-dark.jpg";
import "../../styles/lace-site.css";

/* Brand marks (simplified official logos). */
const brandLogos: Record<string, string> = {
  sharepoint: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="9.5" cy="9" r="7" fill="#036C70"/><circle cx="16.5" cy="12.5" r="5.4" fill="#1A9BA1"/><circle cx="11.5" cy="17.5" r="4.2" fill="#37C6D0"/></svg>`,
  gdrive: `<svg viewBox="0 0 24 22" aria-hidden="true"><path fill="#00AC47" d="M8.1 0 0 14.4l4.05 7.2 8.1-14.4z"/><path fill="#FFBA00" d="M8.1 0h7.8L24 14.4h-7.8z"/><path fill="#2684FC" d="M4.05 21.6h15.9L24 14.4H8.1z"/></svg>`,
  onedrive: `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#0364B8" d="M19.35 10.54A7.49 7.49 0 0 0 12 4.5a7.5 7.5 0 0 0-6.96 4.76A6 6 0 0 0 6 21.5h13a5 5 0 0 0 .35-9.96z"/></svg>`,
  slack: `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#E01E5A" d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z"/><path fill="#36C5F0" d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z"/><path fill="#2EB67D" d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312z"/><path fill="#ECB22E" d="M15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/></svg>`,
  teams: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="19.6" cy="7" r="2.2" fill="#7B83EB"/><circle cx="13.4" cy="5.6" r="3" fill="#7B83EB"/><path fill="#7B83EB" d="M9 10.4h8.6c.4 0 .7.3.7.7v5.2a4.8 4.8 0 0 1-4.8 4.8h-.2A4.8 4.8 0 0 1 9 17.3z"/><rect x=".5" y="7" width="12.5" height="12.5" rx="1.4" fill="#6264A7"/><path fill="#fff" d="M9.6 10.3H4v1.8h1.9v5.7h1.9v-5.7h1.8z"/></svg>`,
  notion: `<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2.6" y="1.8" width="18.8" height="20.4" rx="2.2" fill="#fff" stroke="#37352F" stroke-width="1.1"/><path fill="#0b0b0b" d="M8.1 17.3V7.2l1.9-.15 4.4 7V7.5l2-.3v10l-2 .15-4.4-7v6.8z"/></svg>`,
  dropbox: `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#0061FF" d="M6 2 0 5.86l6 3.86 6-3.86zm12 0-6 3.86 6 3.86 6-3.86zM0 13.58l6 3.86 6-3.86-6-3.86zm18-3.86-6 3.86 6 3.86 6-3.86zM6 18.72l6 3.86 6-3.86-6-3.86z"/></svg>`,
  gmail: `<svg viewBox="0 0 24 18" aria-hidden="true"><path fill="#4285F4" d="M1.636 18H5.4V8.864L0 4.815v11.549C0 17.268.732 18 1.636 18z"/><path fill="#34A853" d="M18.6 18h3.764c.904 0 1.636-.732 1.636-1.636V4.815l-5.4 4.049z"/><path fill="#FBBC04" d="M18.6 1.636v7.228l5.4-4.049V2.454c0-2.023-2.309-3.178-3.927-1.964z"/><path fill="#EA4335" d="M5.4 8.864V1.636L12 6.586l6.6-4.95v7.228L12 13.814z"/><path fill="#C5221F" d="M0 2.454v2.361l5.4 4.049V1.636L3.927.49C2.309-.724 0 .431 0 2.454z"/></svg>`,
  s3: `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#E25444" d="M4.2 5.5C4.2 4 7.7 3 12 3s7.8 1 7.8 2.5l-1.9 13.9c-.1 1.1-2.5 2.1-5.9 2.1s-5.8-1-5.9-2.1z"/><ellipse cx="12" cy="5.5" rx="7.8" ry="2.5" fill="#7B1D13"/></svg>`,
  salesforce: `<svg viewBox="0 0 24 17" aria-hidden="true"><g fill="#00A1E0"><circle cx="6.4" cy="10.6" r="5.1"/><circle cx="12" cy="7.2" r="6"/><circle cx="17.8" cy="10.4" r="5.4"/><rect x="4.5" y="10" width="15" height="5.7" rx="2.8"/></g></svg>`,
  postgres: `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#336791" d="M4 6.2v11.6C4 19.6 7.6 21 12 21s8-1.4 8-3.2V6.2z"/><ellipse cx="12" cy="6.2" rx="8" ry="3.2" fill="#4A80AA"/></svg>`,
};

const connectors = [
  { id: "sharepoint", name: "SharePoint" },
  { id: "gdrive", name: "Google Drive" },
  { id: "onedrive", name: "OneDrive" },
  { id: "slack", name: "Slack" },
  { id: "teams", name: "Teams" },
  { id: "notion", name: "Notion" },
  { id: "dropbox", name: "Dropbox" },
  { id: "gmail", name: "Gmail" },
  { id: "s3", name: "Amazon S3" },
  { id: "salesforce", name: "Salesforce" },
  { id: "postgres", name: "PostgreSQL" },
];

/* Industry editions built and operated on the platform. */
const editions = [
  {
    name: "LACE-GOV",
    market: "Federal · Defense · Intelligence",
    line: "Standards-conformant knowledge for the mission boundary.",
    href: "/applications#lace-gov",
  },
  {
    name: "LACE Legal",
    market: "Legal · Compliance",
    line: "Contract intelligence with the receipts attached.",
    href: "/applications#lace-legal",
  },
  {
    name: "LACE Finance",
    market: "Financial Services",
    line: "Research where every figure traces to source.",
    href: "/applications#lace-finance",
  },
];
---

<main class="lp-site lp2">
  <LaceNav active="home" />

  <!-- ── Hero: Introducing LACE (full-bleed; screenshot slides up on scroll) ── -->
  <section class="lp2-hero-intro" data-hero-intro>
    <div class="lp2-hero-pin">
      <div class="lp2-intro-copy">
        <!-- <p class="lp2-eyebrow">The AI platform for the governed enterprise</p> -->
        <h1 class="lp2-intro-h1" data-intro-h1>Introducing <span class="lp2-intro-lace">LACE.</span></h1>
        <p class="lp2-intro-sub" data-intro-sub>LACE turns your company’s knowledge into trusted answers, governed agents, automated workflows, and production-ready applications.</p>
      </div>

      <!-- Product screenshot that rises into view as you scroll -->
      <div class="lp2-introshot" data-hero-shot aria-hidden="true">
        <figure class="lp2-introshot-card">
          <Image
            src={laceScreen2}
            alt="LACE workspace showing a governed workflow run"
            class="lp2-introshot-img"
            widths={[760, 980, 1260, 1500, 1640]}
            sizes="94vw"
          />
        </figure>
      </div>
    </div>
  </section>

  <div class="lp2-frame">
    <!-- ── Editorial ──────────────────────────────────────────────── -->
    <section class="lp2-editorial">
      <p data-r>
        <strong>Put everything you know to work.</strong>
        Find any answer. Build real agentic employees. <span class="lp2-ed-green">Automate real work</span>. Build real software. Explore your enterprise's knowledge graph.<br />
        All on one platform. Run in your cloud.
      </p>
    </section>

    <!-- ── Feature cells ──────────────────────────────────────────── -->
    <section class="lp2-cells">
      <!-- Full-width: live search -->
      <div class="lp2-cell lp2-cell-full">
        <div class="lp2-cell-copy" data-r>
          <p class="lp2-kicker"><b>01</b> Enterprise Search</p>
          <h2>One question. Every system. The exact source.</h2>
          <p>Permissions-aware search across documents, messages, and databases — every answer opens the passage, cell, or row it came from.</p>
        </div>
        <div class="lp2-cell-demo" data-r data-reveal-delay="120">
          <LaceSearchDemo />
        </div>
        <a class="lp2-cell-link" href="/platform/enterprise-search">Enterprise Search →</a>
      </div>

      <div class="lp2-row">
        <!-- Bitemporal -->
        <div class="lp2-cell">
          <div class="lp2-cell-copy" data-r>
            <p class="lp2-kicker"><b>02</b> Knowledge Graph</p>
            <h2>Your entire business, one living map.</h2>
            <p>LACE reads your documents and maps what your company actually knows — every customer, contract, and commitment. Ask what you owe, what expires, what changed — and get the answer with the source attached.</p>
          </div>
          <div class="lp2-fragment lp2-kg-shot" data-r data-reveal-delay="100" aria-hidden="true">
            <Image
              src={laceKgDark}
              alt="LACE knowledge graph — a living map of the business"
              class="lp2-kg-img"
              widths={[460, 720, 940]}
              sizes="(max-width: 900px) 90vw, 460px"
            />
          </div>
          <a class="lp2-cell-link" href="/platform/knowledge-graph">Knowledge Graph →</a>
        </div>

        <!-- Conflicts -->
        <div class="lp2-cell">
          <div class="lp2-cell-copy" data-r>
            <p class="lp2-kicker"><b>02</b> Knowledge Graph</p>
            <h2>It catches what everyone missed.</h2>
            <p>When two documents disagree on a fee, a date, an obligation — LACE surfaces it with the evidence, before it becomes a dispute. Your experts make the call; the graph remembers it.</p>
          </div>
          <div class="lp2-fragment lp2-win" data-r data-reveal-delay="100" aria-hidden="true">
            <div class="lp2-win-bar"><i></i><i></i><i></i><span>graph.lace — conflict review</span></div>
            <div class="lp2-win-body">
              <div class="lp2-conflict-pair">
                <div class="lp2-evidence">
                  <em>MSA-2024 · §7.1</em>
                  <p>“…written notice of <mark>ninety (90) days</mark>…”</p>
                </div>
                <span class="lp2-vs">vs</span>
                <div class="lp2-evidence">
                  <em>Summary deck · p.4</em>
                  <p>“…terminable on <mark class="is-warn">60 days'</mark> notice…”</p>
                </div>
              </div>
              <div class="lp2-conflict-flag">
                <i></i> 1 conflict open · routed to counsel@ for ruling
              </div>
            </div>
          </div>
          <a class="lp2-cell-link" href="/platform/knowledge-graph">Conflict detection →</a>
        </div>
      </div>

      <div class="lp2-row">
        <!-- Approval gates -->
        <div class="lp2-cell">
          <div class="lp2-cell-copy" data-r>
            <p class="lp2-kicker"><b>03</b> Agentic Platform</p>
            <h2>Job description in. AI teammate out.</h2>
            <p>Describe the role in the Agent Studio — renewals watchdog, intake clerk, research analyst. LACE builds it with you, proves it against test scenarios, and puts it to work: on a budget, inside your permissions, with the risky step held for a human.</p>
          </div>
          <div class="lp2-fragment lp2-win" data-r data-reveal-delay="100" aria-hidden="true">
            <div class="lp2-win-bar"><i></i><i></i><i></i><span>agents.lace — contracts-intake · v12</span></div>
            <div class="lp2-win-body">
              <div class="lp2-trace-row"><i></i><span>Email in — Meridian asks about renewal</span></div>
              <div class="lp2-trace-row"><i></i><span>Reply drafted · cites <b>MSA §4.2</b> and <b>Table 3</b></span></div>
              <div class="lp2-gate">
                <div>
                  <em>Approval required</em>
                  <strong>Send reply to vendor</strong>
                </div>
                <span class="lp2-approve">Approve</span>
              </div>
              <p class="lp2-gate-meta">$2.40 of $40 daily budget · every step recorded</p>
            </div>
          </div>
          <a class="lp2-cell-link" href="/platform/agents">Agentic Platform →</a>
        </div>

        <!-- Channels -->
        <div class="lp2-cell">
          <div class="lp2-cell-copy" data-r>
            <p class="lp2-kicker"><b>03</b> Agentic Platform</p>
            <h2>Everywhere your customers already are.</h2>
            <p>One agent, every channel — web chat, Slack, Teams, email, SMS, WhatsApp, live voice. It answers from your verified knowledge, and hands off to a human the moment it should.</p>
          </div>
          <div class="lp2-fragment lp2-win" data-r data-reveal-delay="100" aria-hidden="true">
            <div class="lp2-win-bar"><i></i><i></i><i></i><span>agents.lace — support-desk · channels</span></div>
            <div class="lp2-win-body">
              <div class="lp2-chan-grid">
                <span class="lp2-chan"><i class="lp2-chan-ic"><svg viewBox="0 0 24 24" fill="none"><path d="M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v7a2.5 2.5 0 0 1-2.5 2.5H9.4l-4 3.3c-.5.4-1.4 0-1.4-.7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg></i>Web chat</span>
                <span class="lp2-chan"><i class="lp2-chan-ic" set:html={brandLogos.slack} />Slack</span>
                <span class="lp2-chan"><i class="lp2-chan-ic" set:html={brandLogos.teams} />Teams</span>
                <span class="lp2-chan"><i class="lp2-chan-ic" set:html={brandLogos.gmail} />Email</span>
                <span class="lp2-chan"><i class="lp2-chan-ic"><svg viewBox="0 0 24 24" fill="none"><rect x="7" y="3" width="10" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="17.4" r="0.9" fill="currentColor"/></svg></i>SMS</span>
                <span class="lp2-chan"><i class="lp2-chan-ic"><svg viewBox="0 0 24 24"><path fill="#25D366" d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2z"/><path fill="#fff" d="M8.6 7.8c.2-.5.4-.5.6-.5h.5c.2 0 .4 0 .6.4l.8 2c.1.2.1.4-.1.6l-.5.6c-.1.2-.2.4 0 .6a7 7 0 0 0 2.9 2.9c.3.1.4.1.6-.1l.5-.5c.2-.2.4-.2.6-.1l2 .8c.4.2.4.4.4.6v.5c0 .2 0 .5-.5.6-.4.2-1 .3-1.7.2a8.4 8.4 0 0 1-6.9-6.8c-.1-.7 0-1.4.2-1.8z"/></svg></i>WhatsApp</span>
                <span class="lp2-chan"><i class="lp2-chan-ic"><svg viewBox="0 0 24 24" fill="none"><path d="M4 10v4M8 7v10M12 4v16M16 7v10M20 10v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></i>Voice</span>
                <span class="lp2-chan"><i class="lp2-chan-ic"><svg viewBox="0 0 24 24" fill="none"><path d="M9 4.5 4 12l5 7.5M15 4.5 20 12l-5 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></i>API</span>
              </div>
              <div class="lp2-handoff">
                <i></i> Escalated to Sarah M. — transcript and sources attached
              </div>
            </div>
          </div>
          <a class="lp2-cell-link" href="/platform/agents">Deployment channels →</a>
        </div>
      </div>
    </section>

    <!-- ── Connector strip ────────────────────────────────────────── -->
    <div class="lp2-logos" aria-hidden="true">
      <div class="lp-marquee lp2-marquee">
        <div class="lp-mq-track">
          {
            [0, 1].map(() => (
              <>
                {connectors.map((connector) => (
                  <span class="lp-mq-item">
                    <span class="lp-mq-logo" set:html={brandLogos[connector.id]} />
                    {connector.name}
                  </span>
                ))}
              </>
            ))
          }
        </div>
      </div>
    </div>

    <!-- ── 04 App Builder: prompt → production ────────────────────── -->
    <section class="lp2-appbuild">
      <div class="lp2-appbuild-copy" data-r>
        <p class="lp2-kicker"><b>04</b> App Builder</p>
        <h2>Describe it. <span class="lp-accent">It's software.</span></h2>
        <p class="lp2-appbuild-lead">The tool your team keeps wishing for — described in a sentence, live at a real URL in minutes. Pages, portals, and full applications, with sign-in, database, releases, and rollback handled for you.</p>
      </div>
      <figure class="lp2-appbuild-demo lp2-fragment lp-flow" data-r data-reveal-delay="120" aria-label="Diagram: an agent generates code in an isolated sandbox, which commits to Git, which builds into a container in the cloud — all reaching real resources only through the platform SDK.">
        <div class="lp-flow-row">
          <div class="lp-flow-node">
            <div class="lp-flow-box">
              <span class="lp-flow-badge">Isolated sandbox</span>
              <span class="lp-flow-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="3"></rect>
                  <path d="M7.5 9.5 10 12l-2.5 2.5"></path>
                  <path d="M13 14.5h4"></path>
                </svg>
              </span>
              <span class="lp-flow-title">Agent</span>
            </div>
            <span class="lp-flow-cap">Generates app code in isolation — no database, no network, no credentials, no host.</span>
          </div>

          <div class="lp-flow-arrow"><span class="lp-flow-arrow-label">commit</span></div>

          <div class="lp-flow-node">
            <div class="lp-flow-box">
              <span class="lp-flow-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="6" cy="6" r="2.4"></circle>
                  <circle cx="6" cy="18" r="2.4"></circle>
                  <circle cx="18" cy="9" r="2.4"></circle>
                  <path d="M6 8.4v7.2"></path>
                  <path d="M18 11.4v.6a3 3 0 0 1-3 3H6"></path>
                </svg>
              </span>
              <span class="lp-flow-title">Git</span>
            </div>
            <span class="lp-flow-cap">Generated source is versioned — every change is a reviewable, revertable artifact.</span>
          </div>

          <div class="lp-flow-arrow"><span class="lp-flow-arrow-label">build</span></div>

          <div class="lp-flow-node">
            <div class="lp-flow-box">
              <span class="lp-flow-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17.5a4 4 0 1 1 1-7.87A5 5 0 0 1 18 10.5a3.5 3.5 0 0 1-.5 7Z"></path>
                  <rect x="9.5" y="11.5" width="5" height="5" rx="1"></rect>
                  <path d="M12 11.5v5M9.5 14h5"></path>
                </svg>
              </span>
              <span class="lp-flow-title">Cloud container</span>
            </div>
            <span class="lp-flow-cap">Built and run behind the platform SDK — the only surface that reaches anything real.</span>
          </div>
        </div>

        <div class="lp-flow-base" aria-label="platform SDK: the governed capability surface underneath every stage">
          <span class="lp-flow-base-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Z"></path>
              <path d="m4 7.5 8 4.5 8-4.5"></path>
              <path d="M12 12v9"></path>
            </svg>
          </span>
          <span class="lp-flow-base-text"><strong>@platform/sdk</strong> — the governed capability surface. Imported in the sandbox, enforced in the container: the only path to identity, data, policy, limits, and audit.</span>
        </div>
      </figure>
      <a class="lp2-cell-link" href="/platform/app-builder">App Builder →</a>
    </section>

    <!-- ── 04b App Builder: launch a business ─────────────────────── -->
    <section class="lp2-saas">
      <div class="lp2-saas-copy" data-r>
        <p class="lp2-kicker"><b>04</b> App Builder · Launch</p>
        <h2>Your SaaS idea. <span class="lp-accent">Live. Selling.</span></h2>
        <p>Build the product — and the business around it. Subscriptions and billing are built in, hosting scales as you grow, and LACE handles the launch checklist down to the domain and the entity. From idea to real revenue, on one platform.</p>
        <ul class="lp2-saas-list">
          <li>Subscriptions &amp; billing built in</li>
          <li>Cloud hosting that scales automatically</li>
          <li>Your domain, registered</li>
          <li>Your company, formed</li>
        </ul>
        <a class="lp2-cell-link" href="/platform/app-builder">Launch on LACE →</a>
      </div>
      <div class="lp2-saas-visual" data-r data-reveal-delay="140" aria-hidden="true">
        <div class="lp2-win lp2-saas-win">
          <div class="lp2-win-bar"><i></i><i></i><i></i><span>billing.lace — flowlane.app</span></div>
          <div class="lp2-win-body">
            <div class="lp2-mrr">
              <em>Monthly recurring revenue</em>
              <span><strong>$4,280</strong><b>↑ 18% this month</b></span>
            </div>
            <div class="lp2-spark">
