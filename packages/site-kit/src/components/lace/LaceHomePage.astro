    display: inline-grid;
  }

  .lp2-time-vals strong {
    grid-area: 1 / 1;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--lp-ink);
  }

  .lp2-val-then { animation: lp2-then 7s ease-in-out infinite; }
  .lp2-val-now { animation: lp2-now 7s ease-in-out infinite; }

  @keyframes lp2-then {
    0%, 38% { opacity: 0; }
    50%, 88% { opacity: 1; }
    100% { opacity: 0; }
  }

  @keyframes lp2-now {
    0%, 38% { opacity: 1; }
    50%, 88% { opacity: 0; }
    100% { opacity: 1; }
  }

  .lp2-time-fact i {
    margin-left: auto;
    font-style: normal;
    padding: 0.16rem 0.5rem;
    border: 1px solid rgba(var(--lp-green-rgb), 0.4);
    border-radius: var(--lp-radius);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.56rem;
    color: var(--lp-green-deep);
  }

  .lp2-time-scrub {
    padding: 0.8rem 0.95rem 0.9rem;
    border: 1px solid var(--lp-line-soft);
    border-radius: var(--lp-radius-lg);
    background: rgba(255, 255, 255, 0.7);
  }

  .lp2-time-labels {
    position: relative;
    display: block;
    height: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .lp2-time-labels em {
    position: absolute;
    left: 0;
    font-style: normal;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lp-ink-soft);
  }

  .lp2-asof-then { animation: lp2-then 7s ease-in-out infinite; }
  .lp2-asof-now { animation: lp2-now 7s ease-in-out infinite; }

  .lp2-time-track {
    position: relative;
    height: 3px;
    border-radius: 2px;
    background: rgba(13, 27, 22, 0.09);
  }

  .lp2-time-knob {
    position: absolute;
    top: 50%;
    left: 85%;
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    border: 2px solid #fff;
    background: var(--lp-green);
    box-shadow: 0 1px 6px rgba(15, 30, 26, 0.3);
    transform: translate(-50%, -50%);
    animation: lp2-scrub 7s cubic-bezier(0.65, 0, 0.35, 1) infinite;
  }

  @keyframes lp2-scrub {
    0%, 38% { left: 85%; }
    50%, 88% { left: 38%; }
    100% { left: 85%; }
  }

  .lp2-time-ticks {
    display: flex;
    justify-content: space-between;
    margin-top: 0.45rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.55rem;
    color: var(--lp-faint);
  }

  /* — conflict — */
  .lp2-conflict-pair {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: stretch;
    gap: 0.6rem;
  }

  .lp2-evidence {
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--lp-line);
    border-radius: var(--lp-radius-lg);
    background: #ffffff;
    box-shadow: var(--lp-shadow-sm);
  }

  .lp2-evidence em {
    display: block;
    margin-bottom: 0.35rem;
    font-style: normal;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.54rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  .lp2-evidence p {
    margin: 0;
    font-size: 0.76rem;
    line-height: 1.55;
    color: var(--lp-ink-soft);
  }

  .lp2-evidence mark {
    padding: 0.05em 0.2em;
    background: rgba(var(--lp-green-rgb), 0.16);
    color: inherit;
  }

  .lp2-evidence mark.is-warn {
    background: rgba(255, 190, 70, 0.3);
  }

  .lp2-vs {
    align-self: center;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    color: var(--lp-faint);
  }

  .lp2-conflict-flag {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.8rem;
    border: 1px solid rgba(196, 132, 12, 0.4);
    border-radius: var(--lp-radius-lg);
    background: rgba(255, 216, 111, 0.12);
    font-size: 0.74rem;
    font-weight: 500;
    color: #7a5200;
  }

  .lp2-conflict-flag i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: #d99a06;
    animation: lp2-blink 2s ease-in-out infinite;
  }

  @keyframes lp2-blink {
    50% { opacity: 0.35; }
  }

  /* — agent trace + gate — */
  .lp2-trace-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.58rem 0.75rem;
    border: 1px solid var(--lp-line-soft);
    border-radius: var(--lp-radius);
    background: #fdfefe;
    font-size: 0.76rem;
    color: var(--lp-ink-soft);
  }

  .lp2-trace-row i {
    flex: none;
    display: grid;
    place-items: center;
    width: 1.05rem;
    height: 1.05rem;
    border-radius: 50%;
    border: 1px solid rgba(var(--lp-green-rgb), 0.45);
    font-style: normal;
    font-size: 0.58rem;
    color: var(--lp-green-deep);
  }

  .lp2-trace-row i::before {
    content: "✓";
  }

  .lp2-trace-row b {
    font-weight: 600;
    color: var(--lp-ink);
  }

  .lp2-gate {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 0.8rem 0.95rem;
    border: 1px solid rgba(196, 132, 12, 0.45);
    border-radius: var(--lp-radius-lg);
    background: rgba(255, 216, 111, 0.1);
  }

  .lp2-gate em {
    display: block;
    font-style: normal;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a06a00;
  }

  .lp2-gate strong {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--lp-ink);
  }

  .lp2-approve {
    flex: none;
    padding: 0.45rem 0.95rem;
    border-radius: var(--lp-radius);
    background: linear-gradient(135deg, #00b88d, #00d9ae);
    color: var(--lp-green-ink);
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    box-shadow: 0 4px 14px -6px rgba(var(--lp-green-rgb), 0.7);
  }

  .lp2-gate-meta {
    margin: 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.56rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  /* — build — */
  .lp2-prompt {
    display: flex;
    gap: 0.5rem;
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--lp-line);
    border-radius: var(--lp-radius-lg);
    background: #ffffff;
    box-shadow: var(--lp-shadow-sm);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    color: var(--lp-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lp2-prompt b {
    color: var(--lp-green);
  }

  .lp2-buildsteps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.4rem;
  }

  .lp2-buildsteps span {
    position: relative;
    padding: 0.45rem 0.4rem 0.45rem 1.25rem;
    border: 1px solid var(--lp-line-soft);
    border-radius: var(--lp-radius);
    background: #ffffff;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.56rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--lp-muted);
  }

  .lp2-buildsteps span::before {
    content: "";
    position: absolute;
    left: 0.48rem;
    top: 50%;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    border: 1.5px solid rgba(13, 27, 22, 0.2);
    transform: translateY(-50%);
    animation: lp2-dot 6s ease-in-out infinite;
    animation-delay: var(--d, 0s);
  }

  @keyframes lp2-dot {
    0%, 100% { border-color: rgba(13, 27, 22, 0.2); background: transparent; }
    8%, 18% { border-color: var(--lp-green); background: rgba(var(--lp-green-rgb), 0.35); }
    24%, 96% { border-color: var(--lp-green); background: var(--lp-green); }
  }

  .lp2-liveurl {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.6rem 0.85rem;
    border: 1px solid rgba(var(--lp-green-rgb), 0.5);
    border-radius: var(--lp-radius-lg);
    background: linear-gradient(90deg, rgba(var(--lp-green-rgb), 0.07), transparent 80%);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    color: var(--lp-ink);
  }

  .lp2-liveurl i {
    flex: none;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--lp-green);
    animation: lp2-blink 1.8s ease-in-out infinite;
  }

  .lp2-liveurl b {
    margin-left: auto;
    padding: 0.16rem 0.45rem;
    border-radius: var(--lp-radius);
    background: var(--lp-green);
    color: #fff;
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.14em;
  }

  /* ═══ Governance ════════════════════════════════════════════════ */
  .lp2-gov {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
  }

  .lp2-gov-copy {
    padding: clamp(2.6rem, 5vw, 4.5rem) clamp(1.2rem, 3.5vw, 3.2rem);
  }

  .lp2-gov-copy p {
    max-width: 28ch;
    margin: 0;
    font-family: "Space Grotesk", "Red Hat Display", sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.35rem);
    font-weight: 400;
    letter-spacing: -0.015em;
    text-transform: uppercase;
    line-height: 1.15;
    color: var(--lp-faint);
  }

  .lp2-gov-copy strong {
    display: block;
    font-weight: 500;
    color: var(--lp-ink);
  }

  .lp2-gov-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1.8rem;
  }

  .lp2-gov-tags span {
    padding: 0.38rem 0.8rem;
    border: 1px solid rgba(var(--lp-green-rgb), 0.35);
    border-radius: 100px;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lp-green-deep);
    background: rgba(255, 255, 255, 0.65);
  }

  .lp2-gov-visual {
    display: grid;
    align-content: center;
    padding: clamp(2.6rem, 5vw, 4.5rem) clamp(1.2rem, 3.5vw, 3.2rem);
    border-left: 1px solid var(--hair);
  }

  .lp2-run {
    position: relative;
    display: grid;
    gap: 1.15rem;
    padding-left: 0.2rem;
  }

  .lp2-run::before {
    content: "";
    position: absolute;
    left: 0.42rem;
    top: 0.6rem;
    bottom: 0.6rem;
    border-left: 1.5px dashed rgba(var(--lp-green-rgb), 0.45);
  }

  .lp2-runrow {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .lp2-runmark {
    flex: none;
    position: relative;
    z-index: 1;
    margin-top: 0.32rem;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    border: 1.5px solid rgba(var(--lp-green-rgb), 0.6);
    background: #ffffff;
    animation: lp2-mark 4.8s ease-in-out infinite;
    animation-delay: var(--rd2, 0s);
  }

  @keyframes lp2-mark {
    0%, 20%, 100% { background: #ffffff; box-shadow: none; }
    6%, 12% { background: var(--lp-green); box-shadow: 0 0 10px rgba(var(--lp-green-rgb), 0.6); }
  }

  .lp2-runrow > span {
    display: grid;
    gap: 0.1rem;
  }

  .lp2-runrow em {
    font-style: normal;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.54rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--lp-green-deep);
  }

  .lp2-runrow strong {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.45;
    color: var(--lp-ink-soft);
  }

  /* ═══ Channels fragment ═════════════════════════════════════════ */
  .lp2-chan-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .lp2-chan {
    display: grid;
    justify-items: center;
    gap: 0.34rem;
    padding: 0.62rem 0.3rem 0.55rem;
    border: 1px solid var(--lp-line-soft);
    border-radius: var(--lp-radius);
    background: #fdfefe;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.54rem;
    letter-spacing: 0.04em;
    color: var(--lp-ink-soft);
  }

  .lp2-chan-ic {
    display: grid;
    place-items: center;
    width: 1.05rem;
    height: 1.05rem;
    font-style: normal;
    color: var(--lp-green-deep);
  }

  .lp2-chan-ic :global(svg) {
    width: 100%;
    height: 100%;
  }

  .lp2-handoff {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.6rem 0.85rem;
    border: 1px solid rgba(var(--lp-green-rgb), 0.45);
    border-radius: var(--lp-radius-lg);
    background: rgba(var(--lp-green-rgb), 0.06);
    font-size: 0.74rem;
    font-weight: 500;
    color: var(--lp-ink-soft);
  }

  .lp2-handoff i {
    flex: none;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--lp-green);
    animation: lp2-blink 2s ease-in-out infinite;
  }

  /* ═══ App Builder: prompt → production ══════════════════════════ */
  .lp2-appbuild {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(2.2rem, 4vw, 3.2rem);
    min-height: min(94svh, 900px);
    padding: clamp(4rem, 8vw, 6.5rem) clamp(1.2rem, 3.5vw, 3.2rem);
    text-align: center;
    background:
      radial-gradient(46rem 20rem at 50% 8%, rgba(var(--lp-green-rgb), 0.05), transparent 62%);
  }

  .lp2-appbuild-copy h2 {
    margin: 0 0 1.1rem;
    font-size: clamp(2.1rem, 4.6vw, 3.6rem);
  }

  .lp2-appbuild-lead {
    max-width: 56ch;
    margin: 0 auto;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.65;
    color: var(--lp-muted);
    text-wrap: balance;
  }

  .lp2-appbuild .lp2-fragment {
    width: min(760px, 100%);
    margin-block: 0;
  }

  .lp2-appbuild .lp2-win-body {
    gap: 0.85rem;
    padding: clamp(1.1rem, 2.4vw, 1.5rem);
  }

  .lp2-appbuild .lp2-prompt {
    padding: 0.9rem 1.05rem;
    font-size: 0.85rem;
  }

  .lp2-appbuild .lp2-buildsteps span {
    padding: 0.6rem 0.5rem 0.6rem 1.5rem;
    font-size: 0.64rem;
  }

  .lp2-appbuild .lp2-buildsteps span::before {
    left: 0.6rem;
  }

  .lp2-appbuild .lp2-liveurl {
    padding: 0.8rem 1.05rem;
    font-size: 0.85rem;
  }

  .lp2-appbuild > .lp2-cell-link {
    align-self: center;
    margin-top: 0;
  }

  /* ── App Builder flow diagram: Agent → Git → Container on the SDK ── */
  .lp2-appbuild .lp-flow {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    text-align: left;
  }

  .lp-flow-row {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
  }

  .lp-flow-node {
    display: flex;
    flex: 1 1 0;
    flex-direction: column;
    align-items: stretch;
    gap: 0.75rem;
  }

  .lp-flow-box {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 7.5rem;
    padding: 1.5rem 1rem 1.25rem;
    border: 1px solid rgba(var(--lp-green-rgb), 0.3);
    border-radius: var(--lp-radius-lg);
    background:
      radial-gradient(10rem 6rem at 50% 0%, rgba(var(--lp-green-rgb), 0.05), transparent 70%),
      #ffffff;
    box-shadow: var(--lp-shadow-sm);
  }

  .lp-flow-badge {
    position: absolute;
    top: -0.62rem;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    padding: 0.24rem 0.62rem;
    border: 1px dashed rgba(var(--lp-green-rgb), 0.5);
    border-radius: 100px;
    background: #f4faf8;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--lp-green-deep);
  }

  .lp-flow-icon {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border: 1px solid rgba(var(--lp-green-rgb), 0.28);
    border-radius: var(--lp-radius-lg);
    background: #f4faf8;
    color: var(--lp-green-deep);
  }

  .lp-flow-icon svg {
    width: 1.45rem;
    height: 1.45rem;
  }

  .lp-flow-title {
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.98rem;
    font-weight: 650;
    letter-spacing: -0.01em;
    color: var(--lp-ink);
    text-align: center;
  }

  .lp-flow-cap {
    display: block;
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--lp-muted);
    text-align: center;
  }

  .lp-flow-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    flex: 0 0 auto;
    min-height: 7.5rem;
    color: rgba(var(--lp-green-rgb), 0.75);
  }

  .lp-flow-arrow-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.54rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  .lp-flow-arrow::after {
    content: "→";
    font-size: 1.25rem;
    line-height: 1;
  }

  .lp-flow-base {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-top: 0.7rem;
    padding: 0.85rem 1.1rem;
    border: 1px solid rgba(var(--lp-green-rgb), 0.35);
    border-radius: var(--lp-radius-lg);
    background:
      linear-gradient(0deg, rgba(var(--lp-green-rgb), 0.09), rgba(var(--lp-green-rgb), 0.045));
  }

  .lp-flow-base::before {
    content: "";
    position: absolute;
    top: -0.72rem;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 0.72rem;
    background: rgba(var(--lp-green-rgb), 0.45);
  }

  .lp-flow-base-icon {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    flex: none;
    border: 1px solid rgba(var(--lp-green-rgb), 0.35);
    border-radius: var(--lp-radius);
    background: #ffffff;
    color: var(--lp-green-deep);
  }

  .lp-flow-base-icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .lp-flow-base-text {
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--lp-ink-soft);
  }

  .lp-flow-base-text strong {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--lp-green-deep);
  }

  @media (max-width: 640px) {
    .lp-flow-row {
      flex-direction: column;
    }

    .lp-flow-arrow {
      flex-direction: row;
      gap: 0.5rem;
      min-height: 0;
    }

    .lp-flow-arrow::after {
      content: "↓";
    }
  }

  /* ═══ App Builder: launch a business ════════════════════════════ */
  .lp2-saas {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    min-height: min(90svh, 860px);
  }

  .lp2-saas-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.2rem, 3.5vw, 3.2rem);
  }

  .lp2-saas-copy h2 {
    margin: 0 0 1rem;
    font-size: clamp(1.9rem, 3.6vw, 3rem);
  }

  .lp2-saas-copy > p {
    max-width: 46ch;
    margin: 0;
    font-size: clamp(0.98rem, 1.3vw, 1.08rem);
    line-height: 1.65;
    color: var(--lp-muted);
  }

  .lp2-saas-list {
    display: grid;
    gap: 0.7rem;
    margin: 1.9rem 0 0;
    padding: 0;
    list-style: none;
  }

  .lp2-saas-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.94rem;
    font-weight: 500;
    color: var(--lp-ink-soft);
  }

  .lp2-saas-list li::before {
