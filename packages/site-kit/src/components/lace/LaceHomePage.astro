---
/**
 * laceplatform.com — home page.
 * Design language: a visible hairline grid the whole page is drawn on
 * (Attio-style), sentence-case type, one product fragment per cell,
 * almost no body copy. Green stays the only accent.
 */
import { Image } from "astro:assets";
import LaceNav from "./LaceNav.astro";
import LaceFooter from "./LaceFooter.astro";
import LaceSearchDemo from "./LaceSearchDemo.astro";
import whitepaper from "../../assets/docs/LACE_Enterprise_Overview_v3.pdf";
import laceScreen2 from "../../assets/images/lace-screen2.png";
import "../../styles/lace-site.css";

/* Brand marks (simplified official logos). */
const brandLogos: Record<string, string> = {
  sharepoint: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="9.5" cy="9" r="7" fill="#036C70"/><circle cx="16.5" cy="12.5" r="5.4" fill="#1A9BA1"/><circle cx="11.5" cy="17.5" r="4.2" fill="#37C6D0"/></svg>`,
  gdrive: `<svg viewBox="0 0 24 22" aria-hidden="true"><path fill="#00AC47" d="M8.1 0 0 14.4l4.05 7.2 8.1-14.4z"/><path fill="#FFBA00" d="M8.1 0h7.8L24 14.4h-7.8z"/><path fill="#2684FC" d="M4.05 21.6h15.9L24 14.4H8.1z"/></svg>`,
  onedrive: `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#0364B8" d="M19.35 10.54A7.49 7.49 0 0 0 12 4.5a7.5 7.5 0 0 0-6.96 4.76A6 6 0 0 0 6 21.5h13a5 5 0 0 0 .35-9.96z"/></svg>`,
  slack: `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#E01E5A" d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z"/><path fill="#36C5F0" d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z"/><path fill="#2EB67D" d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312z"/><path fill="#ECB22E" d="M15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/></svg>`,
  teams: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="19.6" cy="7" r="2.2" fill="#7B83EB"/><circle cx="13.4" cy="5.6" r="3" fill="#7B83EB"/><path fill="#7B83EB" d="M9 10.4h8.6c.4 0 .7.3.7.7v5.2a4.8 4.8 0 0 1-4.8 4.8h-.2A4.8 4.8 0 0 1 9 17.3z"/><rect x=".5" y="7" width="12.5" height="12.5" rx="1.4" fill="#6264A7"/><path fill="#fff" d="M9.6 10.3H4v1.8h1.9v5.7h1.9v-5.7h1.8z"/></svg>`,
  notion: `<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2.6" y="1.8" width="18.8" height="20.4" rx="2.2" fill="#fff" stroke="#37352F" stroke-width="1.1"/><path fill="#0b0b0b" d="M8.1 17.3V7.2l1.9-.15 4.4 7V7.5l2-.3v10l-2 .15-4.4-7v6.8z"/></svg>`,
  dropbox: `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#0061FF" d="M6 2 0 5.86l6 3.86 6-3.86zm12 0-6 3.86 6 3.86 6-3.86zM0 13.58l6 3.86 6-3.86-6-3.86zm18-3.86-6 3.86 6 3.86 6-3.86zM6 18.72l6 3.86 6-3.86-6-3.86z"/></svg>`,
  gmail: `<svg viewBox="0 0 24 18" aria-hidden="true"><path fill="#4285F4" d="M1.636 18H5.4V8.864L0 4.815v11.549C0 17.268.732 18 1.636 18z"/><path fill="#34A853" d="M18.6 18h3.764c.904 0 1.636-.732 1.636-1.636V4.815l-5.4 4.049z"/><path fill="#FBBC04" d="M18.6 1.636v7.228l5.4-4.049V2.454c0-2.023-2.309-3.178-3.927-1.964z"/><path fill="#EA4335" d="M5.4 8.864V1.636L12 6.586l6.6-4.95v7.228L12 13.814z"/><path fill="#C5221F" d="M0 2.454v2.361l5.4 4.049V1.636L3.927.49C2.309-.724 0 .431 0 2.454z"/></svg>`,
  s3: `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#E25444" d="M4.2 5.5C4.2 4 7.7 3 12 3s7.8 1 7.8 2.5l-1.9 13.9c-.1 1.1-2.5 2.1-5.9 2.1s-5.8-1-5.9-2.1z"/><ellipse cx="12" cy="5.5" rx="7.8" ry="2.5" fill="#7B1D13"/></svg>`,
  salesforce: `<svg viewBox="0 0 24 17" aria-hidden="true"><g fill="#00A1E0"><circle cx="6.4" cy="10.6" r="5.1"/><circle cx="12" cy="7.2" r="6"/><circle cx="17.8" cy="10.4" r="5.4"/><rect x="4.5" y="10" width="15" height="5.7" rx="2.8"/></g></svg>`,
  postgres: `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#336791" d="M4 6.2v11.6C4 19.6 7.6 21 12 21s8-1.4 8-3.2V6.2z"/><ellipse cx="12" cy="6.2" rx="8" ry="3.2" fill="#4A80AA"/></svg>`,
};

const connectors = [
  { id: "sharepoint", name: "SharePoint" },
  { id: "gdrive", name: "Google Drive" },
  { id: "onedrive", name: "OneDrive" },
  { id: "slack", name: "Slack" },
  { id: "teams", name: "Teams" },
  { id: "notion", name: "Notion" },
  { id: "dropbox", name: "Dropbox" },
  { id: "gmail", name: "Gmail" },
  { id: "s3", name: "Amazon S3" },
  { id: "salesforce", name: "Salesforce" },
  { id: "postgres", name: "PostgreSQL" },
];

/* Industry editions built and operated on the platform. */
const editions = [
  {
    name: "LACE-GOV",
    market: "Federal · Defense · Intelligence",
    line: "Standards-conformant knowledge for the mission boundary.",
    href: "/applications#lace-gov",
  },
  {
    name: "LACE Legal",
    market: "Legal · Compliance",
    line: "Contract intelligence with the receipts attached.",
    href: "/applications#lace-legal",
  },
  {
    name: "LACE Finance",
    market: "Financial Services",
    line: "Research where every figure traces to source.",
    href: "/applications#lace-finance",
  },
];
---

<main class="lp-site lp2">
  <LaceNav active="home" />

  <!-- ── Hero: Introducing LACE (full-bleed; screenshot slides up on scroll) ── -->
  <section class="lp2-hero-intro" data-hero-intro>
    <div class="lp2-hero-pin">
      <div class="lp2-intro-copy">
        <p class="lp2-eyebrow">The AI platform for the governed enterprise</p>
        <h1 class="lp2-intro-h1" data-intro-h1>Introducing <span class="lp2-intro-lace">LACE.</span></h1>
        <p class="lp2-intro-sub" data-intro-sub>LACE weaves your actual knowledge, rules, and operations into secure, production-ready AI.</p>
      </div>

      <!-- Product screenshot that rises into view as you scroll -->
      <div class="lp2-introshot" data-hero-shot aria-hidden="true">
        <figure class="lp2-introshot-card">
          <Image
            src={laceScreen2}
            alt="LACE workspace showing a governed workflow run"
            class="lp2-introshot-img"
            widths={[760, 980, 1260, 1500]}
            sizes="94vw"
          />
        </figure>
      </div>
    </div>
  </section>

  <div class="lp2-frame">
    <!-- ── Connector strip ────────────────────────────────────────── -->
    <div class="lp2-logos" aria-hidden="true">
      <div class="lp-marquee lp2-marquee">
        <div class="lp-mq-track">
          {
            [0, 1].map(() => (
              <>
                {connectors.map((connector) => (
                  <span class="lp-mq-item">
                    <span class="lp-mq-logo" set:html={brandLogos[connector.id]} />
                    {connector.name}
                  </span>
                ))}
              </>
            ))
          }
        </div>
      </div>
    </div>

    <!-- ── Editorial ──────────────────────────────────────────────── -->
    <section class="lp2-editorial">
      <p data-r>
        <strong>One platform. Four products.</strong>
        Enterprise search, a knowledge graph, an agentic runtime, and an
        app builder — built on your knowledge, bound by your rules,
        recorded in one audit trail.
      </p>
    </section>

    <!-- ── Feature cells ──────────────────────────────────────────── -->
    <section class="lp2-cells">
      <!-- Full-width: live search -->
      <div class="lp2-cell lp2-cell-full">
        <div class="lp2-cell-copy" data-r>
          <p class="lp2-kicker"><b>01</b> Enterprise Search</p>
          <h2>One question. Every system. The exact source.</h2>
          <p>Permissions-aware search across documents, messages, and databases — every answer opens the passage, cell, or row it came from.</p>
        </div>
        <div class="lp2-cell-demo" data-r data-reveal-delay="120">
          <LaceSearchDemo />
        </div>
        <a class="lp2-cell-link" href="/platform/enterprise-search">Enterprise Search →</a>
      </div>

      <div class="lp2-row">
        <!-- Bitemporal -->
        <div class="lp2-cell">
          <div class="lp2-cell-copy" data-r>
            <p class="lp2-kicker"><b>02</b> Knowledge Graph</p>
            <h2>Every fact, versioned in time.</h2>
            <p>The graph records what's true and when you learned it. Query today's state — or any date before it.</p>
          </div>
          <div class="lp2-fragment lp2-win" data-r data-reveal-delay="100" aria-hidden="true">
            <div class="lp2-win-bar"><i></i><i></i><i></i><span>graph.lace — Meridian Corp</span></div>
            <div class="lp2-win-body">
              <div class="lp2-time-fact">
                <span>Annual fee</span>
                <span class="lp2-time-vals">
                  <strong class="lp2-val-then">$1.1M</strong>
                  <strong class="lp2-val-now">$1.2M</strong>
                </span>
                <i>Table 3</i>
              </div>
              <div class="lp2-time-fact">
                <span>Renewal date</span>
                <span class="lp2-time-vals">
                  <strong class="lp2-val-then">Jan 15, 2026</strong>
                  <strong class="lp2-val-now">Jan 15, 2027</strong>
                </span>
                <i>MSA §4.2</i>
              </div>
              <div class="lp2-time-scrub">
                <span class="lp2-time-labels">
                  <em class="lp2-asof-then">as of · Mar 2025</em>
                  <em class="lp2-asof-now">as of · Jul 2026</em>
                </span>
                <div class="lp2-time-track">
                  <i class="lp2-time-knob"></i>
                </div>
                <div class="lp2-time-ticks"><span>2024</span><span>2025</span><span>2026</span></div>
              </div>
            </div>
          </div>
          <a class="lp2-cell-link" href="/platform/knowledge-graph">Knowledge Graph →</a>
        </div>

        <!-- Conflicts -->
        <div class="lp2-cell">
          <div class="lp2-cell-copy" data-r>
            <p class="lp2-kicker"><b>02</b> Knowledge Graph</p>
            <h2>Conflicts surface. Nothing gets papered over.</h2>
            <p>When sources disagree, both versions sit side by side with their evidence — routed to a person for a ruling.</p>
          </div>
          <div class="lp2-fragment lp2-win" data-r data-reveal-delay="100" aria-hidden="true">
            <div class="lp2-win-bar"><i></i><i></i><i></i><span>graph.lace — conflict review</span></div>
            <div class="lp2-win-body">
              <div class="lp2-conflict-pair">
                <div class="lp2-evidence">
                  <em>MSA-2024 · §7.1</em>
                  <p>“…written notice of <mark>ninety (90) days</mark>…”</p>
                </div>
                <span class="lp2-vs">vs</span>
                <div class="lp2-evidence">
                  <em>Summary deck · p.4</em>
                  <p>“…terminable on <mark class="is-warn">60 days'</mark> notice…”</p>
                </div>
              </div>
              <div class="lp2-conflict-flag">
                <i></i> 1 conflict open · routed to counsel@ for ruling
              </div>
            </div>
          </div>
          <a class="lp2-cell-link" href="/platform/knowledge-graph">Conflict detection →</a>
        </div>
      </div>

      <div class="lp2-row">
        <!-- Approval gates -->
        <div class="lp2-cell">
          <div class="lp2-cell-copy" data-r>
            <p class="lp2-kicker"><b>03</b> Agentic Platform</p>
            <h2>Agents that do real work, under real controls.</h2>
            <p>Deployed with budgets, permissions, and approval gates. The risky step waits for a human — and every step is recorded.</p>
          </div>
          <div class="lp2-fragment lp2-win" data-r data-reveal-delay="100" aria-hidden="true">
            <div class="lp2-win-bar"><i></i><i></i><i></i><span>agents.lace — contracts-intake · v12</span></div>
            <div class="lp2-win-body">
              <div class="lp2-trace-row"><i></i><span>Email in — Meridian asks about renewal</span></div>
              <div class="lp2-trace-row"><i></i><span>Reply drafted · cites <b>MSA §4.2</b> and <b>Table 3</b></span></div>
              <div class="lp2-gate">
                <div>
                  <em>Approval required</em>
                  <strong>Send reply to vendor</strong>
                </div>
                <span class="lp2-approve">Approve</span>
              </div>
              <p class="lp2-gate-meta">$2.40 of $40 daily budget · every step recorded</p>
            </div>
          </div>
          <a class="lp2-cell-link" href="/platform/agents">Agentic Platform →</a>
        </div>

        <!-- App builder -->
        <div class="lp2-cell">
          <div class="lp2-cell-copy" data-r>
            <p class="lp2-kicker"><b>04</b> App Builder</p>
            <h2>From prompt to production software.</h2>
            <p>LACE plans, builds, verifies, and hosts the app — sign-in, database, releases, and rollback included.</p>
          </div>
          <div class="lp2-fragment lp2-win" data-r data-reveal-delay="100" aria-hidden="true">
            <div class="lp2-win-bar"><i></i><i></i><i></i><span>builder.lace — field-inventory</span></div>
            <div class="lp2-win-body">
              <div class="lp2-prompt"><b>&gt;</b> an inventory tracker for our field teams…</div>
              <div class="lp2-buildsteps">
                <span style="--d: 0s">Plan</span>
                <span style="--d: 1.5s">Build</span>
                <span style="--d: 3s">Verify</span>
                <span style="--d: 4.5s">Publish</span>
              </div>
              <div class="lp2-liveurl">
                <i></i> inventory.acme-field.app <b>LIVE</b>
              </div>
            </div>
          </div>
          <a class="lp2-cell-link" href="/platform/app-builder">App Builder →</a>
        </div>
      </div>
    </section>

    <!-- ── Governance ─────────────────────────────────────────────── -->
    <section class="lp2-gov">
      <div class="lp2-gov-copy" data-r>
        <p>
          <strong>Probabilistic AI.<br />Deterministic control.</strong>
          Model output is a proposal — validation, policy, and approvals
          decide what's applied. The audit trail records all of it.
        </p>
        <div class="lp2-gov-tags">
          <span>Provenance</span><span>Permissions</span><span>Budgets</span><span>Approvals</span><span>Audit</span>
        </div>
      </div>

      <div class="lp2-gov-visual" data-r data-reveal-delay="140" aria-hidden="true">
        <div class="lp2-run">
          <div class="lp2-runrow" style="--rd2: 0s">
            <i class="lp2-runmark"></i>
            <span><em>Propose</em><strong>The model drafts an output</strong></span>
          </div>
          <div class="lp2-runrow" style="--rd2: 1.2s">
            <i class="lp2-runmark"></i>
            <span><em>Validate</em><strong>Citations verified · schema passes</strong></span>
          </div>
          <div class="lp2-runrow" style="--rd2: 2.4s">
            <i class="lp2-runmark"></i>
            <span><em>Approve</em><strong>A human signs off — on the record</strong></span>
          </div>
          <div class="lp2-runrow" style="--rd2: 3.6s">
            <i class="lp2-runmark"></i>
            <span><em>Apply</em><strong>One controlled write · fully attributed</strong></span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Stats ──────────────────────────────────────────────────── -->
    <section class="lp2-stats" data-r>
      <div><strong>4</strong><span>Products, one substrate</span></div>
      <div><strong class="lp-accent">1</strong><span>Audit trail across everything</span></div>
      <div><strong>0</strong><span>External AI calls required</span></div>
    </section>

    <!-- ── Built on LACE ──────────────────────────────────────────── -->
    <section class="lp2-editions">
      <div class="lp2-editions-head" data-r>
        <h2>Built <span class="lp-accent">on LACE.</span></h2>
        <p>Industry editions built and operated on the platform.</p>
      </div>
      <div class="lp2-editions-grid">
        {
          editions.map((edition, i) => (
            <a href={edition.href} data-r data-reveal-delay={String(i * 90)}>
              <em>{edition.market}</em>
              <strong>{edition.name}</strong>
              <span>{edition.line}</span>
              <b>Explore →</b>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ── Deploy ─────────────────────────────────────────────────── -->
    <section class="lp2-deploy">
      <div data-r>
        <h2>Runs where <span class="lp-accent">you run.</span></h2>
        <p>Fully air-gapped if needed. No external AI calls.</p>
      </div>
      <div class="lp2-deploy-tiles" data-r data-reveal-delay="100" aria-hidden="true">
        <div class="lp2-deploy-tile">
          <svg viewBox="0 0 24 24" fill="none"><path d="M7 18a4.5 4.5 0 1 1 .66-8.95A6 6 0 0 1 19.35 10.6 3.75 3.75 0 0 1 18.25 18z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
          <span><strong>Cloud</strong><em>Fastest start</em></span>
        </div>
        <div class="lp2-deploy-tile">
          <svg viewBox="0 0 24 24" fill="none"><path d="M12 3.5l7 2.8v5.2c0 4.1-2.9 7-7 8.9-4.1-1.9-7-4.8-7-8.9V6.3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9.2 11.8l2 2 3.6-3.8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span><strong>Private Cloud</strong><em>Your VPC</em></span>
        </div>
        <div class="lp2-deploy-tile">
          <svg viewBox="0 0 24 24" fill="none"><rect x="4" y="4.5" width="16" height="6" rx="1.2" stroke="currentColor" stroke-width="1.5"/><rect x="4" y="13.5" width="16" height="6" rx="1.2" stroke="currentColor" stroke-width="1.5"/><circle cx="8" cy="7.5" r="1" fill="currentColor"/><circle cx="8" cy="16.5" r="1" fill="currentColor"/></svg>
          <span><strong>On-Premises</strong><em>Your hardware</em></span>
        </div>
        <div class="lp2-deploy-tile lp2-deploy-air">
          <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8.2" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2.6 3"/><circle cx="12" cy="12" r="2.6" fill="currentColor"/></svg>
          <span><strong>Air-Gapped</strong><em>Zero external calls</em></span>
        </div>
      </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────────── -->
    <section class="lp2-cta">
      <div data-r>
        <h2>See it on <span class="lp-accent">your documents.</span></h2>
        <p>
          We set up a pilot on your documents and one workflow your team
          actually runs. You judge the working output — in weeks, not a
          quarter-long project.
        </p>
        <div class="lp2-actions">
          <a href="/contact" class="lp-btn lp-btn-primary lp-btn-lg">Book a demo</a>
          <a
            href={whitepaper}
            target="_blank"
            rel="noopener noreferrer"
            class="lp-btn lp-btn-ghost lp-btn-lg"
          >
            Download the overview →
          </a>
        </div>
      </div>
    </section>
  </div>

  <LaceFooter />
</main>

<style>
  /* ═══ The frame: hairline rails + crosshair intersections ═══════ */
  .lp2 {
    --hair: rgba(13, 27, 22, 0.09);
    --hair-soft: rgba(13, 27, 22, 0.055);
  }

  .lp2-frame {
    position: relative;
    width: min(1180px, calc(100% - 3rem));
    margin-inline: auto;
    /* The full-bleed hero above already clears the fixed nav, so the
       frame only needs a little breathing room before the marquee. */
    padding-top: clamp(1.5rem, 4vw, 3rem);
  }

  @media (min-width: 1080px) {
    .lp2-frame::before,
    .lp2-frame::after {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      width: 1px;
      background: var(--hair);
    }

    .lp2-frame::before { left: 0; }
    .lp2-frame::after { right: 0; }

    /* crosshairs where section borders meet the rails */
    .lp2-frame > section {
      position: relative;
    }

    .lp2-frame > section::before,
    .lp2-frame > section::after {
      content: "+";
      position: absolute;
      top: -0.72em;
      z-index: 2;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.85rem;
      font-weight: 400;
      line-height: 1;
      color: rgba(var(--lp-green-rgb), 0.65);
      background: transparent;
    }

    .lp2-frame > section::before { left: -0.34em; }
    .lp2-frame > section::after { right: -0.34em; }

    .lp2-hero::before,
    .lp2-hero::after {
      content: none;
    }
  }

  .lp2-frame > section {
    border-top: 1px solid var(--hair);
  }

  .lp2-frame > .lp2-hero {
    border-top: 0;
  }

  /* ═══ Type ══════════════════════════════════════════════════════ */
  .lp2-eyebrow {
    margin: 0 0 1.6rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--lp-green-deep);
  }

  .lp2-h1 {
    margin: 0;
    font-family: "Space Grotesk", "Red Hat Display", sans-serif;
    font-size: clamp(2.5rem, 5.6vw, 4.4rem);
    font-weight: 500;
    letter-spacing: -0.025em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--lp-ink);
    text-wrap: balance;
  }

  .lp2-sub {
    max-width: 480px;
    margin: 1.5rem auto 0;
    font-size: clamp(1rem, 1.4vw, 1.13rem);
    line-height: 1.65;
    color: var(--lp-muted);
    text-wrap: balance;
  }

  .lp2 h2 {
    font-family: "Space Grotesk", "Red Hat Display", sans-serif;
    font-weight: 400;
    letter-spacing: -0.015em;
    text-transform: uppercase;
    line-height: 1.05;
    color: var(--lp-ink);
  }

  .lp2-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
    margin-top: 2.2rem;
  }

  /* ═══ Hero ══════════════════════════════════════════════════════ */
  .lp2-hero {
    padding: 0 0 clamp(3rem, 6vw, 5rem);
    text-align: center;
  }

  /* ── Hero: Introducing LACE + scroll-driven screenshot ─────────── */
  /* Restored from the original homepage's "Introducing LACE" moment:
     the headline is pinned to the top of the viewport and the dark,
     neon-framed screenshot rises up from below into full view as you
     scroll. Full-bleed (breaks out of the 1180px frame). */
  .lp2-hero-intro {
    position: relative;
    width: 100%;
    min-height: 200svh;
    padding: 0;
    margin: 0;
  }

  .lp2-hero-pin {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
  }

  /* Headline: vertically centred in the viewport (like the original), and
     it fades out as the screenshot rises up over it. */
  .lp2-intro-copy {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    z-index: 5;
    text-align: center;
    padding-inline: 1.5rem;
    opacity: var(--copy-opacity, 1);
    transform: translateY(calc(-50% + var(--copy-y, 0svh)));
    will-change: opacity, transform;
  }

  .lp2-intro-h1 {
    margin: 0.6rem 0 0;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: clamp(2.6rem, 7.4vw, 5.6rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    line-height: 0.97;
    color: var(--lp-ink);
  }

  .lp2-intro-lace {
    color: var(--lp-green);
  }

  .lp2-intro-sub {
    max-width: min(660px, 92vw);
    margin: 1.5rem auto 0;
    font-size: clamp(1rem, 1.5vw, 1.22rem);
    line-height: 1.6;
    color: var(--lp-muted);
    text-wrap: balance;
  }

  /* Load entrance: eyebrow, headline and subhead fade/rise in, staggered. */
  .lp2-eyebrow,
  .lp2-intro-h1,
  .lp2-intro-sub {
    animation: lp2-hero-in 820ms cubic-bezier(0.22, 0.61, 0.36, 1) both;
  }

  .lp2-eyebrow { animation-delay: 60ms; }
  .lp2-intro-h1 { animation-delay: 200ms; }
  .lp2-intro-sub { animation-delay: 420ms; }

  @keyframes lp2-hero-in {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp2-eyebrow,
    .lp2-intro-h1,
    .lp2-intro-sub {
      animation: none;
    }
  }

  /* Screenshot stage: ~95vw (nearly full width, no height cap — like the
     original), rising from below the fold up to nearly fill the screen. */
  .lp2-introshot {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 4;
    width: min(95vw, 1640px);
    aspect-ratio: 1.575 / 1;
    pointer-events: none;
    opacity: var(--introshot-opacity, 0);
    transform: translate3d(-50%, calc(-50% + var(--introshot-y, 112svh)), 0);
    transform-origin: 50% 76%;
    will-change: opacity, transform;
  }

  .lp2-introshot::before {
    content: "";
    position: absolute;
    inset: 5% 2% -8%;
    z-index: 0;
    pointer-events: none;
    border-radius: 18px;
    background:
      radial-gradient(ellipse at 50% 24%, rgba(0, 255, 194, 0.22), transparent 58%),
      radial-gradient(ellipse at 50% 100%, rgba(0, 168, 130, 0.16), transparent 66%);
    filter: blur(22px);
    opacity: var(--introshot-halo, 0.35);
  }

  .lp2-introshot-card {
    position: absolute;
    inset: 0;
    margin: 0;
    aspect-ratio: 1.575 / 1;
    padding: 7px;
    overflow: hidden;
    border: 1px solid rgba(247, 250, 255, 0.2);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(54, 60, 64, 0.96) 0%, rgba(22, 25, 27, 0.98) 48%, rgba(10, 11, 12, 0.98) 100%),
      #101214;
    box-shadow:
      0 0 0 1px rgba(0, 255, 194, 0.48),
      0 0 26px rgba(0, 255, 194, 0.3),
      0 22px 48px rgba(2, 10, 14, 0.26),
      0 0 0 1px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      inset 0 -1px 0 rgba(0, 0, 0, 0.72);
  }

  .lp2-introshot-card::before {
    content: "";
    position: absolute;
    inset: 7px;
    z-index: 2;
    pointer-events: none;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 4px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 0 0 1px rgba(0, 0, 0, 0.22);
  }

  .lp2-introshot-card::after {
    content: "";
    position: absolute;
    left: 1rem;
    right: 1rem;
    top: 0;
    z-index: 3;
    height: 1px;
    pointer-events: none;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.34), transparent);
  }

  .lp2-introshot-img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    object-fit: cover;
    object-position: center top;
  }

  @media (prefers-reduced-motion: reduce) {
    .lp2-hero-intro { min-height: 0; }
    .lp2-hero-pin { position: static; height: auto; padding: clamp(2rem, 5vw, 4rem) 0 clamp(3rem, 6vw, 5rem); }
    .lp2-intro-copy { position: static; padding-inline: 1.5rem; opacity: 1 !important; transform: none !important; }
    .lp2-introshot {
      position: relative;
      top: auto;
      left: 50%;
      margin: clamp(2.4rem, 5vw, 4rem) 0 0;
      width: min(95vw, 1400px);
      transform: translateX(-50%);
      opacity: 1 !important;
    }
  }

  @media (max-width: 680px) {
    .lp2-intro-h1 { font-size: clamp(2.2rem, 9vw, 3.2rem); }
  }

  /* ═══ Logo strip ════════════════════════════════════════════════ */
  .lp2-logos {
    border-top: 1px solid var(--hair);
  }

  .lp2-marquee {
    border: 0;
    background: transparent;
    padding: 1.15rem 0;
  }

  /* ═══ Editorial ═════════════════════════════════════════════════ */
  .lp2-editorial {
    padding: clamp(4rem, 8vw, 6.5rem) clamp(1.2rem, 4vw, 4rem);
  }

  .lp2-editorial p {
    max-width: 32ch;
    margin: 0;
    font-family: "Space Grotesk", "Red Hat Display", sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.35rem);
    font-weight: 400;
    letter-spacing: -0.015em;
    text-transform: uppercase;
    line-height: 1.15;
    color: var(--lp-faint);
  }

  .lp2-editorial strong {
    display: block;
    font-weight: 500;
    color: var(--lp-ink);
  }

  /* ═══ Feature cells ═════════════════════════════════════════════ */
  .lp2-cells {
    display: grid;
  }

  .lp2-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--hair);
  }

  .lp2-row > .lp2-cell + .lp2-cell {
    border-left: 1px solid var(--hair);
  }

  .lp2-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
    padding: clamp(2.2rem, 4.5vw, 3.6rem) clamp(1.2rem, 3.5vw, 3.2rem);
  }

  .lp2-cell-full {
    align-items: center;
    text-align: center;
  }

  .lp2-cell-copy h2 {
    margin: 0 0 0.55rem;
    font-size: clamp(1.35rem, 2.3vw, 1.8rem);
  }

  .lp2-cell-copy p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--lp-muted);
  }

  .lp2-cell-copy .lp2-kicker {
    margin: 0 0 0.8rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  .lp2-cell-copy .lp2-kicker b {
    margin-right: 0.4rem;
    font-weight: 600;
    color: var(--lp-green-deep);
  }

  .lp2-cell-demo {
    width: min(720px, 100%);
  }

  .lp2-cell-link {
    margin-top: auto;
    align-self: flex-start;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--lp-green-deep);
    transition: opacity 160ms ease;
  }

  .lp2-cell-full .lp2-cell-link {
    align-self: center;
  }

  .lp2-cell-link:hover {
    opacity: 0.7;
  }

  /* fragments: one product window per cell */
  .lp2-fragment {
    width: min(460px, 100%);
    margin-block: auto;
  }

  .lp2-win {
    overflow: hidden;
    border: 1px solid var(--lp-line);
    border-radius: 10px;
    background: #ffffff;
    box-shadow: 0 26px 60px -24px rgba(15, 30, 26, 0.3);
    text-align: left;
  }

  .lp2-win-bar {
    display: flex;
    align-items: center;
    gap: 0.38rem;
    padding: 0.55rem 0.9rem;
    border-bottom: 1px solid var(--lp-line-soft);
    background: #f6f7f8;
  }

  .lp2-win-bar i {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
  }

  .lp2-win-bar i:nth-child(1) { background: #f57d72; }
  .lp2-win-bar i:nth-child(2) { background: #f5c94e; }
  .lp2-win-bar i:nth-child(3) { background: #55ca77; }

  .lp2-win-bar span {
    margin-inline: auto;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    color: var(--lp-faint);
  }

  .lp2-win-body {
    display: grid;
    gap: 0.65rem;
    padding: clamp(0.9rem, 2vw, 1.2rem);
  }

  /* — bitemporal — */
  .lp2-time-fact {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.8rem 0.95rem;
    border: 1px solid var(--lp-line);
    border-radius: var(--lp-radius-lg);
    background: #ffffff;
    box-shadow: var(--lp-shadow-sm);
  }

  .lp2-time-fact > span:first-child {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  .lp2-time-vals {
    position: relative;
    display: inline-grid;
  }

  .lp2-time-vals strong {
    grid-area: 1 / 1;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--lp-ink);
  }

  .lp2-val-then { animation: lp2-then 7s ease-in-out infinite; }
  .lp2-val-now { animation: lp2-now 7s ease-in-out infinite; }

  @keyframes lp2-then {
    0%, 38% { opacity: 0; }
    50%, 88% { opacity: 1; }
    100% { opacity: 0; }
  }

  @keyframes lp2-now {
    0%, 38% { opacity: 1; }
    50%, 88% { opacity: 0; }
    100% { opacity: 1; }
  }

  .lp2-time-fact i {
    margin-left: auto;
    font-style: normal;
    padding: 0.16rem 0.5rem;
    border: 1px solid rgba(var(--lp-green-rgb), 0.4);
    border-radius: var(--lp-radius);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.56rem;
    color: var(--lp-green-deep);
  }

  .lp2-time-scrub {
    padding: 0.8rem 0.95rem 0.9rem;
    border: 1px solid var(--lp-line-soft);
    border-radius: var(--lp-radius-lg);
    background: rgba(255, 255, 255, 0.7);
  }

  .lp2-time-labels {
    position: relative;
    display: block;
    height: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .lp2-time-labels em {
    position: absolute;
    left: 0;
    font-style: normal;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lp-ink-soft);
  }

  .lp2-asof-then { animation: lp2-then 7s ease-in-out infinite; }
  .lp2-asof-now { animation: lp2-now 7s ease-in-out infinite; }

  .lp2-time-track {
    position: relative;
    height: 3px;
    border-radius: 2px;
    background: rgba(13, 27, 22, 0.09);
  }

  .lp2-time-knob {
    position: absolute;
    top: 50%;
    left: 85%;
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    border: 2px solid #fff;
    background: var(--lp-green);
    box-shadow: 0 1px 6px rgba(15, 30, 26, 0.3);
    transform: translate(-50%, -50%);
    animation: lp2-scrub 7s cubic-bezier(0.65, 0, 0.35, 1) infinite;
  }

  @keyframes lp2-scrub {
    0%, 38% { left: 85%; }
    50%, 88% { left: 38%; }
    100% { left: 85%; }
  }

  .lp2-time-ticks {
    display: flex;
    justify-content: space-between;
    margin-top: 0.45rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.55rem;
    color: var(--lp-faint);
  }

  /* — conflict — */
  .lp2-conflict-pair {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: stretch;
    gap: 0.6rem;
  }

  .lp2-evidence {
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--lp-line);
    border-radius: var(--lp-radius-lg);
    background: #ffffff;
    box-shadow: var(--lp-shadow-sm);
  }

  .lp2-evidence em {
    display: block;
    margin-bottom: 0.35rem;
    font-style: normal;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.54rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  .lp2-evidence p {
    margin: 0;
    font-size: 0.76rem;
    line-height: 1.55;
    color: var(--lp-ink-soft);
  }

  .lp2-evidence mark {
    padding: 0.05em 0.2em;
    background: rgba(var(--lp-green-rgb), 0.16);
    color: inherit;
  }

  .lp2-evidence mark.is-warn {
    background: rgba(255, 190, 70, 0.3);
  }

  .lp2-vs {
    align-self: center;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6rem;
    color: var(--lp-faint);
  }

  .lp2-conflict-flag {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.8rem;
    border: 1px solid rgba(196, 132, 12, 0.4);
    border-radius: var(--lp-radius-lg);
    background: rgba(255, 216, 111, 0.12);
    font-size: 0.74rem;
    font-weight: 500;
    color: #7a5200;
  }

  .lp2-conflict-flag i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: #d99a06;
    animation: lp2-blink 2s ease-in-out infinite;
  }

  @keyframes lp2-blink {
    50% { opacity: 0.35; }
  }

  /* — agent trace + gate — */
  .lp2-trace-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.58rem 0.75rem;
    border: 1px solid var(--lp-line-soft);
    border-radius: var(--lp-radius);
    background: #fdfefe;
    font-size: 0.76rem;
    color: var(--lp-ink-soft);
  }

  .lp2-trace-row i {
    flex: none;
    display: grid;
    place-items: center;
    width: 1.05rem;
    height: 1.05rem;
    border-radius: 50%;
    border: 1px solid rgba(var(--lp-green-rgb), 0.45);
    font-style: normal;
    font-size: 0.58rem;
    color: var(--lp-green-deep);
  }

  .lp2-trace-row i::before {
    content: "✓";
  }

  .lp2-trace-row b {
    font-weight: 600;
    color: var(--lp-ink);
  }

  .lp2-gate {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 0.8rem 0.95rem;
    border: 1px solid rgba(196, 132, 12, 0.45);
    border-radius: var(--lp-radius-lg);
    background: rgba(255, 216, 111, 0.1);
  }

  .lp2-gate em {
    display: block;
    font-style: normal;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a06a00;
  }

  .lp2-gate strong {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--lp-ink);
  }

  .lp2-approve {
    flex: none;
    padding: 0.45rem 0.95rem;
    border-radius: var(--lp-radius);
    background: linear-gradient(135deg, #00b88d, #00d9ae);
    color: var(--lp-green-ink);
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    box-shadow: 0 4px 14px -6px rgba(var(--lp-green-rgb), 0.7);
  }

  .lp2-gate-meta {
    margin: 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.56rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  /* — build — */
  .lp2-prompt {
    display: flex;
    gap: 0.5rem;
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--lp-line);
    border-radius: var(--lp-radius-lg);
    background: #ffffff;
    box-shadow: var(--lp-shadow-sm);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    color: var(--lp-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lp2-prompt b {
    color: var(--lp-green);
  }

  .lp2-buildsteps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.4rem;
  }

  .lp2-buildsteps span {
    position: relative;
    padding: 0.45rem 0.4rem 0.45rem 1.25rem;
    border: 1px solid var(--lp-line-soft);
    border-radius: var(--lp-radius);
    background: #ffffff;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.56rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--lp-muted);
  }

  .lp2-buildsteps span::before {
    content: "";
    position: absolute;
    left: 0.48rem;
    top: 50%;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    border: 1.5px solid rgba(13, 27, 22, 0.2);
    transform: translateY(-50%);
    animation: lp2-dot 6s ease-in-out infinite;
    animation-delay: var(--d, 0s);
  }

  @keyframes lp2-dot {
    0%, 100% { border-color: rgba(13, 27, 22, 0.2); background: transparent; }
    8%, 18% { border-color: var(--lp-green); background: rgba(var(--lp-green-rgb), 0.35); }
    24%, 96% { border-color: var(--lp-green); background: var(--lp-green); }
  }

  .lp2-liveurl {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.6rem 0.85rem;
    border: 1px solid rgba(var(--lp-green-rgb), 0.5);
    border-radius: var(--lp-radius-lg);
    background: linear-gradient(90deg, rgba(var(--lp-green-rgb), 0.07), transparent 80%);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    color: var(--lp-ink);
  }

  .lp2-liveurl i {
    flex: none;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--lp-green);
    animation: lp2-blink 1.8s ease-in-out infinite;
  }

  .lp2-liveurl b {
    margin-left: auto;
    padding: 0.16rem 0.45rem;
    border-radius: var(--lp-radius);
    background: var(--lp-green);
    color: #fff;
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.14em;
  }

  /* ═══ Governance ════════════════════════════════════════════════ */
  .lp2-gov {
    display: grid;
