---
/**
 * Fixed top navigation for laceplatform.com (light theme) with the
 * PRODUCT megamenu (Platform · Applications · Customer Stories).
 * Also carries the site-wide interaction script: megamenu, mobile menu,
 * scroll chrome, and the [data-r] reveal observer used by every page.
 */
interface Props {
  active?: "home" | "product" | "pricing" | "docs" | "blog";
}

const { active } = Astro.props;

const platform = [
  {
    href: "/platform/enterprise-search",
    icon: "search",
    title: "Enterprise Search",
    desc: "One search bar for everything you know",
  },
  {
    href: "/platform/knowledge-graph",
    icon: "graph",
    title: "Knowledge Graph",
    desc: "Every fact carries a receipt",
  },
  {
    href: "/platform/agents",
    icon: "agent",
    title: "Agentic Platform",
    desc: "AI teammates that follow policy",
  },
  {
    href: "/platform/app-builder",
    icon: "apps",
    title: "App Builder",
    desc: "One prompt to a live application",
    badge: "New",
  },
] as const;

const applications = [
  {
    href: "/applications#lace-gov",
    icon: "shield",
    title: "LACE-GOV",
    desc: "Federal & defense knowledge, BFO/CCO-conformant",
  },
  {
    href: "/applications#lace-legal",
    icon: "scale",
    title: "LACE Legal",
    desc: "Contract intelligence & obligation tracking",
  },
  {
    href: "/applications#lace-finance",
    icon: "chart",
    title: "LACE Finance",
    desc: "Research where every figure traces to source",
  },
] as const;
---

<header id="lp-nav" class="lp-nav">
  <div class="lp-nav-inner">
    <a href="/" class="lp-brand" aria-label="LACE home">
      <svg width="19" height="19" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="9" cy="9" r="3" fill="#00A882"></circle>
        <circle cx="9" cy="9" r="6.5" stroke="#00A882" stroke-width="0.7" opacity="0.5"></circle>
        <circle cx="9" cy="9" r="8.6" stroke="#00A882" stroke-width="0.5" opacity="0.22"></circle>
      </svg>
      <span>LACE</span>
    </a>

    <button
      class="lp-nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="lpNavPanel"
      aria-label="Toggle navigation"
    >
      <span></span>
      <span></span>
    </button>

    <div class="lp-nav-panel" id="lpNavPanel">
      <nav class="lp-nav-links" aria-label="Primary">
        <button
          type="button"
          class="lp-mega-trigger"
          data-mega-trigger
          aria-expanded="false"
          aria-controls="lpMega"
          aria-current={active === "product" ? "page" : undefined}
        >
          Product
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M2 3.5 5 6.5 8 3.5" stroke="currentColor" stroke-width="1.4"></path>
          </svg>
        </button>

        <!-- Mobile-only accordion mirror of the megamenu -->
        <details class="lp-nav-acc">
          <summary>Product</summary>
          <div class="lp-nav-acc-body">
            <em>Platform</em>
            {platform.map((item) => <a href={item.href}>{item.title}</a>)}
            <em>Applications</em>
            <a href="/applications#built-on-lace">Built on LACE</a>
            {applications.map((item) => <a href={item.href}>{item.title}</a>)}
            <em>Customers</em>
            {/* Customer stories temporarily disabled — route off until real stories are cleared. */}
            {/* <a href="/customers">Customer stories</a> */}
            <span class="lp-nav-acc-soon">Customer stories — coming soon</span>
          </div>
        </details>

        <a href="/pricing" aria-current={active === "pricing" ? "page" : undefined}>Pricing</a>
        <a href="/docs" aria-current={active === "docs" ? "page" : undefined}>Docs</a>
        <a href="/blog" aria-current={active === "blog" ? "page" : undefined}>Blog</a>
      </nav>
      <a href="/contact" class="lp-nav-cta">Book a demo</a>
    </div>
  </div>

  <!-- ── PRODUCT megamenu ─────────────────────────────────────────── -->
  <div class="lp-mega" id="lpMega" data-mega>
    <div class="lp-wrap lp-mega-grid">
      <div class="lp-mega-col">
        <p class="lp-mega-label">Platform</p>
        {
          platform.map((item) => (
            <a href={item.href} class="lp-mega-row">
              <span class="lp-mega-icon" aria-hidden="true">
                {item.icon === "search" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <circle cx="10.5" cy="10.5" r="6.5" stroke="currentColor" stroke-width="1.5" />
                    <path d="M15.5 15.5L21 21" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )}
                {item.icon === "graph" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <circle cx="5" cy="19" r="2.4" stroke="currentColor" stroke-width="1.5" />
                    <circle cx="12" cy="5" r="2.4" stroke="currentColor" stroke-width="1.5" />
                    <circle cx="19" cy="15" r="2.4" stroke="currentColor" stroke-width="1.5" />
                    <path d="M6.4 16.9L10.8 7.2M14 6.5l3.4 6.4M7.5 18.5l9-2.8" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )}
                {item.icon === "agent" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M12 2.5l8 4.6v9.3l-8 4.6-8-4.6V7.1z" stroke="currentColor" stroke-width="1.5" />
                    <circle cx="12" cy="12" r="2.4" fill="currentColor" />
                  </svg>
                )}
                {item.icon === "apps" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="3" width="7.5" height="7.5" stroke="currentColor" stroke-width="1.5" />
                    <rect x="13.5" y="3" width="7.5" height="7.5" stroke="currentColor" stroke-width="1.5" />
                    <rect x="3" y="13.5" width="7.5" height="7.5" stroke="currentColor" stroke-width="1.5" />
                    <path d="M17.25 13.5v7.5M13.5 17.25H21" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )}
              </span>
              <span class="lp-mega-copy">
                <strong>
                  {item.title}
                  {"badge" in item && item.badge && <i class="lp-mega-badge">{item.badge}</i>}
                </strong>
                <span>{item.desc}</span>
              </span>
            </a>
          ))
        }
      </div>

      <div class="lp-mega-col">
        <p class="lp-mega-label">Applications</p>
        <a href="/applications#built-on-lace" class="lp-mega-story lp-mega-story-sm">
          <span class="lp-mega-story-top">
            <span class="lp-mega-story-pill">Built on LACE</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 11 11 3M5 3h6v6" stroke="currentColor" stroke-width="1.4"></path>
            </svg>
          </span>
          <span class="lp-mega-story-title">
            Launch and monetize <em>your own app</em>
          </span>
          <span class="lp-mega-story-meta">App Builder + lace-app-sdk · billing & rollback built in</span>
        </a>
        {
          applications.map((item) => (
            <a href={item.href} class="lp-mega-row">
              <span class="lp-mega-icon" aria-hidden="true">
                {item.icon === "shield" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M12 2.8 20 6v6.2c0 4.6-3.4 7.8-8 9-4.6-1.2-8-4.4-8-9V6z" stroke="currentColor" stroke-width="1.5" />
                    <path d="m8.6 12 2.3 2.3 4.5-4.6" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )}
                {item.icon === "scale" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M12 3v18M5 6.5h14M8 21h8" stroke="currentColor" stroke-width="1.5" />
                    <path d="M5 6.5 2.5 13a2.9 2.9 0 0 0 5 0z" stroke="currentColor" stroke-width="1.5" />
                    <path d="M19 6.5 16.5 13a2.9 2.9 0 0 0 5 0z" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )}
                {item.icon === "chart" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M3.5 20.5h17" stroke="currentColor" stroke-width="1.5" />
                    <path d="M6 20.5v-7M11 20.5V6M16 20.5v-10M21 20.5V9.5" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )}
                {item.icon === "rocket" && (
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M12 15c5-4 6.5-8.5 6.2-12.2C14.5 2.5 10 4 6 9l-3 6 3 3z" stroke="currentColor" stroke-width="1.5" transform="rotate(45 12 12)" />
                    <circle cx="13.4" cy="10.6" r="1.6" stroke="currentColor" stroke-width="1.3" />
                    <path d="m5.5 18.5-2 2" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )}
              </span>
              <span class="lp-mega-copy">
                <strong>{item.title}</strong>
                <span>{item.desc}</span>
              </span>
            </a>
          ))
        }
      </div>

      <div class="lp-mega-col lp-mega-col-story">
        <p class="lp-mega-label">Customer Stories</p>
        {/* Customer stories temporarily disabled — the /customers route is off
            (src/pages/_customers.astro) until we have real, cleared stories.
            Restore the two anchors below and re-enable the route to bring back. */}
        {/*
        <a href="/customers#federal" class="lp-mega-story">
          <span class="lp-mega-story-top">
            <span class="lp-mega-story-pill">Customer story</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 11 11 3M5 3h6v6" stroke="currentColor" stroke-width="1.4"></path>
            </svg>
          </span>
          <span class="lp-mega-story-title">
            Searching <em>12 enclaves</em> without moving a single document
          </span>
          <span class="lp-mega-story-meta">Federal program office · Enterprise Search + LACE-GOV</span>
        </a>
        <a href="/customers" class="lp-mega-row lp-mega-row-more">
          <span class="lp-mega-copy">
            <strong>Browse customer stories</strong>
            <span>How teams run governed AI on LACE</span>
          </span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4"></path>
          </svg>
        </a>
        */}
        <div class="lp-mega-soon">
          <span class="lp-mega-story-pill">Coming soon</span>
          <span class="lp-mega-soon-copy">Customer stories are on the way.</span>
        </div>
      </div>
    </div>
  </div>
</header>

<div class="lp-mega-veil" data-mega-veil aria-hidden="true"></div>

<style>
  /* Load-in: the nav settles down from the top on first paint — brand first,
     then the links, then the CTA — a quiet cue that the page is ready. */
  .lp-brand {
    animation: lp-nav-in 720ms cubic-bezier(0.22, 0.61, 0.36, 1) both;
    animation-delay: 80ms;
  }

  @media (min-width: 881px) {
    .lp-nav-links > *,
    .lp-nav-cta {
      animation: lp-nav-in 720ms cubic-bezier(0.22, 0.61, 0.36, 1) both;
    }

    .lp-nav-links > *:nth-child(1) { animation-delay: 200ms; }
    .lp-nav-links > *:nth-child(2) { animation-delay: 250ms; }
    .lp-nav-links > *:nth-child(3) { animation-delay: 300ms; }
    .lp-nav-links > *:nth-child(4) { animation-delay: 350ms; }
    .lp-nav-links > *:nth-child(5) { animation-delay: 400ms; }
    .lp-nav-cta { animation-delay: 470ms; }
  }

  @keyframes lp-nav-in {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lp-brand,
    .lp-nav-links > *,
    .lp-nav-cta {
      animation: none;
    }
  }
</style>

<script>
  // Megamenu: hover + click open, Esc / outside click close
  (() => {
    const nav = document.getElementById("lp-nav");
    if (!nav) return;
    const trigger = nav.querySelector<HTMLButtonElement>("[data-mega-trigger]");
    const mega = nav.querySelector<HTMLElement>("[data-mega]");
    const veil = document.querySelector<HTMLElement>("[data-mega-veil]");
    if (!trigger || !mega || !veil) return;

    let closeTimer = 0;
    const canHover = window.matchMedia("(hover: hover) and (min-width: 881px)");

    const setOpen = (open: boolean) => {
      window.clearTimeout(closeTimer);
      nav.classList.toggle("mega-open", open);
      veil.classList.toggle("is-on", open);
      trigger.setAttribute("aria-expanded", open ? "true" : "false");
    };

    const delayClose = () => {
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(() => setOpen(false), 160);
    };

    trigger.addEventListener("click", () =>
      setOpen(!nav.classList.contains("mega-open")),
    );

    [trigger, mega].forEach((el) => {
      el.addEventListener("mouseenter", () => {
        if (canHover.matches) setOpen(true);
      });
      el.addEventListener("mouseleave", () => {
        if (canHover.matches) delayClose();
      });
    });

    veil.addEventListener("click", () => setOpen(false));
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setOpen(false);
    });
    mega.querySelectorAll("a").forEach((link) =>
      link.addEventListener("click", () => setOpen(false)),
    );
  })();

  // Mobile menu + scroll chrome
  (() => {
    const nav = document.getElementById("lp-nav");
    if (!nav) return;
    const toggle = nav.querySelector(".lp-nav-toggle");
    const panel = nav.querySelector(".lp-nav-panel");

    if (toggle && panel) {
      const setOpen = (open: boolean) => {
        nav.classList.toggle("is-open", open);
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      };

      toggle.addEventListener("click", () =>
        setOpen(!nav.classList.contains("is-open")),
      );
      panel
        .querySelectorAll("a")
        .forEach((link) => link.addEventListener("click", () => setOpen(false)));
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setOpen(false);
      });
      document.addEventListener("click", (event) => {
        if (!nav.contains(event.target as Node)) setOpen(false);
      });
    }

    let raf = 0;
    const update = () => {
      raf = 0;
      const progress = Math.min(1, Math.max(0, (window.scrollY - 14) / 90));
      nav.style.setProperty("--np", progress.toFixed(3));
    };
    const request = () => {
      if (!raf) raf = requestAnimationFrame(update);
    };
    update();
    window.addEventListener("scroll", request, { passive: true });
    window.addEventListener("resize", request);
  })();

  // Scroll reveal for [data-r]
  (() => {
    const els = Array.from(document.querySelectorAll<HTMLElement>("[data-r]"));
    if (!els.length) return;

    els.forEach((el, index) => {
      const explicit = Number(el.getAttribute("data-reveal-delay"));
      const delay = Number.isFinite(explicit) ? explicit : Math.min(index * 20, 260);
      el.style.setProperty("--rd", `${delay}ms`);
    });

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      els.forEach((el) => el.classList.add("vis"));
      return;
    }

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("vis");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -5% 0px" },
    );

    els.forEach((el) => obs.observe(el));
  })();
</script>
