---
/**
 * laceplatform.com — pricing page (light theme).
 * Packaging-led: one platform subscription, priced by deployment scope
 * and usage. No public rate card — every tier routes to sales.
 */
import LaceNav from "./LaceNav.astro";
import LaceFooter from "./LaceFooter.astro";
import whitepaper from "../../assets/docs/LACE_Enterprise_Overview_v3.pdf";
import "../../styles/lace-site.css";

const tiers = [
  {
    name: "Cloud",
    tagline: "The full platform, managed by us.",
    blurb:
      "For organizations that want search, graph, agents, and apps running on their data — without running infrastructure.",
    bullets: [
      "All four offerings on one subscription",
      "Managed hosting, upgrades, and scaling",
      "Standard connector library with scheduled sync",
      "Usage-based AI budgets with hard caps",
      "Guided onboarding on your first corpus",
    ],
    cta: { label: "Talk to sales", href: "/contact" },
    featured: false,
  },
  {
    name: "Enterprise",
    tagline: "Your cloud or your data center.",
    badge: "Most deployed",
    blurb:
      "For regulated enterprises that need the platform inside their own boundary — private cloud (VPC) or on-premises.",
    bullets: [
      "Everything in Cloud",
      "Private cloud (VPC) or on-premises deployment",
      "SSO / OIDC and role-mapped permission scopes",
      "Bring-your-own models and model policy controls",
      "Custom connectors and federation across enclaves",
      "Priority support and implementation services",
    ],
    cta: { label: "Book a demo", href: "/contact" },
    featured: true,
  },
  {
    name: "Government & Defense",
    tagline: "Air-gapped. Accreditation-ready.",
    blurb:
      "For federal, defense, and intelligence programs where the deployment boundary is the mission boundary.",
    bullets: [
      "Everything in Enterprise",
      "Fully air-gapped deployment — no external AI calls",
      "BFO/CCO ontology conformance artifacts",
      "Accreditation evidence: lineage, access enforcement, audit",
      "Cross-enclave discovery without data movement",
      "High-touch delivery by a team with DoD/USAF pedigree",
    ],
    cta: { label: "Contact us", href: "/contact" },
    featured: false,
  },
];

const included = [
  "Provenance on every output",
  "Permissions enforced at query time",
  "Complete audit trail",
  "Budgets & approval gates",
  "App Builder + lace-app-sdk",
  "Evaluation & monitoring",
];

const comparison = {
  columns: ["Cloud", "Enterprise", "Gov & Defense"],
  groups: [
    {
      title: "Platform",
      rows: [
        { label: "Enterprise Search", values: ["yes", "yes", "yes"] },
        { label: "Knowledge Graph", values: ["yes", "yes", "yes"] },
        { label: "Agentic Platform — all channels", values: ["yes", "yes", "yes"] },
        { label: "App Builder + hosting", values: ["yes", "yes", "yes"] },
        { label: "lace-app-sdk developer access", values: ["yes", "yes", "yes"] },
      ],
    },
    {
      title: "Deployment",
      rows: [
        { label: "Managed cloud", values: ["yes", "optional", "—"] },
        { label: "Private cloud (VPC)", values: ["—", "yes", "yes"] },
        { label: "On-premises", values: ["—", "yes", "yes"] },
        { label: "Air-gapped, no external AI calls", values: ["—", "optional", "yes"] },
      ],
    },
    {
      title: "Governance & security",
      rows: [
        { label: "Role-based access + resource ACLs", values: ["yes", "yes", "yes"] },
        { label: "SSO / OIDC", values: ["optional", "yes", "yes"] },
        { label: "Bring-your-own models & model policy", values: ["—", "yes", "yes"] },
        { label: "BFO/CCO conformance artifacts", values: ["—", "optional", "yes"] },
        { label: "Accreditation evidence pack", values: ["—", "optional", "yes"] },
      ],
    },
    {
      title: "Support",
      rows: [
        { label: "Guided onboarding", values: ["yes", "yes", "yes"] },
        { label: "Priority support", values: ["—", "yes", "yes"] },
        { label: "Implementation services", values: ["optional", "yes", "yes"] },
      ],
    },
  ],
};

const monetize = {
  kicker: "Apps as products",
  title: "Build it on LACE. Sell it on LACE.",
  accent: "Sell it on LACE.",
  body: "Applications built on the App Builder ship with subscription and billing infrastructure out of the box. An internal tool can become a revenue-generating product without a re-platforming project — launch, price, and sell on the same governed platform, at near-zero marginal cost per new app.",
};

const faqs = [
  {
    q: "How is LACE licensed?",
    a: "As a platform subscription: one contract covers all four offerings — Enterprise Search, Knowledge Graph, Agentic Platform, and App Builder — priced by deployment scope and usage. AI usage runs under budgets you set, with hard caps enforced by the platform.",
  },
  {
    q: "Can LACE run fully offline?",
    a: "Yes. LACE deploys to managed cloud, private cloud (VPC), on-premises, or fully air-gapped environments with no external AI calls. The governance substrate — provenance, permissions, budgets, audit — is identical in every footprint.",
  },
  {
    q: "Which AI models does LACE use?",
    a: "LACE resolves models by purpose through a model registry and settings plane. You can run our managed defaults, bring your own endpoints, or restrict specific workloads to specific models — with usage and cost attributed per tenant, user, and purpose.",
  },
  {
    q: "How does an evaluation work?",
    a: "We scope a technical evaluation on your documents and one real workflow, under NDA. You judge LACE on cited answers and working output — not slides. Typical evaluations run in weeks, not quarters.",
  },
  {
    q: "Does LACE replace our existing systems?",
    a: "No — it connects to them. Connectors sync SharePoint, Google Drive, OneDrive, Dropbox, Notion, Slack, email, S3, databases, and existing indexes, and federated discovery reaches sources that can't move. Source-system permissions carry through to every result.",
  },
  {
    q: "Is the SDK included?",
    a: "Yes. The lace-app-sdk — the public, versioned contract surface for building apps on LACE — is available to developers on every tier, along with local development that mirrors production and push-to-deploy through the governed release pipeline.",
  },
];

const accentize = (title: string, accent: string) =>
  title.replace(accent, `<span class="lp-accent">${accent}</span>`);
---

<main class="lp-site lp-pricing">
  <LaceNav active="pricing" />

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="lp-phero">
    <div class="lp-wrap lp-phero-center">
      <p class="lp-kicker" data-r>Pricing</p>
      <h1 class="lp-h1 lp-phero-title" data-r data-reveal-delay="70">
        One platform.<br />
        <span class="lp-accent">Priced by footprint.</span>
      </h1>
      <p class="lp-lead lp-phero-lead" data-r data-reveal-delay="140">
        Every tier includes all four offerings on one contract — search, graph,
        agents, and apps — with the same governance substrate underneath.
        You choose where it runs and how far it reaches.
      </p>
    </div>
  </section>

  <!-- ── Tiers ────────────────────────────────────────────────────── -->
  <section class="lp-section-tight lp-tiers-section">
    <div class="lp-wrap">
      <div class="lp-tiers">
        {
          tiers.map((tier, index) => (
            <article
              class:list={["lp-card", "lp-tier", tier.featured && "lp-tier-featured"]}
              data-r
              data-reveal-delay={100 + index * 90}
            >
              {tier.badge && <span class="lp-tier-badge">{tier.badge}</span>}
              <h2 class="lp-h3 lp-tier-name">{tier.name}</h2>
              <p class="lp-tier-tagline">{tier.tagline}</p>
              <p class="lp-tier-blurb">{tier.blurb}</p>
              <ul class="lp-tier-list">
                {tier.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
              <a
                href={tier.cta.href}
                class:list={[
                  "lp-btn",
                  tier.featured ? "lp-btn-primary" : "lp-btn-ghost",
                  "lp-tier-cta",
                ]}
              >
                {tier.cta.label}
              </a>
            </article>
          ))
        }
      </div>

      <div class="lp-included" data-r>
        <p class="lp-included-label">Included in every tier</p>
        <div class="lp-included-items">
          {included.map((item) => <span class="lp-chip">{item}</span>)}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Comparison ───────────────────────────────────────────────── -->
  <section class="lp-section">
    <div class="lp-wrap">
      <div class="lp-head" data-r>
        <p class="lp-kicker">Compare</p>
        <h2 class="lp-h2" set:html={accentize("What ships in each footprint.", "each footprint.")} />
      </div>

      <div class="lp-table-scroll" data-r data-reveal-delay="100">
        <table class="lp-table lp-compare">
          <thead>
            <tr>
              <th></th>
              {comparison.columns.map((column) => <th>{column}</th>)}
            </tr>
          </thead>
          <tbody>
            {
              comparison.groups.map((group) => (
                <>
                  <tr class="lp-compare-group">
                    <td colspan="4">{group.title}</td>
                  </tr>
                  {group.rows.map((row) => (
                    <tr>
                      <td>
                        <strong>{row.label}</strong>
                      </td>
                      {row.values.map((value) => (
                        <td
                          class:list={[
                            value === "yes" && "lp-yes",
                            value === "—" && "lp-no",
                          ]}
                        >
                          {value === "yes" ? "✓" : value === "optional" ? "Optional" : "—"}
                        </td>
                      ))}
                    </tr>
                  ))}
                </>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ── Apps as products ─────────────────────────────────────────── -->
  <section class="lp-section-tight">
    <div class="lp-wrap">
      <div class="lp-monetize" data-r>
        <div>
          <p class="lp-kicker">{monetize.kicker}</p>
          <h2 class="lp-h2" set:html={accentize(monetize.title, monetize.accent)} />
          <p class="lp-body lp-monetize-body">{monetize.body}</p>
        </div>
        <div class="lp-monetize-panel" aria-hidden="true">
          <div class="lp-monetize-row">
            <span>field-inventory.app</span><em>142 subscribers</em>
          </div>
          <div class="lp-monetize-row">
            <span>permit-review.app</span><em>38 seats · annual</em>
          </div>
          <div class="lp-monetize-row">
            <span>intake-triage.app</span><em>usage-billed</em>
          </div>
          <div class="lp-monetize-foot">Hosting · sign-in · billing · rollback — built in</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ──────────────────────────────────────────────────────── -->
  <section class="lp-section">
    <div class="lp-wrap lp-faq-wrap">
      <div class="lp-head" data-r>
        <p class="lp-kicker">FAQ</p>
        <h2 class="lp-h2" set:html={accentize("Answers, cited below.", "cited below.")} />
      </div>

      <div class="lp-faq" data-r data-reveal-delay="100">
        {
          faqs.map((faq) => (
            <details class="lp-faq-item">
              <summary>
                <span>{faq.q}</span>
                <i aria-hidden="true" />
              </summary>
              <p>{faq.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────────────── -->
  <section class="lp-section-tight">
    <div class="lp-wrap">
      <div class="lp-cta-band" data-r>
        <p class="lp-kicker">Next step</p>
        <h2 class="lp-h2">
          Scope your footprint <span class="lp-accent">in one call.</span>
        </h2>
        <p class="lp-lead">
          Tell us your deployment boundary, your corpus, and the first workflow.
          We'll come back with a concrete evaluation plan and pricing.
        </p>
        <div class="lp-cta-actions">
          <a href="/contact" class="lp-btn lp-btn-primary lp-btn-lg">Talk to sales</a>
          <a
            href={whitepaper}
            target="_blank"
            rel="noopener noreferrer"
            class="lp-btn lp-btn-ghost lp-btn-lg"
          >
            Download the overview →
          </a>
        </div>
      </div>
    </div>
  </section>

  <LaceFooter />
</main>

<style>
  .lp-phero {
    padding: clamp(8.5rem, 15vh, 11rem) 0 clamp(2rem, 4vw, 3rem);
  }

  .lp-phero-center {
    text-align: center;
  }

  .lp-phero-title {
    font-size: clamp(2.1rem, 4.6vw, 3.7rem);
  }

  .lp-phero-lead {
    max-width: 680px;
    margin: 1.5rem auto 0;
  }

  /* ── Tiers ────────────────────────────────────────────────────── */
  .lp-tiers {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.1rem;
    align-items: stretch;
  }

  .lp-tier {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.9rem 1.7rem 1.7rem;
  }

  .lp-tier-featured {
    border-color: rgba(var(--lp-green-rgb), 0.55);
    box-shadow:
      0 0 0 1px rgba(var(--lp-green-rgb), 0.25),
      0 18px 44px rgba(15, 30, 26, 0.12);
    background:
      linear-gradient(180deg, rgba(var(--lp-green-rgb), 0.05), transparent 40%),
      #ffffff;
  }

  .lp-tier-badge {
    position: absolute;
    top: -0.7rem;
    left: 1.6rem;
    padding: 0.28rem 0.7rem;
    border-radius: var(--lp-radius);
    background: var(--lp-grad);
    color: #ffffff;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .lp-tier-name {
    font-size: 1.15rem;
  }

  .lp-tier-tagline {
    margin: 0;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lp-green-deep);
  }

  .lp-tier-blurb {
    margin: 0.3rem 0 0;
    font-size: 0.86rem;
    line-height: 1.65;
    color: var(--lp-muted);
  }

  .lp-tier-list {
    margin: 1rem 0 1.6rem;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.55rem;
  }

  .lp-tier-list li {
    position: relative;
    margin: 0;
    padding-left: 1.3rem;
    font-size: 0.84rem;
    line-height: 1.55;
    color: var(--lp-ink-soft);
  }

  .lp-tier-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--lp-green);
  }

  .lp-tier-cta {
    margin-top: auto;
    justify-content: center;
  }

  .lp-included {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.6rem;
    margin-top: clamp(2rem, 4vw, 3rem);
    padding-top: 1.6rem;
    border-top: 1px solid var(--lp-line-soft);
  }

  .lp-included-label {
    margin: 0;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  .lp-included-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* ── Comparison table ─────────────────────────────────────────── */
  .lp-compare th:first-child {
    width: 42%;
  }

  .lp-compare th:not(:first-child),
  .lp-compare td:not(:first-child) {
    text-align: center;
  }

  .lp-compare-group td {
    padding-top: 1.2rem;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--lp-green-deep);
    background: rgba(var(--lp-green-rgb), 0.035);
  }

  /* ── Monetize ─────────────────────────────────────────────────── */
  .lp-monetize {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 5fr);
    gap: clamp(2.4rem, 5vw, 4.5rem);
    align-items: center;
    padding: clamp(2.2rem, 5vw, 3.6rem);
    border: 1px solid var(--lp-line);
    border-radius: var(--lp-radius-lg);
    background:
      radial-gradient(40rem 20rem at 100% 0%, rgba(var(--lp-green-rgb), 0.07), transparent 60%),
      #ffffff;
    box-shadow: var(--lp-shadow-sm);
  }

  .lp-monetize-body {
    max-width: 56ch;
  }

  .lp-monetize-panel {
    display: grid;
    gap: 0.5rem;
  }

  .lp-monetize-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0.95rem;
    border: 1px solid var(--lp-line-soft);
    border-radius: var(--lp-radius);
    background: #fdfefe;
  }

  .lp-monetize-row span {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: var(--lp-ink);
  }

  .lp-monetize-row em {
    font-style: normal;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    color: var(--lp-green-deep);
  }

  .lp-monetize-foot {
    margin-top: 0.4rem;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lp-faint);
  }

  /* ── FAQ ──────────────────────────────────────────────────────── */
  .lp-faq-wrap {
    max-width: 860px;
  }

  .lp-faq {
    display: grid;
    gap: 0.7rem;
    margin-top: clamp(1.6rem, 3vw, 2.4rem);
  }

  .lp-faq-item {
    border: 1px solid var(--lp-line);
    border-radius: var(--lp-radius-lg);
    background: #ffffff;
    box-shadow: var(--lp-shadow-sm);
    transition: border-color 200ms ease;
  }

  .lp-faq-item[open] {
    border-color: rgba(var(--lp-green-rgb), 0.45);
  }

  .lp-faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.05rem 1.3rem;
    cursor: pointer;
    list-style: none;
    font-family: "Space Grotesk", "JetBrains Mono", monospace;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--lp-ink);
  }

  .lp-faq-item summary::-webkit-details-marker {
    display: none;
  }

  .lp-faq-item summary i {
    flex: none;
    position: relative;
    width: 0.85rem;
    height: 0.85rem;
  }

  .lp-faq-item summary i::before,
  .lp-faq-item summary i::after {
    content: "";
    position: absolute;
    inset: 50% auto auto 0;
    width: 100%;
    height: 1.6px;
    background: var(--lp-green-deep);
    transition: transform 220ms ease;
  }

  .lp-faq-item summary i::after {
    transform: rotate(90deg);
  }

  .lp-faq-item[open] summary i::after {
    transform: rotate(0deg);
  }

  .lp-faq-item p {
    margin: 0;
    padding: 0 1.3rem 1.2rem;
    max-width: 72ch;
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--lp-muted);
  }

  /* ── Responsive ───────────────────────────────────────────────── */
  @media (max-width: 980px) {
    .lp-tiers {
      grid-template-columns: 1fr;
      max-width: 32rem;
      margin-inline: auto;
    }

    .lp-monetize {
      grid-template-columns: 1fr;
    }
  }
</style>
