<script>
  (() => {
    const topnav = document.getElementById("topnav");
    const toggle = document.querySelector(".official-topnav-toggle");
    const panel = document.getElementById("topNavPanel");

    if (topnav && toggle && panel) {
      const setOpen = (open) => {
        topnav.classList.toggle("is-open", open);
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      };

      toggle.addEventListener("click", () => {
        const open = !topnav.classList.contains("is-open");
        setOpen(open);
      });

      panel.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => setOpen(false));
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setOpen(false);
      });

      document.addEventListener("click", (event) => {
        if (!topnav.contains(event.target)) setOpen(false);
      });

      let navRaf = 0;
      const updateNav = () => {
        navRaf = 0;
        const progress = Math.min(1, Math.max(0, (window.scrollY - 20) / 100));
        topnav.style.setProperty("--nav-progress", String(progress));
      };
      const requestNav = () => {
        if (navRaf) return;
        navRaf = requestAnimationFrame(updateNav);
      };
      updateNav();
      window.addEventListener("scroll", requestNav, { passive: true });
      window.addEventListener("resize", requestNav);
    }
  })();

  (() => {
    const els = Array.from(document.querySelectorAll("[data-r]"));
    els.forEach((el, i) => {
      const explicit = Number(el.getAttribute("data-reveal-delay"));
      const delay = Number.isFinite(explicit) ? explicit : i * 25;
      el.style.setProperty("--rd", `${delay}ms`);
    });

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("vis");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -4% 0px" }
    );

    els.forEach((el) => obs.observe(el));
  })();

  (() => {
    const diagram = document.getElementById("identity-diagram");
    if (!diagram) return;

    const statusQueued = diagram.getAttribute("data-status-queued") || "queued";
    const statusRunning = diagram.getAttribute("data-status-running") || "running";
    const statusSucceeded = diagram.getAttribute("data-status-succeeded") || "succeeded";

    const nodes = Array.from(diagram.querySelectorAll("[data-flow-node]")).sort(
      (a, b) => Number(a.getAttribute("data-order")) - Number(b.getAttribute("data-order"))
    );
    const edges = Array.from(diagram.querySelectorAll("[data-flow-edge]")).sort(
      (a, b) => Number(a.getAttribute("data-order")) - Number(b.getAttribute("data-order"))
    );

    const progressEl = diagram.querySelector("[data-flow-progress]");
    const statusEl = diagram.querySelector("[data-flow-status]");

    const formatProgress = (value) => `${String(value).padStart(2, "0")}/${String(nodes.length).padStart(2, "0")}`;

    const setNodeStatus = (node, value) => {
      const chip = node.querySelector("[data-flow-node-status]");
      if (chip) chip.textContent = value;
    };

    const reset = () => {
      diagram.setAttribute("data-flow-phase", "idle");
      nodes.forEach((node) => {
        node.classList.remove("is-visible", "is-running", "is-done");
        setNodeStatus(node, statusQueued);
      });
      edges.forEach((edge) => edge.classList.remove("is-visible"));
      if (progressEl) progressEl.textContent = formatProgress(0);
      if (statusEl) statusEl.textContent = statusQueued;
    };

    const start = () => {
      reset();
      diagram.setAttribute("data-flow-phase", "running");
      if (statusEl) statusEl.textContent = statusRunning;

      let previousNode = null;
      nodes.forEach((node, index) => {
        const stepNumber = index + 1;
        const stepStart = index * 700;

        window.setTimeout(() => {
          edges
            .filter((edge) => Number(edge.getAttribute("data-order")) === stepNumber)
            .forEach((edge) => edge.classList.add("is-visible"));
        }, stepStart);

        window.setTimeout(() => {
          if (previousNode) {
            previousNode.classList.remove("is-running");
            previousNode.classList.add("is-done");
            setNodeStatus(previousNode, statusSucceeded);
          }

          node.classList.add("is-visible", "is-running");
          setNodeStatus(node, statusRunning);

          if (progressEl) progressEl.textContent = formatProgress(stepNumber);

          previousNode = node;

          if (stepNumber === nodes.length) {
            window.setTimeout(() => {
              node.classList.remove("is-running");
              node.classList.add("is-done");
              setNodeStatus(node, statusSucceeded);
              diagram.setAttribute("data-flow-phase", "complete");
              if (statusEl) statusEl.textContent = statusSucceeded;
            }, 620);
          }
        }, stepStart + (stepNumber === 1 ? 0 : 240));
      });

    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio > 0.2) {
            start();
            observer.disconnect();
          }
        });
      },
      { threshold: 0.2 }
    );

    observer.observe(diagram);
  })();

  (() => {
    const section = document.getElementById("pipeline-section");
    if (!section) return;

    let fired = false;
    const activate = () => {
      if (fired) return;
      fired = true;

      const diagram = document.getElementById("pipe-diagram");
      if (diagram) diagram.classList.add("pipe-active");

      const nodeEls = document.querySelectorAll(".pipe-node-el");
      const rings = document.querySelectorAll(".pn-ring");
      nodeEls.forEach((el, i) => {
        setTimeout(() => {
          el.classList.add("is-lit");
          if (rings[i]) rings[i].classList.add("is-lit");
        }, i * 780 + 200);
      });

      const cards = document.querySelectorAll(".pipeline-step-card");
      cards.forEach((card, i) => {
        setTimeout(() => {
          card.classList.add("is-flash");
          setTimeout(() => card.classList.remove("is-flash"), 700);
        }, i * 780 + 350);
      });

      const signals = document.querySelectorAll(".pipe-signal");
      signals.forEach((sig, i) => {
        const delay = i * 780 + 300;
        setTimeout(() => {
          const to = Number(sig.getAttribute("data-to") || "72");
          sig.setAttribute("opacity", "0.9");

          let start = 0;
          const duration = 600;
          const step = (ts) => {
            if (!start) start = ts;
            const p = Math.min(1, (ts - start) / duration);
            const ease = p < 0.5 ? 2 * p * p : -1 + (4 - 2 * p) * p;
            sig.setAttribute("cy", String(ease * to));
            if (p < 1) requestAnimationFrame(step);
            else sig.setAttribute("opacity", "0");
          };

          requestAnimationFrame(step);
        }, delay);
      });
    };

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio > 0.15) {
            activate();
            obs.disconnect();
          }
        });
      },
      { threshold: 0.15 }
    );

    obs.observe(section);
  })();

  (() => {
    const canvas = document.getElementById("cta-canvas");
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const C = "0,255,194";
    let W = 0;
    let H = 0;
    let offset = 0;
    let glints = [];
    let raf = 0;

    const resize = () => {
      const host = canvas.parentElement;
      if (!host) return;
      W = canvas.width = host.offsetWidth;
      H = canvas.height = host.offsetHeight;
    };

    const drawLines = () => {
      const numLines = 90;
      for (let i = 0; i < numLines; i += 1) {
        const t = i / numLines;
        const y = t * H;
        const curl = (t - 0.5) * H * 0.55;
        const cp1x = W * 0.25;
        const cp1y = y - curl * 0.6;
        const cp2x = W * 0.75;
        const cp2y = y + curl * 0.4;
        const dy = (offset * 0.4) % (H / numLines);
        const fy = y + dy;
        const dist = Math.abs(t - 0.5);
        const baseOp = Math.max(0.02, 0.22 - dist * 0.35);

        ctx.beginPath();
        ctx.moveTo(0, fy);
        ctx.bezierCurveTo(cp1x, cp1y + dy, cp2x, cp2y + dy, W, fy - curl * 0.08);
        ctx.strokeStyle = `rgba(${C},${baseOp})`;
        ctx.lineWidth = 0.55;
        ctx.stroke();
      }
    };

    const spawnGlint = () => {
      glints.push({
        x: Math.random() * W * 0.8 + W * 0.1,
        y: Math.random() * H,
        life: 1,
        size: Math.random() * 3 + 2
      });
    };

    const drawGlints = () => {
      glints = glints.filter((g) => g.life > 0);
      glints.forEach((g) => {
        const op = g.life * 0.85;
        const gr = ctx.createRadialGradient(g.x, g.y, 0, g.x, g.y, g.size * 5);
        gr.addColorStop(0, `rgba(${C},${op})`);
        gr.addColorStop(0.3, `rgba(${C},${op * 0.4})`);
        gr.addColorStop(1, `rgba(${C},0)`);

        ctx.beginPath();
        ctx.arc(g.x, g.y, g.size * 5, 0, Math.PI * 2);
        ctx.fillStyle = gr;
        ctx.fill();

        ctx.beginPath();
        ctx.arc(g.x, g.y, g.size * 0.6, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${op})`;
        ctx.fill();

        g.life -= 0.025;
      });
    };

    const draw = () => {
      ctx.clearRect(0, 0, W, H);
      drawLines();
      drawGlints();
      offset += 1;
      if (Math.random() < 0.04) spawnGlint();
      raf = requestAnimationFrame(draw);
    };

    resize();
    draw();

    if (window.ResizeObserver) {
      const ro = new ResizeObserver(() => {
        cancelAnimationFrame(raf);
        resize();
        draw();
      });
      if (canvas.parentElement) ro.observe(canvas.parentElement);
    } else {
      window.addEventListener("resize", () => {
        cancelAnimationFrame(raf);
        resize();
        draw();
      });
    }
  })();

  (() => {
    const canvas = document.getElementById("neural-canvas");
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const home = document.querySelector(".official-home");
    const isLight = () => !!(home && home.classList.contains("canvas-dim"));
    // Dark: bright teal. Light: vivid medium green — clearly colored on white.
    const C = () => isLight() ? "0,168,128" : "0,255,194";
    // Opacity scale: base values were tuned for dark bg; boost them for white.
    const os = () => isLight() ? 2.6 : 1;
    let nodes = [];
    let W = 0;
    let H = 0;
    let raf = 0;
    let sweepAngle = 0;

    const resize = () => {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
      nodes = [];
      const count = Math.max(10, Math.floor((W * H) / 18000));
      for (let i = 0; i < count; i += 1) {
        nodes.push({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.22,
          vy: (Math.random() - 0.5) * 0.22,
          r: Math.random() * 1.4 + 0.4,
          g: Math.random() * 0.2
        });
      }
    };

    const fire = () => {
      const s = nodes[Math.floor(Math.random() * nodes.length)];
      const near = nodes.filter((n) => n !== s && Math.hypot(n.x - s.x, n.y - s.y) < 220);
      if (!near.length) return;
      const d = near[Math.floor(Math.random() * near.length)];
      s.g = 1;
      d.g = Math.max(d.g, 0.6);
    };

    const drawSweep = () => {
      const cx = W * 0.5;
      const cy = H * 0.38;
      for (let i = 0; i < 50; i += 1) {
        const a = (i / 50) * Math.PI * 2 + sweepAngle;
        const r1 = W * 0.25;
        const r2 = W * 0.85;
        const x1 = cx + Math.cos(a) * r1;
        const y1 = cy + Math.sin(a) * r1 * 0.6;
        const x2 = cx + Math.cos(a + 0.18) * r2;
        const y2 = cy + Math.sin(a + 0.18) * r2 * 0.55;
        const op = (0.025 + Math.abs(Math.sin(a * 3 + sweepAngle * 2)) * 0.045) * os();
        ctx.beginPath();
        ctx.moveTo(x1, y1);
        ctx.lineTo(x2, y2);
        ctx.strokeStyle = `rgba(${C()},${op})`;
        ctx.lineWidth = 0.6;
        ctx.stroke();
      }
      sweepAngle += 0.0008;
    };

    const draw = () => {
      ctx.clearRect(0, 0, W, H);
      drawSweep();

      nodes.forEach((n) => {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < 0 || n.x > W) n.vx *= -1;
        if (n.y < 0 || n.y > H) n.vy *= -1;
        n.g = Math.max(0, n.g - 0.012);
      });

      if (Math.random() < 0.045) fire();

      for (let i = 0; i < nodes.length; i += 1) {
        for (let j = i + 1; j < nodes.length; j += 1) {
          const a = nodes[i];
          const b = nodes[j];
          const d = Math.hypot(a.x - b.x, a.y - b.y);
          if (d < 190) {
            const op = ((1 - d / 190) * 0.12 + (a.g + b.g) * 0.09) * os();
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.strokeStyle = `rgba(${C()},${op})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }

      nodes.forEach((n) => {
        if (n.g > 0.15) {
          const gr = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r * 9);
          gr.addColorStop(0, `rgba(${C()},${n.g * 0.35})`);
          gr.addColorStop(1, `rgba(${C()},0)`);
          ctx.beginPath();
          ctx.arc(n.x, n.y, n.r * 9, 0, Math.PI * 2);
          ctx.fillStyle = gr;
          ctx.fill();
        }

        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${C()},${Math.min(1, (0.18 + n.g * 0.7) * os())})`;
        ctx.fill();
      });

      raf = requestAnimationFrame(draw);
    };

    resize();
    draw();

    window.addEventListener("resize", () => {
      cancelAnimationFrame(raf);
      resize();
      draw();
    });
  })();

  (() => {
    const zone = document.getElementById("light-zone");
    const veil = document.getElementById("lace-flash-veil");
    const trigger = document.querySelector(".platform-intro-sub");
    const home = document.querySelector(".official-home");
    if (!zone || !veil || !trigger || !home) return;

    let isLight = false;
    let flashTimer = null;
    let initialCheck = true;

    const clearFlash = () => {
      if (flashTimer) { clearTimeout(flashTimer); flashTimer = null; }
      veil.classList.remove("flash-to-light", "flash-to-dark");
    };

    const applyLight = (on) => {
      if (on) {
        zone.classList.add("is-light");
        home.classList.add("canvas-dim");
      } else {
        zone.classList.remove("is-light");
        home.classList.remove("canvas-dim");
      }
    };

    const flash = (toLight) => {
      clearFlash();
      veil.classList.add(toLight ? "flash-to-light" : "flash-to-dark");
      // swap colors at peak of flash (~90ms in)
      flashTimer = setTimeout(() => { applyLight(toLight); }, 90);
      // clean up animation class after it completes
      setTimeout(clearFlash, 520);
    };

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !isLight) {
            isLight = true;
            if (initialCheck) {
              // Page loaded with trigger already in view — apply immediately, no flash
              applyLight(true);
            } else {
              flash(true);
            }
          } else if (!entry.isIntersecting && isLight) {
            // check if we scrolled back up above the trigger
            if (entry.boundingClientRect.top > 0) {
              isLight = false;
              if (initialCheck) {
                applyLight(false);
              } else {
                flash(false);
              }
            }
          }
          initialCheck = false;
        });
      },
      { threshold: 0, rootMargin: "0px 0px -5% 0px" }
    );

    // Also handle the case where the page loads scrolled well past the trigger
    // (trigger above viewport — boundingClientRect.top < 0, not intersecting)
    const rect = trigger.getBoundingClientRect();
    if (rect.bottom < 0) {
      // Trigger is entirely above the viewport — we're deep in the light zone
      isLight = true;
      applyLight(true);
    }

    obs.observe(trigger);
  })();
</script>
