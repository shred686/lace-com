        <a href={languageToggleHref}>{languageToggleLabel}</a>
      </div>
    </div>
  </footer>
</main>

<script>
  (() => {
    const topnav = document.getElementById("topnav");
    const toggle = document.querySelector(".official-topnav-toggle");
    const panel = document.getElementById("topNavPanel");

    if (topnav && toggle && panel) {
      const setOpen = (open) => {
        topnav.classList.toggle("is-open", open);
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      };

      toggle.addEventListener("click", () => {
        const open = !topnav.classList.contains("is-open");
        setOpen(open);
      });

      panel.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => setOpen(false));
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setOpen(false);
      });

      document.addEventListener("click", (event) => {
        if (!topnav.contains(event.target)) setOpen(false);
      });

      let navRaf = 0;
      const updateNav = () => {
        navRaf = 0;
        const progress = Math.min(1, Math.max(0, (window.scrollY - 20) / 100));
        topnav.style.setProperty("--nav-progress", String(progress));
      };
      const requestNav = () => {
        if (navRaf) return;
        navRaf = requestAnimationFrame(updateNav);
      };
      updateNav();
      window.addEventListener("scroll", requestNav, { passive: true });
      window.addEventListener("resize", requestNav);
    }
  })();

  (() => {
    const section = document.querySelector("[data-problem-scroll]");
    if (!section) return;

    const line = section.querySelector("[data-problem-line]");
    const finalLine = section.querySelector("[data-problem-final]");
    const laceLine = section.querySelector("[data-problem-lace]");
    const word = section.querySelector("[data-problem-word]");
    const slot = word ? word.parentElement : null;
    const zone = document.getElementById("light-zone");
    const veil = document.getElementById("lace-flash-veil");
    const home = document.querySelector(".official-home");
    if (!line || !finalLine || !laceLine || !word || !slot || !zone || !veil || !home) return;

    const configuredWords = (line.getAttribute("data-problem-words") || "fast.|smart.|impressive.").split("|");
    let activeWord = configuredWords[0];
    let isLight = false;
    let flashTimer = 0;
    let flipTimer = 0;
    let raf = 0;

    const clearFlash = () => {
      if (flashTimer) window.clearTimeout(flashTimer);
      flashTimer = 0;
      veil.classList.remove("flash-to-light", "flash-to-dark");
    };

    const applyLight = (on) => {
      section.classList.toggle("is-light", on);
      zone.classList.toggle("is-light", on);
      home.classList.toggle("canvas-dim", on);
    };

    const setLight = (on) => {
      if (on === isLight) return;
      isLight = on;
      clearFlash();
      veil.classList.add(on ? "flash-to-light" : "flash-to-dark");
      flashTimer = window.setTimeout(() => {
        applyLight(on);
        flashTimer = 0;
      }, 90);
      window.setTimeout(clearFlash, 520);
    };

    const setWord = (nextWord) => {
      if (nextWord === activeWord) return;
      activeWord = nextWord;
      slot.classList.remove("is-flipping");
      void slot.offsetWidth;
      slot.classList.add("is-flipping");
      if (flipTimer) window.clearTimeout(flipTimer);
      flipTimer = window.setTimeout(() => {
        word.textContent = nextWord;
        flipTimer = 0;
      }, 170);
    };

    const update = () => {
      raf = 0;
      const rect = section.getBoundingClientRect();
      const travel = Math.max(1, rect.height - window.innerHeight);
      const progress = Math.min(1, Math.max(0, -rect.top / travel));
      const clampValue = (value, min, max) => Math.min(max, Math.max(min, value));
      const easeOut = (value) => 1 - Math.pow(1 - value, 3);
      const lerp = (start, end, value) => start + (end - start) * value;
      const entryProgress = clampValue(1 - rect.top / window.innerHeight, 0, 1);
      const labelHoldEnd = 0.055;
      const labelSettleEnd = 0.14;
      const entryEase = easeOut(entryProgress);
      const isMobile = window.innerWidth <= 680;
      const labelStartScale = isMobile ? 0.82 : 0.72;
      const labelPeakScale = isMobile ? 2.05 : 3.35;
      const labelStartY = isMobile ? 0.8 : 1.4;
      const labelPeakY = isMobile ? 3.8 : 7.2;
      const labelStartLetter = isMobile ? 0.34 : 0.46;
      const labelPeakLetter = isMobile ? 0.24 : 0.34;
      const labelSettleLetter = isMobile ? 0.24 : 0.3;
      let labelScale = lerp(labelStartScale, labelPeakScale, entryEase);
      let labelY = lerp(labelStartY, labelPeakY, entryEase);
      let labelLetter = lerp(labelStartLetter, labelPeakLetter, entryEase);
      let labelGlow = entryEase;
      let labelOpacity = entryProgress;

      if (progress > 0 && progress < labelHoldEnd) {
        labelScale = labelPeakScale;
        labelY = labelPeakY;
        labelLetter = labelPeakLetter;
        labelGlow = 1;
        labelOpacity = 1;
      } else if (progress >= labelHoldEnd && progress < labelSettleEnd) {
        const settleProgress = easeOut((progress - labelHoldEnd) / (labelSettleEnd - labelHoldEnd));
        labelScale = lerp(labelPeakScale, 1, settleProgress);
        labelY = lerp(labelPeakY, 0, settleProgress);
        labelLetter = lerp(labelPeakLetter, labelSettleLetter, settleProgress);
        labelGlow = lerp(1, 0.28, settleProgress);
        labelOpacity = 1;
      } else if (progress >= labelSettleEnd) {
        labelScale = 1;
        labelY = 0;
        labelLetter = labelSettleLetter;
        labelGlow = 0.28;
        labelOpacity = 1;
      }

      section.style.setProperty("--problem-kicker-scale", String(labelScale));
      section.style.setProperty("--problem-kicker-y", `${labelY}svh`);
      section.style.setProperty("--problem-kicker-letter", `${labelLetter}em`);
      section.style.setProperty("--problem-kicker-glow", String(labelGlow));
      section.style.setProperty("--problem-kicker-opacity", String(labelOpacity));

      section.classList.toggle("is-label-visible", progress >= 0);
      line.classList.toggle("is-visible", progress >= 0.14 && progress < 0.76);
      line.classList.toggle("is-exiting", progress >= 0.73 && progress < 0.78);
      finalLine.classList.toggle("is-visible", progress >= 0.72 && progress < 0.86);
      laceLine.classList.toggle("is-visible", progress >= 0.86);
      setLight(progress >= 0.84);

      if (progress < 0.34) {
        setWord(configuredWords[0]);
      } else if (progress < 0.54) {
        setWord(configuredWords[1]);
      } else {
        setWord(configuredWords[2]);
      }
    };

    const requestUpdate = () => {
      if (raf) return;
      raf = requestAnimationFrame(update);
    };

    update();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
  })();

  (() => {
    const stage = document.querySelector("[data-rag-scroll]");
    if (!stage) return;

    const clampValue = (value, min, max) => Math.min(max, Math.max(min, value));
    const easeOut = (value) => 1 - Math.pow(1 - value, 3);
    const easeInOut = (value) =>
      value < 0.5 ? 4 * value * value * value : 1 - Math.pow(-2 * value + 2, 3) / 2;
    const lerp = (start, end, value) => start + (end - start) * value;
    let raf = 0;

    const update = () => {
      raf = 0;
      const rect = stage.getBoundingClientRect();
      const travel = Math.max(1, rect.height - window.innerHeight);
      const progress = Math.min(1, Math.max(0, -rect.top / travel));
      const entryProgress = clampValue(1 - rect.top / window.innerHeight, 0, 1);
      const entryEase = easeOut(entryProgress);
      const isMobile = window.innerWidth <= 680;

      const peakScale = isMobile ? 1 : 1.04;
      const finalScale = isMobile ? 0.58 : 0.5;
      const finalY = isMobile ? -12.4 : -12.5;
      const activeFinalY = isMobile ? 7.6 : 8.2;
      const activeStartY = isMobile ? 16 : 18;

      let struckScale = lerp(isMobile ? 0.8 : 0.72, peakScale, entryEase);
      let struckY = lerp(isMobile ? 2.2 : 3.2, 0, entryEase);
      let struckOpacity = entryProgress;
      let struckColorOpacity = 1;
      let strikeProgress = 0;
      let activeOpacity = 0;
      let activeY = activeStartY;
      let activeScale = 0.9;
      let activeGlow = 0;
      let activeStamp = 0;
      let activeBoxIn = 0;
      let activeBoxOut = 0;

      if (progress > 0 && progress < 0.08) {
        struckScale = peakScale;
        struckY = 0;
        struckOpacity = 1;
      }

      if (progress >= 0.08) {
        strikeProgress = easeInOut(clampValue((progress - 0.08) / 0.14, 0, 1));
        struckColorOpacity = lerp(1, 0.36, strikeProgress);
      }

      if (progress >= 0.23) {
        const settleProgress = easeOut(clampValue((progress - 0.23) / 0.15, 0, 1));
        struckScale = lerp(peakScale, finalScale, settleProgress);
        struckY = lerp(0, finalY, settleProgress);
      }

      if (progress >= 0.28) {
        activeOpacity = easeOut(clampValue((progress - 0.28) / 0.14, 0, 1));
        activeY = lerp(activeStartY, activeFinalY, activeOpacity);
        activeScale = lerp(0.96, 1, activeOpacity);
        activeGlow = activeOpacity;
        activeBoxIn = easeInOut(clampValue((progress - 0.28) / 0.24, 0, 1));
      }

      if (isMobile && progress >= 0.28) {
        const mobileStruckFade = easeOut(clampValue((progress - 0.28) / 0.12, 0, 1));
        struckOpacity = lerp(struckOpacity, 0, mobileStruckFade);
      }

      if (progress >= 0.8) {
        activeStamp = easeInOut(clampValue((progress - 0.8) / 0.1, 0, 1));
        activeScale = lerp(activeScale, 1, activeStamp);
        activeGlow = lerp(activeGlow, 0, activeStamp);
      }

      if (progress >= 0.79) {
        const exitRaw = clampValue((progress - 0.79) / 0.21, 0, 1);
        const exitProgress = easeInOut(exitRaw);
        const exitTravel = easeInOut(clampValue((exitRaw - 0.75) / 0.25, 0, 1));
        const struckFade = easeOut(clampValue(exitRaw / 0.22, 0, 1));
        activeBoxIn = 1;
        activeBoxOut = exitProgress;
        activeY = lerp(activeFinalY, activeFinalY - (isMobile ? 88 : 104), exitTravel);
        struckY = lerp(finalY, finalY - (isMobile ? 16 : 20), exitTravel);
        struckOpacity = lerp(struckOpacity, 0, struckFade);
      }

      stage.style.setProperty("--rag-struck-scale", String(struckScale));
      stage.style.setProperty("--rag-struck-y", `${struckY}svh`);
      stage.style.setProperty("--rag-struck-opacity", String(struckOpacity));
      stage.style.setProperty("--rag-struck-color-opacity", String(struckColorOpacity));
      stage.style.setProperty("--rag-strike-progress", String(strikeProgress));
      stage.style.setProperty("--rag-active-opacity", String(activeOpacity));
      stage.style.setProperty("--rag-active-y", `${activeY}svh`);
      stage.style.setProperty("--rag-active-scale", String(activeScale));
      stage.style.setProperty("--rag-active-blur", `${(1 - activeOpacity) * 2}px`);
      stage.style.setProperty("--rag-active-glow", String(activeGlow));
      stage.style.setProperty("--rag-active-stamp", String(activeStamp));
      stage.style.setProperty("--rag-active-box-enter-cut", `${(1 - activeBoxIn) * 100}%`);
      stage.style.setProperty("--rag-active-box-exit-cut", `${activeBoxOut * 100}%`);
    };

    const requestUpdate = () => {
      if (raf) return;
      raf = requestAnimationFrame(update);
    };

    update();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
  })();

  (() => {
    const els = Array.from(document.querySelectorAll("[data-r]"));
    els.forEach((el, i) => {
      const explicit = Number(el.getAttribute("data-reveal-delay"));
      const delay = Number.isFinite(explicit) ? explicit : i * 25;
      el.style.setProperty("--rd", `${delay}ms`);
    });

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("vis");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -4% 0px" }
    );

    els.forEach((el) => obs.observe(el));
  })();

  (() => {
    const section = document.getElementById("pipeline-section");
    if (!section) return;

    let fired = false;
    const activate = () => {
      if (fired) return;
      fired = true;

      const diagram = document.getElementById("pipe-diagram");
      if (diagram) diagram.classList.add("pipe-active");

      const nodeEls = document.querySelectorAll(".pipe-node-el");
      const rings = document.querySelectorAll(".pn-ring");
      nodeEls.forEach((el, i) => {
        setTimeout(() => {
          el.classList.add("is-lit");
          if (rings[i]) rings[i].classList.add("is-lit");
        }, i * 780 + 200);
      });

      const cards = document.querySelectorAll(".pipeline-step-card");
      cards.forEach((card, i) => {
        setTimeout(() => {
          card.classList.add("is-flash");
          setTimeout(() => card.classList.remove("is-flash"), 700);
        }, i * 780 + 350);
      });

      const signals = document.querySelectorAll(".pipe-signal");
      signals.forEach((sig, i) => {
        const delay = i * 780 + 300;
        setTimeout(() => {
          const to = Number(sig.getAttribute("data-to") || "72");
          sig.setAttribute("opacity", "0.9");

          let start = 0;
          const duration = 600;
          const step = (ts) => {
            if (!start) start = ts;
            const p = Math.min(1, (ts - start) / duration);
            const ease = p < 0.5 ? 2 * p * p : -1 + (4 - 2 * p) * p;
            sig.setAttribute("cy", String(ease * to));
            if (p < 1) requestAnimationFrame(step);
            else sig.setAttribute("opacity", "0");
          };

          requestAnimationFrame(step);
        }, delay);
      });
    };

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio > 0.15) {
            activate();
            obs.disconnect();
          }
        });
      },
      { threshold: 0.15 }
    );

    obs.observe(section);
  })();

  (() => {
    const canvas = document.getElementById("cta-canvas");
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const C = "255,216,111";
    let W = 0;
    let H = 0;
    let offset = 0;
    let glints = [];
    let raf = 0;

    const resize = () => {
      const host = canvas.parentElement;
      if (!host) return;
      W = canvas.width = host.offsetWidth;
      H = canvas.height = host.offsetHeight;
    };

    const drawLines = () => {
      const numLines = 90;
      for (let i = 0; i < numLines; i += 1) {
        const t = i / numLines;
        const y = t * H;
        const curl = (t - 0.5) * H * 0.55;
        const cp1x = W * 0.25;
        const cp1y = y - curl * 0.6;
        const cp2x = W * 0.75;
        const cp2y = y + curl * 0.4;
        const dy = (offset * 0.4) % (H / numLines);
        const fy = y + dy;
        const dist = Math.abs(t - 0.5);
        const baseOp = Math.max(0.02, 0.22 - dist * 0.35);

        ctx.beginPath();
        ctx.moveTo(0, fy);
        ctx.bezierCurveTo(cp1x, cp1y + dy, cp2x, cp2y + dy, W, fy - curl * 0.08);
        ctx.strokeStyle = `rgba(${C},${baseOp})`;
        ctx.lineWidth = 0.55;
        ctx.stroke();
      }
    };

    const spawnGlint = () => {
      glints.push({
        x: Math.random() * W * 0.8 + W * 0.1,
        y: Math.random() * H,
        life: 1,
        size: Math.random() * 3 + 2
      });
    };

    const drawGlints = () => {
      glints = glints.filter((g) => g.life > 0);
      glints.forEach((g) => {
        const op = g.life * 0.85;
        const gr = ctx.createRadialGradient(g.x, g.y, 0, g.x, g.y, g.size * 5);
        gr.addColorStop(0, `rgba(${C},${op})`);
        gr.addColorStop(0.3, `rgba(${C},${op * 0.4})`);
        gr.addColorStop(1, `rgba(${C},0)`);

        ctx.beginPath();
        ctx.arc(g.x, g.y, g.size * 5, 0, Math.PI * 2);
        ctx.fillStyle = gr;
        ctx.fill();

        ctx.beginPath();
        ctx.arc(g.x, g.y, g.size * 0.6, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${op})`;
        ctx.fill();

        g.life -= 0.025;
      });
    };

    const draw = () => {
      ctx.clearRect(0, 0, W, H);
      drawLines();
      drawGlints();
      offset += 1;
      if (Math.random() < 0.04) spawnGlint();
      raf = requestAnimationFrame(draw);
    };

    resize();
    draw();

    if (window.ResizeObserver) {
      const ro = new ResizeObserver(() => {
        cancelAnimationFrame(raf);
        resize();
        draw();
      });
      if (canvas.parentElement) ro.observe(canvas.parentElement);
    } else {
      window.addEventListener("resize", () => {
        cancelAnimationFrame(raf);
        resize();
        draw();
      });
    }
  })();

  (() => {
    const canvas = document.getElementById("neural-canvas");
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const home = document.querySelector(".official-home");
    const isLight = () => !!(home && home.classList.contains("canvas-dim"));
    // Dark: honey yellow. Light: deeper amber so the network remains visible on white.
    const C = () => isLight() ? "154,111,14" : "255,216,111";
    // Opacity scale: base values were tuned for dark bg; boost them for white.
    const os = () => isLight() ? 2.1 : 1;
    let nodes = [];
    let links = [];
    let layers = [];
    let signals = [];
    let W = 0;
    let H = 0;
    let raf = 0;
    let lastTs = 0;
    let nextSignalAt = 0;

    const clampValue = (value, min, max) => Math.min(max, Math.max(min, value));
    const lerp = (start, end, value) => start + (end - start) * value;

    const createLayeredNetwork = () => {
      nodes = [];
      links = [];
      layers = [];
      const isSmall = W <= 680;
      const counts = isSmall ? [1, 4, 4, 1] : [1, 5, 6, 1];
      const layerX = isSmall ? [0.055, 0.32, 0.68, 0.945] : [0.045, 0.31, 0.69, 0.955];
      const centerY = H * 0.5;
      const spread = Math.min(H * (isSmall ? 0.56 : 0.62), isSmall ? 430 : 560);

      const addNode = (x, y, layer, ordinal) => {
        const index = nodes.length;
        nodes.push({
          x,
          y,
          bx: x,
          by: y,
          layer,
          ordinal,
          phase: Math.random() * Math.PI * 2,
          r: layer === 0 || layer === counts.length - 1 ? 1.7 : 1.1 + Math.random() * 0.5,
          g: Math.random() * 0.2
        });
        return index;
      };

      const seen = new Set();
      const addLink = (a, b) => {
        const key = a < b ? `${a}:${b}` : `${b}:${a}`;
        if (seen.has(key)) return;
        seen.add(key);
        links.push({
          a,
          b,
          fromLayer: nodes[a].layer,
          toLayer: nodes[b].layer,
          seed: Math.random()
        });
      };

      counts.forEach((count, layer) => {
        const layerNodes = [];
        const x = W * layerX[layer];
        for (let ordinal = 0; ordinal < count; ordinal += 1) {
          const t = count === 1 ? 0.5 : ordinal / (count - 1);
          const y = count === 1 ? centerY : centerY - spread / 2 + spread * t;
          const xJitter = count === 1 ? 0 : (Math.random() - 0.5) * (isSmall ? 10 : 22);
          const yJitter = count === 1 ? (Math.random() - 0.5) * 24 : (Math.random() - 0.5) * 28;
          layerNodes.push(addNode(x + xJitter, y + yJitter, layer, ordinal));
        }
        layers.push(layerNodes);
      });

      layers[0].forEach((source) => {
        layers[1].forEach((target) => addLink(source, target));
      });

      layers[1].forEach((source, sourceIndex) => {
        const targetCount = layers[2].length;
        const targetOrdinals = new Set([
          sourceIndex % targetCount,
          (targetCount - 1 - sourceIndex + targetCount) % targetCount,
          (sourceIndex + 2) % targetCount
        ]);

        targetOrdinals.forEach((targetOrdinal) => {
          addLink(source, layers[2][targetOrdinal]);
        });
      });

      layers[2].forEach((source) => {
        layers[3].forEach((target) => addLink(source, target));
      });
    };

    const resize = () => {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
      signals = [];
      lastTs = 0;
      createLayeredNetwork();
      nextSignalAt = 0;
    };

    const layerLinks = (fromLayer, toLayer) =>
      links.filter((link) => link.fromLayer === fromLayer && link.toLayer === toLayer);

    const linkDelay = (link, stageIndex) => {
      const from = nodes[link.a];
      const to = nodes[link.b];
      if (stageIndex === 0) return to.ordinal * 34;
      if (stageIndex === 2) return from.ordinal * 30;
      return (from.ordinal * 24 + to.ordinal * 17 + link.seed * 42) % 150;
    };

    const spawnSignal = (now) => {
      if (signals.length > 1 || layers.length < 4) return;
      const traceMs = 540 + Math.random() * 90;
      const stageGap = 110;
      const stages = [0, 1, 2].map((stageIndex) => {
        const stageLinks = layerLinks(stageIndex, stageIndex + 1);
        return {
          startOffset: stageIndex * (traceMs + stageGap),
          traceMs,
          links: stageLinks.map((link) => ({
            ...link,
            delay: linkDelay(link, stageIndex)
          }))
        };
      });

      if (stages.some((stage) => !stage.links.length)) return;
      signals.push({
        stages,
        source: layers[0][0],
        start: now,
        glowMs: 700
      });
    };

    const stageEnd = (stage) => {
      let maxDelay = 0;
      stage.links.forEach((link) => {
        maxDelay = Math.max(maxDelay, link.delay);
      });
      return stage.startOffset + maxDelay + stage.traceMs;
    };

    const signalDuration = (signal) => {
      let end = 0;
      signal.stages.forEach((stage) => {
        end = Math.max(end, stageEnd(stage));
      });
      return end + signal.glowMs;
    };

    const applyNodeGlow = (nodeIndex, elapsed, fireAt, duration) => {
      if (elapsed < fireAt) return;
      const glow = clampValue(1 - (elapsed - fireAt) / duration, 0, 1);
      if (glow > 0) nodes[nodeIndex].g = Math.max(nodes[nodeIndex].g, glow);
    };

    const updateNodePositions = (now) => {
      const drift = W <= 680 ? 4 : 7;
      nodes.forEach((node) => {
        node.x = node.bx + Math.sin(now * 0.00018 + node.phase) * drift;
        node.y = node.by + Math.cos(now * 0.00016 + node.phase * 0.7) * drift * 0.55;
        node.g = Math.max(0, node.g - 0.018);
      });
    };

    const drawReceivingNodes = (signal, elapsed) => {
      applyNodeGlow(signal.source, elapsed, 0, signal.glowMs);
      signal.stages.forEach((stage) => {
        stage.links.forEach((link) => {
          applyNodeGlow(link.b, elapsed, stage.startOffset + link.delay + stage.traceMs, signal.glowMs);
        });
      });
    };

    const drawStageTraces = (signal, elapsed, color, scale) => {
      signal.stages.forEach((stage, stageIndex) => {
        stage.links.forEach((link) => {
          const progress = (elapsed - stage.startOffset - link.delay) / stage.traceMs;
          const a = nodes[link.a];
          const b = nodes[link.b];

          if (progress >= 0 && progress <= 1) {
            const head = clampValue(progress, 0, 1);
            const alpha = (0.1 + Math.sin(head * Math.PI) * 0.08) * scale;
            drawTrace(a, b, head, alpha, color);
          } else if (progress > 1 && progress < 1.24) {
            const fade = 1 - (progress - 1) / 0.24;
            drawStroke(a, b, (stageIndex === 1 ? 0.075 : 0.06) * fade * scale, 0.74, color);
          }
        });
      });
    };

    const drawIdleNetwork = (color, scale) => {
      links.forEach((link) => {
        const a = nodes[link.a];
        const b = nodes[link.b];
        const op = (0.018 + (a.g + b.g) * 0.024) * scale;
        drawStroke(a, b, op, 0.38, color);
      });
    };

    const drawNodes = (color, scale) => {
      nodes.forEach((n) => {
        if (n.g > 0.15) {
          const gr = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r * 10);
          gr.addColorStop(0, `rgba(${color},${n.g * 0.34 * scale})`);
          gr.addColorStop(1, `rgba(${color},0)`);
          ctx.beginPath();
          ctx.arc(n.x, n.y, n.r * 10, 0, Math.PI * 2);
          ctx.fillStyle = gr;
          ctx.fill();
        }

        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${color},${Math.min(1, (0.12 + n.g * 0.72) * scale)})`;
        ctx.fill();
      });
    };

    const drawStroke = (a, b, alpha, width, color) => {
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = `rgba(${color},${alpha})`;
      ctx.lineWidth = width;
      ctx.stroke();
    };

    const drawTrace = (a, b, progress, alpha, color) => {
      const head = clampValue(progress, 0, 1);
      if (head <= 0) return;
      const to = {
        x: lerp(a.x, b.x, head),
        y: lerp(a.y, b.y, head)
      };
      const trace = ctx.createLinearGradient(a.x, a.y, to.x, to.y);
      trace.addColorStop(0, `rgba(${color},${alpha * 0.12})`);
      trace.addColorStop(0.58, `rgba(${color},${alpha * 0.42})`);
      trace.addColorStop(1, `rgba(255,243,184,${alpha})`);

      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(to.x, to.y);
      ctx.strokeStyle = trace;
      ctx.lineWidth = 1.08;
      ctx.lineCap = "butt";
      ctx.stroke();
    };

    const drawSignal = (signal, now, color, scale) => {
      const elapsed = now - signal.start;
      drawReceivingNodes(signal, elapsed);

      ctx.save();
      ctx.shadowColor = `rgba(${color},0.5)`;
      ctx.shadowBlur = 10;
      drawStageTraces(signal, elapsed, color, scale);
      ctx.restore();

      return elapsed < signalDuration(signal);
    };

    const draw = (ts) => {
      const now = ts || performance.now();
      lastTs = now;
      const color = C();
      const scale = os();

      ctx.clearRect(0, 0, W, H);
      updateNodePositions(now);

      if (now >= nextSignalAt) {
        spawnSignal(now);
        nextSignalAt = now + 1600 + Math.random() * 1800;
      }

      drawIdleNetwork(color, scale);
      signals = signals.filter((signal) => drawSignal(signal, now, color, scale));
      drawNodes(color, scale);

      raf = requestAnimationFrame(draw);
    };

    resize();
    draw();

    window.addEventListener("resize", () => {
      cancelAnimationFrame(raf);
      resize();
      draw();
    });
  })();

</script>
