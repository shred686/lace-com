---
import { Image } from "astro:assets";
import {
  getHomeNewContent,
  type HomeLocale
} from "../data/homeNewContent";
import WorkflowStorySection from "./workflow-story/WorkflowStorySection.astro";
import whitepaperEnglish from "../assets/docs/lace_enterprise_overview_v2_ENGLISH.pdf";
import whitepaperSpanish from "../assets/docs/LACE_Enterprise_Overview_v2_SPANISH.pdf";
import laceScreen1 from "../assets/images/lace-screen1.png";
import laceScreen2 from "../assets/images/lace-screen2.png";

interface Props {
  locale?: HomeLocale;
}

const { locale = "en" } = Astro.props;

const {
  assuranceTags,
  capabilities,
  capabilityTags,
  deploymentOptions,
  trustItems,
  useCases
} = getHomeNewContent(locale);

const isSpanish = locale === "es";
const currentPath = Astro.url.pathname;
const spanishPath = currentPath === "/" ? "/es/" : `/es${currentPath}`;
const englishPath = isSpanish ? currentPath.replace(/^\/es(?=\/|$)/, "") || "/" : currentPath;
const languageToggleHref = isSpanish ? englishPath : spanishPath;
const languageToggleLabel = isSpanish ? "English" : "Español";
const brandHref = isSpanish ? "/es/" : "/";
const whitepaperUrl = isSpanish ? whitepaperSpanish : whitepaperEnglish;
const problemLeadStart = isSpanish
  ? "La mayoría de las herramientas de AI son"
  : "Most AI tools are";
const problemSlotWords = isSpanish
  ? ["rápidas.", "inteligentes.", "impresionantes."]
  : ["fast.", "smart.", "impressive."];
const problemFinalLine = isSpanish
  ? "Ninguna de ellas es confiable."
  : "None are trustworthy.";

const copy = isSpanish
  ? {
      toggleNav: "Alternar navegación",
      navCompany: "Empresa",
      navPlatform: "Plataforma",
      navUseCases: "Casos de uso",
      navTrust: "Confianza",
      navContact: "Contáctanos",
      heroTitle: "Haz que AI funcione para tu empresa.",
      heroIntro: "Infraestructura para enterprise AI.",
      heroDetail:
        "Determinant Systems ayuda a las empresas a diseñar, construir y desplegar AI workflows controlados, confiables y útiles en producción.",
      heroCtaPrimary: "DESCARGAR WHITEPAPER",
      systemStatus: "Sistema activo // protocolo online",
      whoLabel: "Quiénes somos",
      whoIndex: "01 // Identidad",
      whoTitleLead: "AI fundamentada",
      whoTitleAccent: "en tu negocio.",
      whoTitle: "Una consultoría de AI con infraestructura propia.",
      whoBody:
        "Determinant Systems ayuda a las organizaciones a pasar de experimentos de AI a sistemas de AI que pueden operar en producción. Implementamos enterprise AI workflows, construimos agentic systems para procesos de negocio complejos y desplegamos nuestra propia plataforma - LACE - para organizaciones que necesitan control total sobre cómo opera AI dentro de su entorno.",
      whoBody2:
        "Trabajamos con empresas que no pueden permitirse outputs impredecibles: industrias reguladas, programas gubernamentales, servicios profesionales y cualquier equipo donde una respuesta incorrecta no es solo molesta - es una responsabilidad.",
      whoCta: "Arquitectura del protocolo",
      whoDiagramTop: "Ingestion",
      whoDiagramCore: "LACE ORCHESTRATION",
      whoDiagramCoreSub: "observe // route // verify",
      whoDiagramBottom: "Synthesis",
      whoDiagramLeft: "Deterministic",
      whoDiagramRight: "Adaptive",
      whoDiagramRail: "WORKFLOW-COMPILED // POLICY-BOUND",
      whoDiagramVersion: "LACE CORE // v4.2",
      introLabel: "El problema",
      introTitle: "La mayoría de las herramientas de AI son rápidas.",
      introBody: "Muy pocas son confiables.",
      problemCards: [
        {
          title: "Chatbots genéricos",
          body:
            "Rápidos y capaces, pero imposibles de gobernar. Sin policies, sin audit trail y sin forma de imponer consistencia. Haz la misma pregunta dos veces y obtendrás dos respuestas distintas. Inaceptable en cualquier entorno regulado o de alto riesgo."
        },
        {
          title: "Custom AI builds",
          body:
            "Precisos y controlables, pero caros, lentos y frágiles. Cada uno se construye desde cero, tarda meses en entregarse y sirve exactamente a un use case. Cuando cambian los requisitos, empiezas de nuevo."
        },
        {
          title: "Lo que realmente se necesita",
          body:
            "AI que opere dentro de reglas reales de negocio. Outputs auditables. Resultados consistentes. La capacidad de revisar, aprobar y rastrear cada decisión sin un ciclo de desarrollo de seis meses para cada nuevo workflow."
        }
      ],
      workflowLabel: "Plataforma // Workflow",
      workflowTitle: "Cómo un use case se convierte en un sistema funcional.",
      workflowBody:
        "En lugar de pedirle a AI respuestas aisladas, los equipos definen el workflow una vez y dejan que LACE lo ejecute como un proceso gobernado que pueden reutilizar, inspeccionar y mejorar.",
      ourPlatformLabel: "Nuestra plataforma",
      ourPlatformTitle: "Presentamos LACE.",
      ourPlatformBody:
        "LACE es una enterprise AI platform que convierte business workflows en sistemas gobernados y repetibles. Tú defines lo que debe hacer el proceso — los inputs, las reglas, los outputs — y LACE lo compila en un pipeline que ejecuta AI dentro de pasos controlados, valida cada resultado antes de que cuente y mantiene un registro completo de todo lo que ocurrió.",
      ourPlatformSub:
        "Piensa en ello como la capa operativa entre un modelo de AI potente y tu negocio real — asegurando que AI haga lo que necesitas, de la manera que lo necesitas, cada vez.",
      platformIntroTitleAccent: "AGENTIC AI",
      platformIntroTitleRestLines: ["GOBERNADA POR POLICY,", "CON AUDIT TRAIL"],
      ragTitleStruck: "Chat sobre tus documentos",
      ragTitleActive: "Desbloquea inteligencia en toda tu empresa",
      ragTitleActiveLines: ["Desbloquea inteligencia", "en toda tu empresa"],
      ragOverviewTitle: "Retrieval Augmented Generation",
      ragOverviewLead:
        "La mayoría de los productos RAG recuperan TEXT. LACE recupera EVIDENCE.",
      ragOverviewBody:
        "Esta es la diferencia entre un sistema que suena correcto y un sistema que puede demostrarlo.",
      ragPositioningLabel: "Posicionamiento RAG v2",
      ragOverviewItems: [
        {
          title: "Documentos, comprendidos por completo",
          body: [
            "Los documentos no se aplanan; se modelan.",
            "Tablas, charts, cláusulas, secciones y contexto narrativo se convierten en un sistema estructurado y multimodal sobre el que el modelo puede razonar."
          ]
        },
        {
          title: "Evidencia, no chunks",
          body: [
            "Facts, claims, celdas de tabla, regiones visuales y source links son objetos de primera clase.",
            "Los text chunks son solo una proyección, no la base."
          ]
        },
        {
          title: "Retrieval que coincide con la pregunta",
          body: [
            "Cada pregunta es distinta.",
            "Numeric lookup, table execution, semantic search, graph traversal, multi-hop reasoning: LACE enruta la query antes de gastar compute."
          ]
        },
        {
          title: "Respuestas desde la fuente correcta",
          body: [
            "Si la respuesta es un número, viene de una tabla. Si es una explicación, viene del contexto.",
            "No más adivinar desde párrafos."
          ]
        },
        {
          title: "Un graph de evidencia",
          body: [
            "Cada pieza de evidencia está conectada:",
            "Qué pasó → dónde aparece → qué lo explica → qué lo respalda o contradice",
            "El sistema no solo hace retrieval; razona sobre relaciones."
          ]
        },
        {
          title: "Cuando search no basta",
          body: [
            "Algunas preguntas requieren todo.",
            "Auditorías, trend analysis, comparaciones full-corpus: LACE puede pasar de retrieval a procesamiento exhaustivo cuando la precisión importa."
          ]
        },
        {
          title: "Respuestas en las que puedes confiar",
          body: [
            "Cada respuesta está grounded en structured evidence.",
            "Generation y verification están separadas, para que puedas inspeccionar el razonamiento antes de confiar en el output."
          ]
        }
      ],
      capabilitiesLabel: "Capacidades de la plataforma",
      capabilitiesTitle: "Lo que hace que LACE sea distinto de un AI wrapper.",
      capabilitiesBody:
        "LACE no es una capa delgada sobre una AI API. Es un execution environment completo — con type-checked pipelines, una policy enforcement layer, provenance completa en cada output y un publishing system que convierte workflows probados en software desplegable.",
      useCasesLabel: "Casos de uso",
      useCasesTitle: "Toda empresa tiene un proceso que AI podría manejar — pero no puede confiar en que lo haga.",
      useCasesBody:
        "LACE no reemplaza esos instintos. Le da a AI la estructura, las reglas y la supervisión que la hacen utilizable en entornos reales de negocio.",
      spotlight: "Destacado",
      typicalInputs: "Inputs típicos",
      laceFit: "Cómo encaja LACE",
      whatYouGet: "Lo que obtienes",
      trustTitle: "Controles de confianza",
      trustHeading: "AI que puedes auditar, no AI que suele acertar.",
      deploymentTitle: "Opciones de despliegue",
      deploymentHeading: "Despliega en cualquier lugar. Tu entorno, tus reglas.",
      ctaLabel: "Comienza",
      ctaTitle: "¿Listo para ejecutar AI de la manera correcta?",
      ctaTitleAccent: "de la manera correcta?",
      ctaBody:
        "Cuéntanos qué proceso intentas gobernar. Te mostraremos cómo LACE lo maneja - o lo construiremos por ti.",
      ctaPrimary: "Habla con nosotros",
      ctaSecondary: "Descargar enterprise overview →",
      runtime: "LACE_RUNTIME_PROTOCOL_V3",
      sourceGrounded: "Source-grounded",
      footerTagline: "Infraestructura de enterprise AI",
      security: "Seguridad",
      privacy: "Privacidad",
      workflows: "Workflows",
      traceable: "Trazable",
      blackBoxes: "Black Boxes",
      deployModes: "Modos de despliegue",
      readyForExecution: "LISTO_PARA_EJECUTAR"
    }
  : {
      toggleNav: "Toggle navigation",
      navCompany: "Company",
      navPlatform: "Platform",
      navUseCases: "Use Cases",
      navTrust: "Trust",
      navContact: "Contact us",
      heroTitle: "Make AI work for your company.",
      heroIntro: "Infrastructure for enterprise AI.",
      heroDetail:
        "Determinant Systems helps companies design, build, and deploy AI workflows that are controlled, reliable, and useful in production.",
      heroCtaPrimary: "DOWNLOAD WHITEPAPER",
      systemStatus: "System active // protocol online",
      whoLabel: "Who We Are",
      whoIndex: "01 // Identity",
      whoTitleLead: "AI that is Grounded",
      whoTitleAccent: " In your business.",
      whoTitle: "An AI consultancy with its own infrastructure.",
      whoBody:
        "Determinant Systems helps organizations move from AI experiments to AI systems they can run in production. We implement enterprise AI workflows, build agentic systems for complex business processes, and deploy our own platform - LACE - for organizations that need full control over how AI operates inside their environment.",
      whoBody2:
        "We work with businesses that can't afford unpredictable outputs: regulated industries, government programs, professional services, and any team where a wrong answer isn't just annoying - it's a liability.",
      whoCta: "Protocol Architecture",
      whoDiagramTop: "Ingestion",
      whoDiagramCore: "LACE ORCHESTRATION",
      whoDiagramCoreSub: "observe // route // verify",
      whoDiagramBottom: "Synthesis",
      whoDiagramLeft: "Deterministic",
      whoDiagramRight: "Adaptive",
      whoDiagramRail: "WORKFLOW-COMPILED // POLICY-BOUND",
      whoDiagramVersion: "LACE CORE // v4.2",
      introLabel: "The Problem",
      introTitle: "Most AI tools are fast.",
      introBody: "Very few are trustworthy.",
      problemCards: [
        {
          title: "Generic chatbots",
          body:
            "Fast and capable, but impossible to govern. No policies, no audit trail, no way to enforce consistency. Ask the same question twice and get two different answers. Unacceptable in any regulated or high-stakes environment."
        },
        {
          title: "Custom AI builds",
          body:
            "Precise and controllable, but expensive, slow, and brittle. Each one is built from scratch, takes months to deliver, and serves exactly one use case. When requirements change, you start over."
        },
        {
          title: "What's actually needed",
          body:
            "AI that operates inside real business rules. Auditable outputs. Consistent results. The ability to review, approve, and trace every decision without a six-month build cycle for every new workflow."
        }
      ],
      workflowLabel: "Platform // Workflow",
      workflowTitle: "How a use case becomes a working system.",
      workflowBody:
        "Instead of asking AI for one-off answers, teams define the workflow once and let LACE run it as a governed process they can reuse, inspect, and improve.",
      ourPlatformLabel: "Our Platform",
      ourPlatformTitle: "Introducing LACE.",
      ourPlatformBody:
        "LACE is an enterprise AI platform that turns business workflows into governed, repeatable systems. You define what the process should do — the inputs, the rules, the outputs — and LACE compiles it into a pipeline that runs AI inside controlled steps, validates every result before it counts, and keeps a complete record of everything that happened.",
      ourPlatformSub:
        "Think of it as the operational layer that sits between a powerful AI model and your actual business — making sure the AI does what you need, the way you need it, every time.",
      platformIntroTitleAccent: "AGENTIC AI",
      platformIntroTitleRestLines: ["POLICY GOVERNED,", "WITH AN AUDIT TRAIL"],
      ragTitleStruck: "Chat over your documents",
      ragTitleActive: "Unlock intelligence over your entire enterprise",
      ragTitleActiveLines: ["Unlock intelligence", "over your entire enterprise"],
      ragOverviewTitle: "Retrieval Augmented Generation",
      ragOverviewLead:
        "Most RAG products retrieve TEXT. LACE retrieves EVIDENCE.",
      ragOverviewBody:
        "This is the difference between a system that sounds right and a system that can prove it.",
      ragPositioningLabel: "RAG v2 positioning",
      ragOverviewItems: [
        {
          title: "Documents, fully understood",
          body: [
            "Documents aren’t flattened—they’re modeled.",
            "Tables, charts, clauses, sections, and narrative context become a structured, multimodal system the model can reason over."
          ]
        },
        {
          title: "Evidence, not chunks",
          body: [
            "Facts, claims, table cells, visual regions, and source links are first-class objects.",
            "Text chunks are just one projection—not the foundation."
          ]
        },
        {
          title: "Retrieval that matches the question",
          body: [
            "Every question is different.",
            "Numeric lookup, table execution, semantic search, graph traversal, multi-hop reasoning—LACE routes the query before it spends compute."
          ]
        },
        {
          title: "Answers from the right source",
          body: [
            "If the answer is a number, it comes from a table. If it’s an explanation, it comes from context.",
            "No more guessing from paragraphs."
          ]
        },
        {
          title: "A graph of evidence",
          body: [
            "Every piece of evidence is connected:",
            "What happened → where it appears → what explains it → what supports or contradicts it",
            "The system doesn’t just retrieve—it reasons over relationships."
          ]
        },
        {
          title: "When search isn’t enough",
          body: [
            "Some questions require everything.",
            "Audits, trend analysis, full-corpus comparisons—LACE can shift from retrieval to exhaustive processing when precision matters."
          ]
        },
        {
          title: "Answers you can trust",
          body: [
            "Every response is grounded in structured evidence.",
            "Generation and verification are separated—so you can inspect the reasoning before trusting the output."
          ]
        }
      ],
      capabilitiesLabel: "Platform Capabilities",
      capabilitiesTitle: "What makes LACE different from an AI wrapper.",
      capabilitiesBody:
        "LACE isn't a thin layer on top of an AI API. It's a full execution environment — with type-checked pipelines, a policy enforcement layer, full provenance on every output, and a publishing system that turns proven workflows into deployable software.",
      useCasesLabel: "Use Cases",
      useCasesTitle: "Every business has a process that AI could handle — but can't trust it to.",
      useCasesBody:
        "LACE doesn't replace those instincts. It gives AI the structure, the rules, and the oversight that makes it usable in real business environments.",
      spotlight: "Spotlight",
      typicalInputs: "Typical inputs",
      laceFit: "How LACE fits",
      whatYouGet: "What you get",
      trustTitle: "Trust controls",
      trustHeading: "AI you can audit, not AI that is usually right.",
      deploymentTitle: "Deployment options",
      deploymentHeading: "Deploy anywhere. Your environment, your rules.",
      ctaLabel: "Get started",
      ctaTitle: "Ready to run AI the right way?",
      ctaTitleAccent: "the right way?",
      ctaBody:
        "Tell us what process you're trying to govern. We'll show you how LACE handles it - or build it for you.",
      ctaPrimary: "Talk to us",
      ctaSecondary: "Download the enterprise overview →",
      runtime: "LACE_RUNTIME_PROTOCOL_V3",
      sourceGrounded: "Source-grounded",
      footerTagline: "Enterprise AI infrastructure",
      security: "Security",
      privacy: "Privacy",
      workflows: "Workflows",
      traceable: "Traceable",
      blackBoxes: "Black Boxes",
      readyForExecution: "READY_FOR_EXECUTION"
    };

const useCaseIcons = ["→", "◻", "⊕", "◈", "⋯", "⬡"];
const heroTitleWords = copy.heroTitle.split(" ");
const heroDesktopTitleLead = heroTitleWords.slice(0, 4).join(" ");
const heroDesktopTitleRest = heroTitleWords.slice(4).join(" ");
const heroMobileTitleLines = isSpanish
  ? ["Haz", "que AI", "funcione", "para", "tu empresa."]
  : ["Make", "AI", "work", "for", "you."];
const getBodyParagraphs = (body: string | string[]) =>
  Array.isArray(body) ? body : [body];

const year = new Date().getFullYear();
---

<main class:list={["official-home", isSpanish && "official-home-es"]}>
  <canvas id="neural-canvas" class="neural-canvas" aria-hidden="true"></canvas>
  <div class="scan-line" aria-hidden="true"></div>

  <header id="topnav" class="official-topnav" data-r>
    <div class="official-topnav-inner">
      <a href={brandHref} class="brand-mark">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="3" fill="#00FFC2"></circle>
          <circle cx="9" cy="9" r="6.5" stroke="#00FFC2" stroke-width="0.5" opacity="0.4"></circle>
          <circle cx="9" cy="9" r="9" stroke="#00FFC2" stroke-width="0.3" opacity="0.15"></circle>
        </svg>
        <span>DETERMINANT SYSTEMS</span>
      </a>

      <button class="official-topnav-toggle" type="button" aria-expanded="false" aria-label={copy.toggleNav}>
        <span></span>
        <span></span>
      </button>

        <div class="official-topnav-panel" id="topNavPanel">
          <nav class="official-topnav-links" aria-label="Primary">
          <a href="#lace">{copy.navCompany}</a>
          <a href="#platform">{copy.navPlatform}</a>
          <a href="#use-cases">{copy.navUseCases}</a>
          <!-- <a href="#trust">{copy.navTrust}</a> -->
        </nav>

        <div class="official-topnav-actions">
          <a href={languageToggleHref} class="nav-language-toggle">{languageToggleLabel}</a>
          <a href="/contact" class="nav-deploy-link">{copy.navContact}</a>
        </div>
      </div>
    </div>
  </header>

  <section class="official-hero section-shell">
    <div class="hero-radial-glow" aria-hidden="true"></div>

    <div class="official-hero-content" data-r>
      <!-- <div class="hero-status-pill">
        <div class="pulse-dot tiny"></div>
        <span>{copy.systemStatus}</span>
      </div> -->

      <h1 aria-label={copy.heroTitle}>
        <span class="hero-title-desktop" aria-hidden="true">
          {heroDesktopTitleLead}<br />
          <span class="accent-glow">{heroDesktopTitleRest}</span>
        </span>
        <span class="hero-title-mobile" aria-hidden="true">
          {heroMobileTitleLines.map((line, index) => (
            <span
              class:list={[
                "hero-title-line",
                `hero-title-line-${index + 1}`,
                index === heroMobileTitleLines.length - 1 && "accent-glow"
              ]}
            >
              {line}
            </span>
          ))}
        </span>
      </h1>

      <p class="hero-intro">{copy.heroIntro}</p>
      <p class="hero-detail">{copy.heroDetail}</p>

      <div class="hero-actions">
        <a href={whitepaperUrl} target="_blank" rel="noopener noreferrer" class="hero-btn hero-btn-primary">
          {copy.heroCtaPrimary}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5"></path>
          </svg>
        </a>
      </div>

    </div>

    <div class="hero-bottom-glow" aria-hidden="true"></div>
  </section>

  <!-- <div class="official-marquee section-shell" aria-hidden="true">
    <div class="marquee-fade-left"></div>
    <div class="marquee-fade-right"></div>
    <div class="mq-track">
      {[...capabilityTags, ...capabilityTags].map((tag) => (
        <>
          <span>{tag}</span>
          <strong>-</strong>
        </>
      ))}
    </div>
  </div> -->

  <section class="company-intro problem-scroll-section section-shell" data-problem-scroll>
    <span id="platform" class="problem-platform-anchor" aria-hidden="true"></span>
    <div class="problem-scroll-pin">
      <div class="problem-scroll-copy" data-problem-copy>
        <p class="section-kicker problem-scroll-kicker">{copy.introLabel}</p>
        <h2 class="problem-scroll-line" data-problem-line data-problem-words={problemSlotWords.join("|")}>
          <span>{problemLeadStart}</span>
          <span class="problem-slot" aria-live="polite">
            <span data-problem-word>{problemSlotWords[0]}</span>
          </span>
        </h2>
        <h2 class="problem-scroll-final lace-accent-word" data-problem-final>{problemFinalLine}</h2>
        <h2
          class="problem-scroll-lace"
          data-problem-lace
          set:html={copy.ourPlatformTitle.replace("LACE", '<span class="lace-accent-word">LACE</span>')}
        ></h2>
      </div>
    </div>
  </section>

  <div id="light-zone" class="lace-light-zone">

  <section class="platform-intro section-shell">
    <div class="platform-intro-layout" data-r>
      <div class="platform-intro-copy">
        <h2 class="platform-intro-title">
          <span class="platform-intro-title-accent">{copy.platformIntroTitleAccent}</span>
          <span class="platform-intro-title-rest">
            {copy.platformIntroTitleRestLines.map((line, index) => (
              <>
                {line}
                {index < copy.platformIntroTitleRestLines.length - 1 && <br />}
              </>
            ))}
          </span>
        </h2>
        <p class="platform-intro-body">{copy.ourPlatformBody}</p>
        <!-- <p class="platform-intro-sub">{copy.ourPlatformSub}</p> -->
      </div>

      <div class="platform-intro-showcase" aria-label="LACE platform screenshots">
        <figure class="platform-intro-card platform-intro-card-back" aria-hidden="true">
          <Image
            src={laceScreen1}
            alt=""
            class="platform-intro-shot-image"
            widths={[760, 980, 1260]}
            sizes="(max-width: 980px) 86vw, 42vw"
          />
        </figure>

        <figure class="platform-intro-card platform-intro-card-front">
          <Image
            src={laceScreen2}
            alt="LACE platform workflow orchestration screenshot"
            class="platform-intro-shot-image"
            widths={[760, 980, 1260, 1500]}
            sizes="(max-width: 980px) 96vw, 58vw"
          />
        </figure>
      </div>
    </div>
  </section>

  <div class="neural-separator section-shell" aria-hidden="true"></div>

  <WorkflowStorySection
    locale={locale}
    headlineLead={copy.whoTitleLead}
    headlineAccent={copy.whoTitleAccent}
  />

  <div class="neural-separator section-shell" aria-hidden="true"></div>

  <section class="how-it-works rag-overview section-shell">
    <div class="rag-scroll-stage" data-rag-scroll>
      <div class="rag-scroll-pin">
        <div class="rag-scroll-copy">
          <h2 class="rag-scroll-title" aria-label={`${copy.ragTitleStruck}. ${copy.ragTitleActive}`}>
            <s class="rag-scroll-struck">{copy.ragTitleStruck}</s>
            <span class="rag-scroll-active" aria-hidden="true">
              {copy.ragTitleActiveLines.map((line) => (
                <span>{line}</span>
              ))}
            </span>
          </h2>
        </div>
      </div>
    </div>

    <div class="rag-overview-content">
      <h2 class="rag-overview-title" data-r data-reveal-delay="0">{copy.ragOverviewTitle}</h2>

      <div class="rag-overview-intro" data-r data-reveal-delay="80">
        <p class="rag-overview-lead">{copy.ragOverviewLead}</p>
        <p>{copy.ragOverviewBody}</p>
      </div>

      <!-- <div class="rag-positioning-label" data-r data-reveal-delay="140">{copy.ragPositioningLabel}</div> -->

      <div class="rag-overview-grid">
        {copy.ragOverviewItems.map((item, index) => (
          <article class="glass-card rag-evidence-card" data-r data-reveal-delay={180 + index * 55}>
            <span class="rag-evidence-index">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3>{item.title}</h3>
              {getBodyParagraphs(item.body).map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <div class="neural-separator section-shell" aria-hidden="true"></div>

  <section class="platform-capabilities section-shell">
    <div class="section-head" data-r>
      <p class="section-kicker">{copy.capabilitiesLabel}</p>
