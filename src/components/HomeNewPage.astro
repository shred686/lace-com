---

<main class="official-home">
  <canvas id="neural-canvas" class="neural-canvas" aria-hidden="true"></canvas>
  <div class="scan-line" aria-hidden="true"></div>

  <header id="topnav" class="official-topnav" data-r>
    <div class="official-topnav-inner">
      <a href={brandHref} class="brand-mark">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="3" fill="#00FFC2"></circle>
          <circle cx="9" cy="9" r="6.5" stroke="#00FFC2" stroke-width="0.5" opacity="0.4"></circle>
          <circle cx="9" cy="9" r="9" stroke="#00FFC2" stroke-width="0.3" opacity="0.15"></circle>
        </svg>
        <span>DETERMINANT SYSTEMS</span>
      </a>

      <button class="official-topnav-toggle" type="button" aria-expanded="false" aria-label={copy.toggleNav}>
        <span></span>
        <span></span>
      </button>

      <div class="official-topnav-panel" id="topNavPanel">
        <nav class="official-topnav-links" aria-label="Primary">
          <a href="#lace">Company</a>
          <a href="#platform">{copy.navPlatform}</a>
          <a href="#use-cases">{copy.navUseCases}</a>
          <!-- <a href="#trust">{copy.navTrust}</a> -->
        </nav>

        <div class="official-topnav-actions">
          <a href={languageToggleHref} class="nav-language-toggle">{languageToggleLabel}</a>
          <a href="/contact" class="nav-deploy-link">{copy.navContact}</a>
        </div>
      </div>
    </div>
  </header>

  <section class="official-hero section-shell">
    <div class="hero-vertical-lines" aria-hidden="true">
      <div class="hero-line hero-line-a">
        <div class="pulse-dot dot-a"></div>
        <div class="small-dot dot-b"></div>
      </div>
      <div class="hero-line hero-line-b">
        <div class="small-dot dot-c"></div>
      </div>
      <div class="hero-line hero-line-c"></div>
      <div class="hero-line hero-line-d"></div>
      <div class="hero-line hero-line-e">
        <div class="pulse-dot dot-d"></div>
        <div class="small-dot dot-e"></div>
      </div>
    </div>

    <div class="hero-radial-glow" aria-hidden="true"></div>

    <div class="official-hero-content" data-r>
      <!-- <div class="hero-status-pill">
        <div class="pulse-dot tiny"></div>
        <span>{copy.systemStatus}</span>
      </div> -->

      <h1>
        {copy.heroTitle.split(" ").slice(0, 4).join(" ")}<br />
        <span class="accent-glow">{copy.heroTitle.split(" ").slice(4).join(" ")}</span>
      </h1>

      <p class="hero-intro">{copy.heroIntro}</p>
      <p class="hero-detail">{copy.heroDetail}</p>

      <div class="hero-actions">
        <a href={whitepaperUrl} target="_blank" rel="noopener noreferrer" class="hero-btn hero-btn-primary">
          {copy.heroCtaPrimary}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5"></path>
          </svg>
        </a>
      </div>

      <div class="hero-proof-list">
        {heroProofs.map((proof) => (
          <span>{proof}</span>
        ))}
      </div>
    </div>

    <div class="hero-bottom-glow" aria-hidden="true"></div>
    <div class="hero-scroll-cue" aria-hidden="true">
      <span>Scroll</span>
      <div></div>
    </div>
  </section>

  <div class="official-marquee section-shell" aria-hidden="true">
    <div class="marquee-fade-left"></div>
    <div class="marquee-fade-right"></div>
    <div class="mq-track">
      {[...capabilityTags, ...capabilityTags].map((tag) => (
        <>
          <span>{tag}</span>
          <strong>-</strong>
        </>
      ))}
    </div>
  </div>

  <section id="lace" class="who-identity">
    <div class="who-identity-shell section-shell">
      <div class="who-identity-layout">
        <div class="who-identity-copy" data-r>
          <!-- <p class="who-identity-kicker">{copy.whoIndex}</p> -->
          <h2 class="who-identity-title">
            {copy.whoTitleLead}
            <br />
            <span>{copy.whoTitleAccent}</span>
          </h2>

          <div class="who-identity-body who-identity-body-main">
            <p>{copy.whoBody}</p>
          </div>

          <div class="who-identity-body who-identity-body-secondary">
            <p>{copy.whoBody2}</p>
          </div>

          <a href="#platform" class="who-identity-link">
            <span>{copy.whoCta}</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2.5 8h10M9 4.5 12.5 8 9 11.5" stroke="currentColor" stroke-width="1.4"></path>
            </svg>
          </a>
        </div>

        <div class="who-identity-stage" data-r data-reveal-delay="120">
          <div class="who-identity-stage-scale">
            <div
              class="who-identity-diagram"
              id="identity-diagram"
              data-flow-phase="idle"
              data-status-queued={identityWorkflowMeta.statusQueued}
              data-status-running={identityWorkflowMeta.statusRunning}
              data-status-succeeded={identityWorkflowMeta.statusSucceeded}
            >
              <div class="who-grid-fade who-grid-fade-left" aria-hidden="true"></div>
              <div class="who-grid-fade who-grid-fade-right" aria-hidden="true"></div>
              <div class="who-grid-glow" aria-hidden="true"></div>

              <div class="who-flow-hud">
                <div>
                  <p class="who-flow-hud-kicker">{identityWorkflowMeta.hudLabel}</p>
                  <h3>{identityWorkflowMeta.title}</h3>
                </div>
                <div class="who-flow-hud-meta">
                  <span class="who-flow-hud-badge">{identityWorkflowMeta.badge}</span>
                  <span class="who-flow-hud-run">{identityWorkflowMeta.runId}</span>
                  <span class="who-flow-hud-progress" data-flow-progress>{identityWorkflowMeta.progressIdle}</span>
                  <span class="who-flow-hud-status" data-flow-status>{identityWorkflowMeta.statusQueued}</span>
                </div>
              </div>

              <div class="who-flow-canvas">
                <svg class="who-flow-edges" viewBox="0 0 786 812" fill="none" aria-hidden="true">
                  {identityWorkflowEdges.map((edge) => (
                    <>
                      <path class="who-flow-edge-base" d={edge.path}></path>
                      <path
                        class="who-flow-edge"
                        data-flow-edge
                        data-order={edge.order}
                        d={edge.path}
                        pathLength="1"
                      ></path>
                    </>
                  ))}
                </svg>

                {identityWorkflowNodes.map((node) => (
                  <article
                    class="who-flow-node"
                    data-flow-node
                    data-order={node.order}
                    data-node-id={node.id}
                    style={`left:${node.x}px;top:${node.y}px;width:${node.width}px;height:${node.height}px;--entry-x:${node.enterX}px;--entry-y:${node.enterY}px;`}
                  >
                    {node.ports?.map((port) => (
                      <span class={`who-flow-port who-flow-port-${port.kind}`} style={port.style} aria-hidden="true"></span>
                    ))}
                    <div class="who-flow-node-top">
                      <span>{String(node.order).padStart(2, "0")} // {node.badge}</span>
                      <strong data-flow-node-status>{identityWorkflowMeta.statusQueued}</strong>
                    </div>
                    <h4>{node.title}</h4>
                    <p>{node.detail}</p>
                    <div class="who-flow-node-footer">
                      <span>{node.footer}</span>
                      <span>{node.runtime}</span>
                    </div>
