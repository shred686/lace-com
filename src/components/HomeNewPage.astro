  <section id="cta-section" class="final-cta">
    <canvas id="cta-canvas" class="cta-canvas" aria-hidden="true"></canvas>
    <div class="cta-vignette" aria-hidden="true"></div>

    <div class="final-cta-content section-shell">
      <div class="cta-pill" data-r>
        <div class="pulse-dot tiny"></div>
        <span>{copy.ctaLabel}</span>
      </div>

      <h2 data-r data-reveal-delay="60" set:html={copy.ctaTitle.replace(copy.ctaTitleAccent, `<span class="lace-accent-word">${copy.ctaTitleAccent}</span>`)}></h2>

      <p data-r data-reveal-delay="140">{copy.ctaBody}</p>

      <div class="hero-actions cta-actions" data-r data-reveal-delay="220">
        <a href="/contact" class="hero-btn hero-btn-primary">
          {copy.ctaPrimary}
        </a>
        <a href={whitepaperUrl} target="_blank" rel="noopener noreferrer" class="hero-btn hero-btn-ghost">{copy.ctaSecondary}</a>
      </div>

      <div class="cta-stats" data-r data-reveal-delay="300">
        <div><strong>∞</strong><span>{copy.workflows}</span></div>
        <div><strong>100%</strong><span>{copy.traceable}</span></div>
        <div><strong>0</strong><span>{copy.blackBoxes}</span></div>
      </div>
    </div>
